@page "/admin/mailing"
@using FlomiApp.Data.Models
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@inject FlomiApp.Data.ApplicationDbContext Db
@inject IMailService MailService
@inject IAreaService AreaService
@attribute [Authorize(Roles = "Admin")]

<PageTitle>Mailing – Admin</PageTitle>

<div class="dashboard-page">

    <section class="dashboard-hero">
        <div class="dashboard-hero__content">
            <span class="dashboard-hero__badge">Administration</span>
            <h1>Mailing</h1>
            <p>Gezielte E-Mails an ausgewählte Benutzergruppen senden.</p>
        </div>
    </section>

    <div class="mail-layout">

        <!-- ── Linke Seite: Formular ── -->
        <div class="mail-form-col">

            <!-- Empfänger-Auswahl -->
            <div class="mail-card">
                <h3 class="mail-card__title">👥 Empfänger</h3>

                <div class="mail-field">
                    <label>Zielgruppe</label>
                    <select class="mail-select" @bind="targetGroup" @bind:after="UpdatePreview">
                        <option value="all">Alle Benutzer</option>
                        <option value="event">Angemeldete eines Events</option>
                        <option value="area">Angemeldete eines Bereichs</option>
                        <option value="fahrer">Alle Fahrer</option>
                        <option value="beifahrer">Alle Beifahrer</option>
                        <option value="pickups">Offene Möbelanfragen</option>
                        <option value="stufe">Nach Stufe</option>
                    </select>
                </div>

                @if (targetGroup is "event" or "area" or "fahrer" or "beifahrer")
                {
                    <div class="mail-field">
                        <label>Event</label>
                        <select class="mail-select" @bind="filterEventId" @bind:after="UpdatePreview">
                            <option value="0">– Alle Events –</option>
                            @foreach (var ev in events)
                            {
                                <option value="@ev.Id">@ev.Name (@ev.Date.ToShortDateString())</option>
                            }
                        </select>
                    </div>
                }

                @if (targetGroup == "area")
                {
                    <div class="mail-field">
                        <label>Bereich</label>
                        <select class="mail-select" @bind="filterAreaId" @bind:after="UpdatePreview">
                            <option value="0">– Alle Bereiche –</option>
                            @foreach (var a in areas)
                            {
                                <option value="@a.Id">@(a.AreaTemplate?.Name) · @a.Date.ToString("dd.MM")</option>
                            }
                        </select>
                    </div>
                }

                @if (targetGroup == "stufe")
                {
                    <div class="mail-field">
                        <label>Stufe</label>
                        <select class="mail-select" @bind="filterStufe" @bind:after="UpdatePreview">
                            <option value="">– Alle Stufen –</option>
                            <option value="Biber">Biber</option>
                            <option value="Wolf">Wolf</option>
                            <option value="Pfadi">Pfadi</option>
                            <option value="Pio">Pio</option>
                            <option value="Leiter">Leiter</option>
                            <option value="Sonstiges">Sonstiges</option>
                        </select>
                    </div>
                }

                <!-- Vorschau -->
                <div class="mail-preview-badge">
                    @if (isLoadingPreview)
                    {
                        <span>⏳ Berechne…</span>
                    }
                    else
                    {
                        <span class="@(recipients.Count > 0 ? "mail-preview-badge--ok" : "mail-preview-badge--empty")">
                            @recipients.Count Empfänger
                        </span>
                        @if (recipients.Count > 0)
                        {
                            <span class="mail-preview-list">
                                @string.Join(", ", recipients.Take(3).Select(r => r.Name))
                                @if (recipients.Count > 3) { <text> +@(recipients.Count - 3) weitere</text> }
                            </span>
                        }
                    }
                </div>
            </div>

            <!-- Nachricht -->
            <div class="mail-card">
                <h3 class="mail-card__title">✉️ Nachricht</h3>

                <div class="mail-field">
                    <label>Betreff *</label>
                    <input type="text" class="mail-input" @bind="subject"
                           placeholder="z.B. Wichtige Info zum Flomi 2027" />
                </div>

                <div class="mail-field">
                    <label>Nachricht *</label>
                    <textarea class="mail-textarea" rows="8" @bind="body"
                              placeholder="Deine Nachricht an die Empfänger..."></textarea>
                </div>
            </div>

            <!-- Aktionen -->
            <div class="mail-actions">
                <button class="mail-send-btn"
                        @onclick="SendMails"
                        disabled="@(isSending || recipients.Count == 0 || string.IsNullOrWhiteSpace(subject) || string.IsNullOrWhiteSpace(body))">
                    @if (isSending)
                    {
                        <span>⏳ Wird gesendet (@sentCount / @recipients.Count)…</span>
                    }
                    else
                    {
                        <span>📨 An @recipients.Count Person(en) senden</span>
                    }
                </button>
            </div>
        </div>

        <!-- ── Rechte Seite: Ergebnis / Verlauf ── -->
        <div class="mail-result-col">
            @if (result != null)
            {
                <div class="mail-card mail-card--result @(result.Errors == 0 ? "mail-card--success" : "mail-card--warn")">
                    <h3 class="mail-card__title">
                        @(result.Errors == 0 ? "✅ Erfolgreich gesendet" : "⚠️ Teilweise gesendet")
                    </h3>
                    <p>@result.Sent von @result.Total Mails zugestellt.</p>
                    @if (result.Errors > 0)
                    {
                        <p style="color:var(--color-error-text)">@result.Errors Fehler beim Senden.</p>
                    }
                    <small>@result.SentAt.ToString("dd.MM.yyyy HH:mm")</small>
                </div>
            }

            <div class="mail-card mail-hint">
                <h3 class="mail-card__title">ℹ️ Hinweise</h3>
                <ul style="margin:.5rem 0 0;padding-left:1.2rem;font-size:.88rem;color:var(--color-text-medium);line-height:1.8">
                    <li>Nur Benutzer mit aktivierten E-Mail-Benachrichtigungen erhalten die Mail.</li>
                    <li>Mails werden einzeln versendet — kein CC/BCC.</li>
                    <li>Grosse Mengen (>50) können etwas Zeit brauchen.</li>
                    <li>Der Betreff wird mit «FlomiApp: » vorangestellt.</li>
                </ul>
            </div>
        </div>

    </div>
</div>

@code {
    private List<Event>                events         = new();
    private List<Area>                 areas          = new();
    private string                     targetGroup    = "all";
    private int                        filterEventId  = 0;
    private int                        filterAreaId   = 0;
    private string                     filterStufe    = "";
    private string                     subject        = "";
    private string                     body           = "";
    private bool                       isSending      = false;
    private bool                       isLoadingPreview = false;
    private int                        sentCount      = 0;

    private record Recipient(string Email, string Name);
    private List<Recipient> recipients = new();

    private record SendResult(int Sent, int Errors, int Total, DateTime SentAt);
    private SendResult? result = null;

    protected override async Task OnInitializedAsync()
    {
        events = await Db.Events.OrderByDescending(e => e.IsActive).ThenBy(e => e.Date).ToListAsync();
        areas  = await Db.Areas
            .Include(a => a.AreaTemplate)
            .OrderBy(a => a.Date)
            .ThenBy(a => a.AreaTemplate!.Name)
            .AsNoTracking()
            .ToListAsync();
        await UpdatePreview();
    }

    private async Task UpdatePreview()
    {
        isLoadingPreview = true;
        StateHasChanged();
        recipients = await BuildRecipients();
        isLoadingPreview = false;
    }

    private async Task<List<Recipient>> BuildRecipients()
    {
        return targetGroup switch
        {
            "all" => await Db.Users
                .Where(u => u.EmailNotificationsEnabled && u.Email != null)
                .Select(u => new Recipient(u.Email!, $"{u.FirstName} {u.LastName}"))
                .ToListAsync(),

            "event" => await Db.Appointments
                .Include(a => a.User)
                .Where(a => a.Status == AppointmentStatus.Registered
                         && a.User.EmailNotificationsEnabled
                         && a.User.Email != null
                         && (filterEventId == 0 || a.Area.EventId == filterEventId))
                .Select(a => new Recipient(a.User.Email!, $"{a.User.FirstName} {a.User.LastName}"))
                .Distinct()
                .ToListAsync(),

            "area" => await Db.Appointments
                .Include(a => a.User)
                .Where(a => a.Status == AppointmentStatus.Registered
                         && a.User.EmailNotificationsEnabled
                         && a.User.Email != null
                         && (filterEventId == 0 || a.Area.EventId == filterEventId)
                         && (filterAreaId == 0 || a.AreaId == filterAreaId))
                .Select(a => new Recipient(a.User.Email!, $"{a.User.FirstName} {a.User.LastName}"))
                .Distinct()
                .ToListAsync(),

            "fahrer" => await Db.AssignmentDates
                .Include(d => d.Assignment).ThenInclude(a => a.Event)
                .Where(d => d.DriverUserId != null
                         && (filterEventId == 0 || d.Assignment.EventId == filterEventId))
                .Join(Db.Users, d => d.DriverUserId, u => u.Id,
                    (d, u) => new Recipient(u.Email!, $"{u.FirstName} {u.LastName}"))
                .Where(r => r.Email != null)
                .Distinct()
                .ToListAsync(),

            "beifahrer" => await Db.AssignmentDates
                .Include(d => d.Assignment)
                .Where(d => d.HelperUserId != null
                         && (filterEventId == 0 || d.Assignment.EventId == filterEventId))
                .Join(Db.Users, d => d.HelperUserId, u => u.Id,
                    (d, u) => new Recipient(u.Email!, $"{u.FirstName} {u.LastName}"))
                .Where(r => r.Email != null)
                .Distinct()
                .ToListAsync(),

            "pickups" => await Db.FurniturePickupRequests
                .Include(r => r.User)
                .Where(r => r.Status == PickupRequestStatus.Pending
                         && r.User.EmailNotificationsEnabled
                         && r.User.Email != null)
                .Select(r => new Recipient(r.User.Email!, $"{r.User.FirstName} {r.User.LastName}"))
                .Distinct()
                .ToListAsync(),

            "stufe" => await Db.Users
                .Where(u => u.EmailNotificationsEnabled
                         && u.Email != null
                         && (string.IsNullOrEmpty(filterStufe) || u.Stufe == filterStufe))
                .Select(u => new Recipient(u.Email!, $"{u.FirstName} {u.LastName}"))
                .ToListAsync(),

            _ => new()
        };
    }

    private async Task SendMails()
    {
        if (recipients.Count == 0 || string.IsNullOrWhiteSpace(subject) || string.IsNullOrWhiteSpace(body))
            return;

        isSending  = true;
        sentCount  = 0;
        result     = null;
        int errors = 0;
        var total  = recipients.Count;

        foreach (var r in recipients)
        {
            try
            {
                var htmlBody =
                    "<div style=\"font-family:sans-serif;max-width:560px;margin:0 auto;\">" +
                    "<div style=\"background:linear-gradient(135deg,#1d4ed8,#2563eb);border-radius:16px 16px 0 0;padding:24px 28px;\">" +
                    $"<h2 style=\"margin:0;color:#fff;font-size:1.2rem;\">{subject}</h2>" +
                    "</div>" +
                    "<div style=\"background:#f8fafc;border:1px solid #e2e8f0;border-top:none;border-radius:0 0 16px 16px;padding:24px 28px;\">" +
                    $"<p style=\"margin:0 0 16px;color:#374151;\">Hallo <strong>{r.Name}</strong>,</p>" +
                    $"<div style=\"color:#374151;font-size:.95rem;line-height:1.7;white-space:pre-wrap;\">{System.Web.HttpUtility.HtmlEncode(body).Replace("\n", "<br/>")}</div>" +
                    "<p style=\"margin:20px 0 0;color:#94a3b8;font-size:.82rem;\">Diese Nachricht wurde vom Flomi-Admin versendet.</p>" +
                    "</div></div>";
                await MailService.SendAsync(r.Email, r.Name, $"FlomiApp: {subject}", htmlBody);
                sentCount++;
            }
            catch { errors++; }
            StateHasChanged();
        }

        result    = new SendResult(sentCount, errors, total, DateTime.Now);
        isSending = false;
    }
}

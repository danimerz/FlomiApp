@page "/admin/export"
@using FlomiApp.Data.Models
@using FlomiApp.Services
@using Microsoft.AspNetCore.Authorization
@using FlomiApp.Security
@attribute [Authorize(Roles = Roles.Admin)]
@inject IExportService ExportService
@inject IAreaService AreaService
@inject IJSRuntime JS

<PageTitle>Export</PageTitle>

<div class="dashboard-page">
    <section class="dashboard-hero">
        <div class="dashboard-hero__content">
            <span class="dashboard-hero__badge">Administration</span>
            <h1>Daten Export</h1>
            <p>Exportiere Listen als Excel-Datei für weitere Verarbeitung.</p>
        </div>
    </section>

    @* ── Globaler Filter: Event ── *@
    <div class="export-filter-bar">
        <div class="export-filter-bar__group">
            <label for="event-filter">Event filtern</label>
            <select id="event-filter" class="export-select" @onchange="OnEventFilterChanged">
                <option value="0">Alle Events</option>
                @foreach (var evt in events)
                {
                    <option value="@evt.Id">@evt.Name (@evt.Date.ToShortDateString())</option>
                }
            </select>
        </div>
    </div>

    @* ── Export Karten ── *@
    <div class="export-grid">

        @* ── Anmeldungen Verkauf── *@
        <div class="export-card">
            <div class="export-card__icon">📋</div>
            <div class="export-card__content">
                <h3>Anmeldungen Verkauf</h3>
                <p>Alle Anmeldungen der Kategorie «Verkauf» — Ganz- und Halbtagsschichten mit Zeitslot-Spalte.</p>
                <div class="export-card__meta">
                    <span class="export-tag">Ressort</span>
                    <span class="export-tag">Zeitslot</span>
                    <span class="export-tag">Person</span>
                    <span class="export-tag">Pfadiname</span>
                </div>
            </div>
            <div class="export-card__action">
                @if (isExporting == "appointments")
                {
                    <div class="btn-loading btn-loading--primary">
                        <span class="btn-spinner btn-spinner--blue"></span>
                        <span>Wird exportiert...</span>
                    </div>
                }
                else
                {
                    <button class="export-btn"
                            disabled="@(isExporting != null)"
                            @onclick='() => RunExport("appointments")'>
                        ⬇️ Excel exportieren
                    </button>
                }
            </div>
        </div>

        @* ── Anmeldungen Gastro── *@
        <div class="export-card">
            <div class="export-card__icon">🍳</div>
            <div class="export-card__content">
                <h3>Anmeldungen Gastro</h3>
                <p>Alle Anmeldungen der Kategorie «Gastro» — gleiche Struktur wie Verkauf.</p>
                <div class="export-card__meta">
                    <span class="export-tag">Ressort</span>
                    <span class="export-tag">Zeitslot</span>
                    <span class="export-tag">Person</span>
                    <span class="export-tag">Pfadiname</span>
                </div>
            </div>
            <div class="export-card__action">
                @if (isExporting == "gastro")
                {
                    <div class="btn-loading btn-loading--primary">
                        <span class="btn-spinner btn-spinner--blue"></span>
                        <span>Wird exportiert...</span>
                    </div>
                }
                else
                {
                    <button class="export-btn"
                            disabled="@(isExporting != null)"
                            @onclick='() => RunExport("gastro")'>
                        ⬇️ Excel exportieren
                    </button>
                }
            </div>
        </div>

        @* ── Fahrzeuge ── *@
        <div class="export-card">
            <div class="export-card__icon">🚗</div>
            <div class="export-card__content">
                <h3>Fahrzeug-Einsätze</h3>
                <p>Alle Fahrzeugzuweisungen pro Einsatztag mit Fahrer, Beifahrer und Logistikdetails.</p>
                <div class="export-card__meta">
                    <span class="export-tag">Datum</span>
                    <span class="export-tag">Fahrzeughalter</span>
                    <span class="export-tag">Fahrer</span>
                    <span class="export-tag">Beifahrer</span>
                </div>
            </div>
            <div class="export-card__action">
                @if (isExporting == "vehicles")
                {
                    <div class="btn-loading btn-loading--primary">
                        <span class="btn-spinner btn-spinner--blue"></span>
                        <span>Wird exportiert...</span>
                    </div>
                }
                else
                {
                    <button class="export-btn"
                            disabled="@(isExporting != null)"
                            @onclick='() => RunExport("vehicles")'>
                        ⬇️ Excel exportieren
                    </button>
                }
            </div>
        </div>

        @* ── Möbel-Abholungen ── *@
        <div class="export-card">
            <div class="export-card__icon">🛋️</div>
            <div class="export-card__content">
                <h3>Möbel-Abholungen</h3>
                <p>Alle Abholungsanfragen mit Adresse, Status und Admin-Notizen.</p>
                <div class="export-card__meta">
                    <span class="export-tag">Adresse</span>
                    <span class="export-tag">Status</span>
                    <span class="export-tag">Notiz</span>
                </div>
            </div>
            <div class="export-card__action">
                @if (isExporting == "pickups")
                {
                    <div class="btn-loading btn-loading--primary">
                        <span class="btn-spinner btn-spinner--blue"></span>
                        <span>Wird exportiert...</span>
                    </div>
                }
                else
                {
                    <button class="export-btn"
                            disabled="@(isExporting != null)"
                            @onclick='() => RunExport("pickups")'>
                        ⬇️ Excel exportieren
                    </button>
                }
            </div>
        </div>


    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="state-card state-card--error" style="margin-top:1.5rem">
            <div class="state-card__icon">⚠️</div>
            <div class="state-card__content">
                <h3>Fehler beim Export</h3>
                <p>@errorMessage</p>
            </div>
        </div>
    }

</div>

@code {
    private List<Event> events        = new();
    private int         selectedEventId = 0;
    private string?     isExporting   = null;
    private string      errorMessage  = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        events = (await AreaService.GetAllEventsAsync())
            .OrderBy(e => e.Date)
            .ToList();
    }

    private void OnEventFilterChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var id))
            selectedEventId = id;
    }

    // ── Umbenannt von Export() zu RunExport() ─────────────────────────────────
    private async Task RunExport(string type)
    {
        isExporting  = type;
        errorMessage = string.Empty;
        StateHasChanged();

        try
        {
            byte[] bytes;
            string fileName;

            var eventSuffix = selectedEventId > 0
                ? $"_Event{selectedEventId}"
                : "_Alle";
            var dateSuffix = DateTime.Now.ToString("yyyyMMdd_HHmm");

            switch (type)
            {
                case "appointments":
                    bytes    = await ExportService.ExportAppointmentsAsync(
                                   selectedEventId > 0 ? selectedEventId : null);
                    fileName = $"Anmeldungen Verkauf{eventSuffix}_{dateSuffix}.xlsx";
                    break;

                case "gastro":
                    bytes    = await ExportService.ExportGastroAppointmentsAsync(
                                   selectedEventId > 0 ? selectedEventId : null);
                    fileName = $"Anmeldungen Gastro{eventSuffix}_{dateSuffix}.xlsx";
                    break;

                case "vehicles":
                    bytes    = await ExportService.ExportVehicleAssignmentsAsync(
                                   selectedEventId > 0 ? selectedEventId : null);
                    fileName = $"Fahrzeuge{eventSuffix}_{dateSuffix}.xlsx";
                    break;

                case "pickups":
                    bytes    = await ExportService.ExportPickupRequestsAsync(
                                   selectedEventId > 0 ? selectedEventId : null);
                    fileName = $"Abholungen{eventSuffix}_{dateSuffix}.xlsx";
                    break;

                default:
                    return;
            }

            var base64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("downloadFile", fileName,
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                base64);
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isExporting = null;
            StateHasChanged();
        }
    }
}
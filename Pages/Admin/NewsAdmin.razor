@page "/admin/news"
@using FlomiApp.Data.Models
@using Microsoft.AspNetCore.Authorization
@inject INewsService NewsService
@using FlomiApp.Security
@attribute [Authorize(Roles = Roles.Admin)]

<PageTitle>News – Admin</PageTitle>

<div class="dashboard-page">

    <section class="dashboard-hero">
        <div class="dashboard-hero__content">
            <span class="dashboard-hero__badge">Administration</span>
            <h1>News</h1>
            <p>Verwalte Meldungen und Neuigkeiten für die Startseite.</p>
        </div>
    </section>

    <!-- Toolbar -->
    <div class="ac-toolbar">
        <button class="ac-submit-btn" @onclick="ShowCreate">
            ＋ Neue Meldung
        </button>
    </div>

    @if (showForm)
    {
        <div class="ac-form-card">
            <div class="ac-form-card__header">
                <h3>@(isEditing ? "✏️ Meldung bearbeiten" : "➕ Neue Meldung erstellen")</h3>
            </div>
            <div class="ac-form-card__body">
                <EditForm Model="current" OnValidSubmit="Save">
                    <DataAnnotationsValidator />
                    <ValidationSummary class="ac-validation" />

                    <div class="ac-field" style="margin-bottom:1rem">
                        <label>Titel *</label>
                        <InputText @bind-Value="current.Title" class="ac-input"
                                   placeholder="z.B. Flomi 2027 — Wichtige Info" />
                    </div>
                    <div class="ac-field" style="margin-bottom:1rem">
                        <label>Inhalt *</label>
                        <InputTextArea @bind-Value="current.Content" class="ac-input ac-textarea"
                                       rows="5"
                                       placeholder="Text der Meldung..." />
                    </div>
                    <div class="ac-checkbox-row">
                        <InputCheckbox @bind-Value="current.IsPublished" id="pubCheck" class="ac-checkbox" />
                        <label for="pubCheck">Sofort veröffentlichen</label>
                    </div>

                    <div class="ac-form-actions">
                        <button type="submit" class="ac-submit-btn" disabled="@isSaving">
                            @(isSaving ? "⏳ Wird gespeichert..." : isEditing ? "💾 Aktualisieren" : "✅ Erstellen")
                        </button>
                        <button type="button" class="ac-cancel-btn" @onclick="Cancel">Abbrechen</button>
                    </div>
                </EditForm>
            </div>
        </div>
    }

    @if (successMsg != null)
    {
        <div class="ac-state-card ac-state-card--success" style="margin-bottom:1rem">
            <div class="ac-state-card__icon">✅</div>
            <div class="ac-state-card__content"><p>@successMsg</p></div>
        </div>
    }

    @if (news == null)
    {
        <div class="ac-state-card ac-state-card--info">
            <div class="ac-state-card__icon">⏳</div>
            <div class="ac-state-card__content"><h3>Wird geladen...</h3></div>
        </div>
    }
    else if (!news.Any())
    {
        <div class="ac-state-card ac-state-card--empty">
            <div class="ac-state-card__icon">📭</div>
            <div class="ac-state-card__content">
                <h3>Noch keine Meldungen</h3>
                <p>Erstelle eine neue Meldung mit dem Button oben.</p>
            </div>
        </div>
    }
    else
    {
        <table class="ac-table">
            <thead>
                <tr>
                    <th>Titel</th>
                    <th>Erstellt am</th>
                    <th>Status</th>
                    <th>Aktionen</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in news)
                {
                    <tr>
                        <td><strong>@item.Title</strong></td>
                        <td>@item.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>
                            @if (item.IsPublished)
                            {
                                <span class="ac-badge ac-badge--active">✅ Publiziert</span>
                            }
                            else
                            {
                                <span class="ac-badge ac-badge--inactive">🔴 Entwurf</span>
                            }
                        </td>
                        <td>
                            <div class="ac-actions">
                                <button class="ac-btn ac-btn--edit" @onclick="() => Edit(item)">
                                    ✏️ Edit
                                </button>
                                <button class="ac-btn @(item.IsPublished ? "ac-btn--deactivate" : "ac-btn--activate")"
                                        @onclick="() => Toggle(item.Id)">
                                    @(item.IsPublished ? "⏸ Verbergen" : "▶ Publizieren")
                                </button>
                                <button class="ac-btn ac-btn--delete" @onclick="() => Delete(item.Id)">
                                    🗑️ Löschen
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

</div>

@code {
    private List<NewsItem>? news;
    private NewsItem        current    = new() { IsPublished = true };
    private bool            showForm   = false;
    private bool            isEditing  = false;
    private bool            isSaving   = false;
    private string?         successMsg = null;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        news = await NewsService.GetAllAsync();
    }

    private void ShowCreate()
    {
        current   = new NewsItem { IsPublished = true };
        isEditing = false;
        showForm  = true;
        successMsg = null;
    }

    private void Edit(NewsItem item)
    {
        current   = new NewsItem { Id = item.Id, Title = item.Title, Content = item.Content, IsPublished = item.IsPublished };
        isEditing = true;
        showForm  = true;
        successMsg = null;
    }

    private void Cancel()
    {
        showForm  = false;
        isEditing = false;
        current   = new NewsItem { IsPublished = true };
    }

    private async Task Save()
    {
        isSaving = true;
        try
        {
            if (isEditing)
            {
                await NewsService.UpdateAsync(current);
                successMsg = $"Meldung «{current.Title}» wurde aktualisiert.";
            }
            else
            {
                await NewsService.CreateAsync(current);
                successMsg = $"Meldung «{current.Title}» wurde erstellt.";
            }
            await Load();
            Cancel();
        }
        finally { isSaving = false; }
    }

    private async Task Toggle(int id)
    {
        await NewsService.TogglePublishedAsync(id);
        await Load();
    }

    private async Task Delete(int id)
    {
        await NewsService.DeleteAsync(id);
        await Load();
    }
}

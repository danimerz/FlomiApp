@page "/admin/checkin"
@using FlomiApp.Data.Models
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@implements IAsyncDisposable
@inject IAppointmentService AppointmentService
@inject IAreaService AreaService
@inject FlomiApp.Data.ApplicationDbContext Db
@inject IJSRuntime JS
@attribute [Authorize(Roles = "Admin,FahrzeugAdmin,MoebelAdmin,BereichsAdmin")]

<PageTitle>Check-in – Admin</PageTitle>

<div class="dashboard-page">

    <section class="dashboard-hero">
        <div class="dashboard-hero__content">
            <span class="dashboard-hero__badge">Administration</span>
            <h1>📷 Check-in</h1>
            <p>QR-Codes scannen und Einsätze bestätigen.</p>
        </div>
    </section>

    <!-- Event + Toggle -->
    <div class="ci-toolbar">
        <div class="ci-field">
            <label>Event</label>
            <select class="ci-select" @bind="selectedEventId" @bind:after="LoadStats">
                <option value="0">– Bitte wählen –</option>
                @foreach (var ev in events)
                {
                    <option value="@ev.Id">
                        @ev.Name — @(ev.CheckInEnabled ? "✅ Check-in aktiv" : "⚫ Check-in inaktiv")
                    </option>
                }
            </select>
        </div>

        @if (selectedEvent != null)
        {
            <div class="ci-toggle-wrap">
                <span class="ci-toggle-label">🎫 Check-in</span>
                <label class="toggle-switch">
                    <input type="checkbox"
                           checked="@selectedEvent.CheckInEnabled"
                           @onchange="ToggleCheckIn" />
                    <span class="slider round"></span>
                </label>
                <span class="@(selectedEvent.CheckInEnabled ? "ci-status ci-status--on" : "ci-status ci-status--off")">
                    @(selectedEvent.CheckInEnabled ? "Aktiv" : "Inaktiv")
                </span>
            </div>
        }
    </div>

    @if (selectedEvent?.CheckInEnabled == true)
    {
        <!-- ── Tabs ── -->
        <div class="ci-tabs">
            <button class="ci-tab @(activeTab == "scan" ? "ci-tab--active" : "")"
                    @onclick='() => { activeTab = "scan"; lastResult = null; }'>📷 QR-Scan</button>
            <button class="ci-tab @(activeTab == "manual" ? "ci-tab--active" : "")"
                    @onclick='() => SetManualTab()'>🔍 Manuell</button>
            <button class="ci-tab @(activeTab == "walkin" ? "ci-tab--active" : "")"
                    @onclick='() => activeTab = "walkin"'>👤 Walk-in</button>
            <button class="ci-tab @(activeTab == "overview" ? "ci-tab--active" : "")"
                    @onclick='() => activeTab = "overview"'>📋 Übersicht</button>
        </div>

        @if (activeTab == "overview")
        {
            <div class="ci-card ci-card--full">
                <div class="ci-ov-header">
                    <h3 class="ci-card__title" style="margin:0">📋 Alle Teilnehmer</h3>
                    <div class="ci-ov-filters">
                        <button class="ci-ov-filter @(overviewFilter == "" ? "ci-ov-filter--active" : "")"         @onclick='() => overviewFilter = ""'>Alle (@OverviewRows.Count())</button>
                        <button class="ci-ov-filter @(overviewFilter == "open" ? "ci-ov-filter--active" : "")"     @onclick='() => overviewFilter = "open"'>○ Offen (@OverviewRows.Count(r => r.Status == "open"))</button>
                        <button class="ci-ov-filter @(overviewFilter == "in" ? "ci-ov-filter--active" : "")"       @onclick='() => overviewFilter = "in"'>✅ Eingecheckt (@OverviewRows.Count(r => r.Status == "in"))</button>
                        <button class="ci-ov-filter @(overviewFilter == "out" ? "ci-ov-filter--active" : "")"      @onclick='() => overviewFilter = "out"'>🏁 Ausgecheckt (@OverviewRows.Count(r => r.Status == "out"))</button>
                    </div>
                </div>

                <div class="ci-ov-table-wrap">
                    <table class="ci-ov-table">
                        <thead>
                            <tr>
                                <th>Status</th>
                                <th>Name</th>
                                <th>Bereich / Typ</th>
                                <th>Datum</th>
                                <th>Zeit</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in FilteredOverviewRows)
                            {
                                <tr class="ci-ov-row ci-ov-row--@row.Status">
                                    <td>
                                        @if (row.Status == "out")      { <span class="ci-ov-badge ci-ov-badge--out">🏁 Ausgecheckt</span> }
                                        else if (row.Status == "in")   { <span class="ci-ov-badge ci-ov-badge--in">✅ Eingecheckt</span> }
                                        else                           { <span class="ci-ov-badge ci-ov-badge--open">○ Offen</span> }
                                    </td>
                                    <td class="ci-ov-name">@row.Name <small class="ci-ov-type">@(row.IsWalkIn ? "Walk-in" : "")</small></td>
                                    <td>@row.AreaName</td>
                                    <td>@row.Date</td>
                                    <td>@row.StatusTime</td>
                                </tr>
                            }
                            @if (!FilteredOverviewRows.Any())
                            {
                                <tr><td colspan="5" style="text-align:center;color:var(--color-text-placeholder);padding:1.5rem">Keine Einträge.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else
        {

        <div class="ci-layout">

            @if (activeTab == "scan")
            {
                <!-- QR-Scan -->
                <div class="ci-card ci-scan-card">
                    <h3 class="ci-card__title">📷 Scan-Modus</h3>
                    <div class="ci-mode-toggle">
                        <button class="ci-mode-btn @(checkOutMode ? "" : "ci-mode-btn--active")"
                                @onclick="() => { checkOutMode = false; lastResult = null; }">✅ Check-in</button>
                        <button class="ci-mode-btn @(checkOutMode ? "ci-mode-btn--active ci-mode-btn--out" : "")"
                                @onclick="() => { checkOutMode = true; lastResult = null; }">🏁 Check-out</button>
                    </div>
                    @if (!scanning)
                    {
                        <button class="ci-scan-btn @(checkOutMode ? "ci-scan-btn--out" : "")" @onclick="StartScan">
                            📷 @(checkOutMode ? "Check-out scannen" : "Check-in scannen")
                        </button>
                    }
                    else
                    {
                        <div class="ci-video-wrap">
                            <video id="ci-video" autoplay muted playsinline class="ci-video"></video>
                            <canvas id="ci-canvas" class="ci-canvas-hidden"></canvas>
                        </div>
                        <button class="ci-stop-btn" @onclick="StopScan">⏹ Stoppen</button>
                    }
                    @if (lastResult != null)
                    {
                        <div class="ci-result ci-result--@(lastResult.Success ? "ok" : "err")">
                            @if (lastResult.Success)
                            {
                                <div class="ci-result__icon">@(lastResult.isCheckOut ? "🏁" : "✅")</div>
                                <div class="ci-result__text">
                                    <strong>@lastResult.PersonName</strong><br/>
                                    <span>@lastResult.AreaName · @lastResult.Date</span><br/>
                                    <small>@(lastResult.isCheckOut ? "Ausgecheckt" : "Eingecheckt") @lastResult.Time</small>
                                </div>
                            }
                            else
                            {
                                <div class="ci-result__icon">❌</div>
                                <div class="ci-result__text">@lastResult.Message</div>
                            }
                        </div>
                    }
                </div>
            }
            else if (activeTab == "manual")
            {
                <!-- Manuelle Suche -->
                <div class="ci-card">
                    <h3 class="ci-card__title">🔍 Manuelle Suche</h3>
                    <div class="ci-mode-toggle" style="margin-bottom:.75rem">
                        <button class="ci-mode-btn @(checkOutMode ? "" : "ci-mode-btn--active")"
                                @onclick="() => checkOutMode = false">✅ Check-in</button>
                        <button class="ci-mode-btn @(checkOutMode ? "ci-mode-btn--active ci-mode-btn--out" : "")"
                                @onclick="() => checkOutMode = true">🏁 Check-out</button>
                    </div>
                    <input type="text" class="ci-search" placeholder="Name suchen..."
                           @bind="manualSearch" @bind:event="oninput" />

                    <div class="ci-person-list">
                        @foreach (var a in FilteredManualApts)
                        {
                            var pName = a.FamilyMember != null
                                ? $"{a.FamilyMember.FirstName} {a.FamilyMember.LastName}"
                                : $"{a.User?.FirstName} {a.User?.LastName}";
                            var statusIcon = a.CheckedOutAt.HasValue ? "🏁" : a.CheckedInAt.HasValue ? "✅" : "○";
                            var statusText = a.CheckedOutAt.HasValue
                                ? $"Ausgecheckt {a.CheckedOutAt:HH:mm}"
                                : a.CheckedInAt.HasValue
                                    ? $"Eingecheckt {a.CheckedInAt:HH:mm}"
                                    : "Noch offen";

                            <div class="ci-person-row">
                                <div class="ci-person-row__info">
                                    <span class="ci-person-row__status">@statusIcon</span>
                                    <div>
                                        <strong>@pName</strong><br/>
                                        <small>@(a.Area?.AreaTemplate?.Name) · @a.Area?.Date.ToString("dd.MM") · @statusText</small>
                                    </div>
                                </div>
                                <div class="ci-person-row__actions">
                                    @if (!checkOutMode && !a.CheckedInAt.HasValue)
                                    {
                                        <button class="ci-action-btn ci-action-btn--in" @onclick="() => ManualCheckIn(a.Id)">✅ Ein</button>
                                    }
                                    @if (checkOutMode && a.CheckedInAt.HasValue && !a.CheckedOutAt.HasValue)
                                    {
                                        <button class="ci-action-btn ci-action-btn--out" @onclick="() => ManualCheckOut(a.Id)">🏁 Aus</button>
                                    }
                                </div>
                            </div>
                        }
                        @if (!FilteredManualApts.Any())
                        {
                            <p style="color:var(--color-text-placeholder);font-size:.88rem;margin-top:.75rem">
                                @(string.IsNullOrEmpty(manualSearch) ? "Alle Verkauf-Anmeldungen werden hier angezeigt." : "Keine Treffer.")
                            </p>
                        }
                    </div>
                </div>
            }
            else if (activeTab == "walkin")
            {
                <!-- Walk-in -->
                <div class="ci-card">
                    <h3 class="ci-card__title">👤 Walk-in erfassen</h3>
                    <div class="ci-walkin-form">
                        <div style="display:flex;gap:.75rem">
                            <input type="text" class="ci-search" placeholder="Vorname *" @bind="walkInFirst" style="flex:1" />
                            <input type="text" class="ci-search" placeholder="Nachname *" @bind="walkInLast" style="flex:1" />
                        </div>
                        <input type="text" class="ci-search" placeholder="Info (z.B. Tisch 3, schickt Sepp)" @bind="walkInInfo" style="margin-top:.5rem" />
                        <button class="ci-scan-btn" style="margin-top:.75rem"
                                @onclick="AddWalkIn"
                                disabled="@(string.IsNullOrWhiteSpace(walkInFirst) || string.IsNullOrWhiteSpace(walkInLast))">
                            ✅ Jetzt einchecken
                        </button>
                    </div>

                    @if (todayWalkIns.Any())
                    {
                        <div class="ci-recent" style="margin-top:1rem">
                            <div class="ci-recent__title">Heute erfasste Walk-ins (@todayWalkIns.Count)</div>
                            @foreach (var w in todayWalkIns)
                            {
                                <div class="ci-recent__item">
                                    <span class="ci-recent__time">@(w.CheckedOutAt?.ToString("HH:mm") ?? w.CheckedInAt.ToString("HH:mm"))</span>
                                    <span class="ci-recent__person">@(w.CheckedOutAt.HasValue ? "🏁" : "✅") @w.FirstName @w.LastName</span>
                                    <span class="ci-recent__area">@(w.Info ?? "–")</span>
                                    @if (!w.CheckedOutAt.HasValue)
                                    {
                                        <button class="ci-action-btn ci-action-btn--out" @onclick="() => CheckOutWalkIn(w.Id)">🏁</button>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            }

            <!-- Statistik (immer sichtbar rechts) -->
            <div class="ci-card">
                <h3 class="ci-card__title">📊 Übersicht Verkauf</h3>
                <div class="ci-stats">
                    <div class="ci-stat ci-stat--ok"><span class="ci-stat__num">@checkedIn</span><span class="ci-stat__label">Eingecheckt</span></div>
                    <div class="ci-stat ci-stat--out"><span class="ci-stat__num">@checkedOut</span><span class="ci-stat__label">Ausgecheckt</span></div>
                    <div class="ci-stat ci-stat--pending"><span class="ci-stat__num">@pending</span><span class="ci-stat__label">Ausstehend</span></div>
                    <div class="ci-stat ci-stat--total"><span class="ci-stat__num">@(total + todayWalkIns.Count)</span><span class="ci-stat__label">Total</span></div>
                </div>
                <div class="ci-progress-bar">
                    <div class="ci-progress-fill" style="width:@(total > 0 ? checkedIn * 100 / total : 0)%"></div>
                </div>
                @if (recentCheckIns.Any())
                {
                    <div class="ci-recent">
                        <div class="ci-recent__title">Zuletzt</div>
                        @foreach (var a in recentCheckIns)
                        {
                            var person = a.FamilyMember != null
                                ? $"{a.FamilyMember.FirstName} {a.FamilyMember.LastName}"
                                : $"{a.User?.FirstName} {a.User?.LastName}";
                            <div class="ci-recent__item">
                                <span class="ci-recent__time">@(a.CheckedOutAt?.ToString("HH:mm") ?? a.CheckedInAt?.ToString("HH:mm"))</span>
                                <span class="ci-recent__person">@(a.CheckedOutAt.HasValue ? "🏁" : "✅") @person</span>
                                <span class="ci-recent__area">@(a.Area?.AreaTemplate?.Name) · @a.Area?.Date.ToString("dd.MM")</span>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
        } <!-- end else (non-overview tabs) -->
    }
    else if (selectedEvent != null)
    {
        <div class="state-card state-card--info" style="margin-top:1.5rem">
            <div class="state-card__icon">⚫</div>
            <div class="state-card__content">
                <h3>Check-in ist deaktiviert</h3>
                <p>Aktiviere den Check-in für dieses Event mit dem Toggle oben.</p>
            </div>
        </div>
    }

</div>

@code {
    private List<Event>      events        = new();
    private Event?           selectedEvent = null;
    private int              selectedEventId = 0;
    private bool             scanning      = false;
    private bool             checkOutMode  = false;

    // ── Tabs ────────────────────────────────────────────────
    private string activeTab = "scan";

    // ── Manuell Tab ─────────────────────────────────────────
    private string             manualSearch   = "";
    private List<Appointment>  allVerkaufApts = new();

    private IEnumerable<Appointment> FilteredManualApts =>
        string.IsNullOrWhiteSpace(manualSearch)
            ? allVerkaufApts
            : allVerkaufApts.Where(a =>
            {
                var name = a.FamilyMember != null
                    ? $"{a.FamilyMember.FirstName} {a.FamilyMember.LastName}"
                    : $"{a.User?.FirstName} {a.User?.LastName}";
                return name.Contains(manualSearch, StringComparison.OrdinalIgnoreCase);
            });

    // ── Walk-in Tab ─────────────────────────────────────────
    private string          walkInFirst   = "";
    private string          walkInLast    = "";
    private string          walkInInfo    = "";
    private List<WalkIn>    todayWalkIns  = new();

    // ── Übersicht Tab ────────────────────────────────────────
    private string overviewFilter = "";

    private record OverviewRow(string Name, string AreaName, string Date, string Status, string StatusTime, bool IsWalkIn);

    private IEnumerable<OverviewRow> OverviewRows
    {
        get
        {
            var aptRows = allVerkaufApts.Select(a =>
            {
                var name   = a.FamilyMember != null
                    ? $"{a.FamilyMember.FirstName} {a.FamilyMember.LastName}"
                    : $"{a.User?.FirstName} {a.User?.LastName}";
                var status = a.CheckedOutAt.HasValue ? "out" : a.CheckedInAt.HasValue ? "in" : "open";
                var time   = a.CheckedOutAt?.ToString("HH:mm") ?? a.CheckedInAt?.ToString("HH:mm") ?? "–";
                return new OverviewRow(name, a.Area?.AreaTemplate?.Name ?? "–",
                    a.Area?.Date.ToString("dd.MM.yyyy") ?? "–", status, time, false);
            });

            var walkRows = todayWalkIns.Select(w =>
            {
                var status = w.CheckedOutAt.HasValue ? "out" : "in";
                var time   = w.CheckedOutAt?.ToString("HH:mm") ?? w.CheckedInAt.ToString("HH:mm");
                return new OverviewRow($"{w.FirstName} {w.LastName}", w.Info ?? "–",
                    w.CheckedInAt.ToString("dd.MM.yyyy"), status, time, true);
            });

            return aptRows.Concat(walkRows)
                .OrderBy(r => r.Status == "open" ? 0 : r.Status == "in" ? 1 : 2)
                .ThenBy(r => r.Name);
        }
    }

    private IEnumerable<OverviewRow> FilteredOverviewRows =>
        string.IsNullOrEmpty(overviewFilter)
            ? OverviewRows
            : OverviewRows.Where(r => r.Status == overviewFilter);

    // ── Stats ────────────────────────────────────────────────
    private int checkedIn;
    private int checkedOut;
    private int pending;
    private int total;
    private List<Appointment> recentCheckIns = new();

    private record ScanResult(bool Success, string PersonName = "", string AreaName = "",
        string Date = "", string Time = "", string Message = "", bool isCheckOut = false);
    private ScanResult? lastResult = null;

    private DotNetObjectReference<CheckIn>? selfRef;

    protected override async Task OnInitializedAsync()
    {
        events = await AreaService.GetAllEventsAsync();
        selfRef = DotNetObjectReference.Create(this);
    }

    private async Task LoadStats()
    {
        selectedEvent = events.FirstOrDefault(e => e.Id == selectedEventId);
        if (selectedEventId == 0 || selectedEvent == null) return;

        var apts = await Db.Appointments
            .Include(a => a.User).Include(a => a.FamilyMember)
            .Include(a => a.Area).ThenInclude(ar => ar.AreaTemplate).ThenInclude(t => t!.AreaCategory)
            .Where(a => a.Area.EventId == selectedEventId
                     && a.Status == AppointmentStatus.Registered
                     && a.Area.AreaTemplate != null
                     && a.Area.AreaTemplate.AreaCategory != null
                     && a.Area.AreaTemplate.AreaCategory.Name == "Verkauf")
            .AsNoTracking().ToListAsync();

        allVerkaufApts = apts;
        total          = apts.Count;
        checkedIn      = apts.Count(a => a.CheckedInAt.HasValue);
        checkedOut     = apts.Count(a => a.CheckedOutAt.HasValue);
        pending        = total - checkedIn;
        recentCheckIns = apts.Where(a => a.CheckedInAt.HasValue || a.CheckedOutAt.HasValue)
            .OrderByDescending(a => a.CheckedOutAt ?? a.CheckedInAt).Take(5).ToList();

        var today = DateTime.Today;
        todayWalkIns = await Db.WalkIns
            .Where(w => w.EventId == selectedEventId && w.CheckedInAt >= today)
            .OrderByDescending(w => w.CheckedInAt)
            .AsNoTracking().ToListAsync();
    }

    private void SetManualTab()
    {
        activeTab    = "manual";
        manualSearch = "";
    }

    private async Task ManualCheckIn(int aptId)
    {
        await AppointmentService.CheckInAsync(aptId);
        await LoadStats();
    }

    private async Task ManualCheckOut(int aptId)
    {
        await AppointmentService.CheckOutAsync(aptId);
        await LoadStats();
    }

    private async Task AddWalkIn()
    {
        if (string.IsNullOrWhiteSpace(walkInFirst) || string.IsNullOrWhiteSpace(walkInLast)) return;
        var w = new WalkIn
        {
            EventId     = selectedEventId,
            FirstName   = walkInFirst.Trim(),
            LastName    = walkInLast.Trim(),
            Info        = string.IsNullOrWhiteSpace(walkInInfo) ? null : walkInInfo.Trim(),
            CheckedInAt = DateTime.Now
        };
        Db.WalkIns.Add(w);
        await Db.SaveChangesAsync();
        walkInFirst = "";
        walkInLast  = "";
        walkInInfo  = "";
        await LoadStats();
    }

    private async Task CheckOutWalkIn(int walkInId)
    {
        var w = await Db.WalkIns.FindAsync(walkInId);
        if (w != null && !w.CheckedOutAt.HasValue)
        {
            w.CheckedOutAt = DateTime.Now;
            await Db.SaveChangesAsync();
            await LoadStats();
        }
    }

    private async Task ToggleCheckIn()
    {
        if (selectedEvent == null) return;
        await AreaService.ToggleCheckInAsync(selectedEvent.Id);
        events        = await AreaService.GetAllEventsAsync();
        selectedEvent = events.FirstOrDefault(e => e.Id == selectedEventId);
        StateHasChanged();
    }

    private async Task StartScan()
    {
        scanning    = true;
        lastResult  = null;
        StateHasChanged();
        await Task.Delay(100);
        await JS.InvokeVoidAsync("qrScanner.start", "ci-video", "ci-canvas", selfRef);
    }

    private async Task StopScan()
    {
        await JS.InvokeVoidAsync("qrScanner.stop");
        scanning = false;
    }

    [JSInvokable]
    public async Task OnQrDetected(string data)
    {
        await JS.InvokeVoidAsync("qrScanner.stop");
        scanning = false;

        if (!int.TryParse(data.Replace("flomi-apt:", ""), out var aptId))
        {
            lastResult = new ScanResult(false, Message: "Ungültiger QR-Code.");
            StateHasChanged();
            return;
        }

        var apt = await AppointmentService.GetByIdForCheckInAsync(aptId);
        if (apt == null)
        {
            lastResult = new ScanResult(false, Message: "Anmeldung nicht gefunden oder bereits storniert.");
            StateHasChanged();
            return;
        }

        if (apt.Area?.AreaTemplate?.AreaCategory?.Name != "Verkauf")
        {
            lastResult = new ScanResult(false, Message: "Check-in/out nur für Verkauf-Bereiche möglich.");
            StateHasChanged();
            return;
        }

        var person = apt.FamilyMember != null
            ? $"{apt.FamilyMember.FirstName} {apt.FamilyMember.LastName}"
            : $"{apt.User?.FirstName} {apt.User?.LastName}";
        var areaName = apt.Area?.AreaTemplate?.Name ?? "–";
        var date     = apt.Area?.Date.ToString("dd.MM.yyyy") ?? "";

        if (checkOutMode)
        {
            // ── Check-out ──────────────────────────────────────────────────────
            if (!apt.CheckedInAt.HasValue)
            {
                lastResult = new ScanResult(false, Message: $"{person} ist noch nicht eingecheckt.");
                StateHasChanged(); return;
            }
            if (apt.CheckedOutAt.HasValue)
            {
                lastResult = new ScanResult(false, Message: $"Bereits ausgecheckt um {apt.CheckedOutAt:HH:mm} Uhr.");
                StateHasChanged(); return;
            }
            var outOk = await AppointmentService.CheckOutAsync(aptId);
            lastResult = outOk
                ? new ScanResult(true, person, areaName, date, DateTime.Now.ToString("HH:mm"), isCheckOut: true)
                : new ScanResult(false, Message: "Check-out fehlgeschlagen.");
        }
        else
        {
            // ── Check-in ───────────────────────────────────────────────────────
            if (apt.CheckedInAt.HasValue)
            {
                lastResult = new ScanResult(false, Message: $"Bereits eingecheckt um {apt.CheckedInAt:HH:mm} Uhr.");
                StateHasChanged(); return;
            }
            var inOk = await AppointmentService.CheckInAsync(aptId);
            lastResult = inOk
                ? new ScanResult(true, person, areaName, date, DateTime.Now.ToString("HH:mm"))
                : new ScanResult(false, Message: "Check-in fehlgeschlagen.");
        }

        await LoadStats();
        StateHasChanged();
    }

    [JSInvokable]
    public Task OnScanError(string msg)
    {
        lastResult = new ScanResult(false, Message: $"Kamera-Fehler: {msg}");
        scanning   = false;
        StateHasChanged();
        return Task.CompletedTask;
    }

    public async ValueTask DisposeAsync()
    {
        if (scanning) await JS.InvokeVoidAsync("qrScanner.stop");
        selfRef?.Dispose();
    }
}

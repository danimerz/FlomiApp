@page "/admin/dashboard"
@using FlomiApp.Data.Models
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using System.Globalization
@inject FlomiApp.Data.ApplicationDbContext Db
@inject IAreaService AreaService
@inject IFurniturePickupService FurniturePickupService
@inject IJSRuntime JS
@using FlomiApp.Security
@attribute [Authorize(Roles = Roles.AnyAdmin)]

<PageTitle>Admin Dashboard</PageTitle>

<div class="dashboard-page">

    <section class="dashboard-hero">
        <div class="dashboard-hero__content">
            <span class="dashboard-hero__badge">Administration</span>
            <h1>Admin Dashboard</h1>
            <p>Gesamtübersicht aller laufenden Aktivitäten des Flomi.</p>
        </div>
    </section>

    <!-- ── Tabs ── -->
    <div class="ac-tabs">
        <button class="ac-tab @(activeTab == DashTab.Overview ? "ac-tab--active" : "")"
                @onclick="() => SetTab(DashTab.Overview)">
            📊 Übersicht
        </button>
        <button class="ac-tab @(activeTab == DashTab.Stats ? "ac-tab--active" : "")"
                @onclick="() => SetTab(DashTab.Stats)">
            📈 Statistiken
        </button>
    </div>

    @if (isLoading)
    {
        <div class="state-card state-card--info">
            <div class="state-card__icon">⏳</div>
            <div class="state-card__content"><h3>Wird geladen...</h3></div>
        </div>
    }
    else if (activeTab == DashTab.Overview)
    {
        <!-- ── KPI Grid ── -->
        <div class="adm-kpi-grid">
            <a class="adm-kpi adm-kpi--blue" href="/admin/appointments">
                <div class="adm-kpi__num">@totalRegistered</div>
                <div class="adm-kpi__label">Anmeldungen</div>
                <div class="adm-kpi__sub">für aktive Events</div>
            </a>
            <a class="adm-kpi adm-kpi--orange" href="/admin/appointments?filter=open">
                <div class="adm-kpi__num">@openSlots</div>
                <div class="adm-kpi__label">Offene Plätze</div>
                <div class="adm-kpi__sub">in aktiven Bereichen</div>
            </a>
            <a class="adm-kpi adm-kpi--yellow" href="/admin/furniture-pickup">
                <div class="adm-kpi__num">@pendingPickups</div>
                <div class="adm-kpi__label">Offene Abholungen</div>
                <div class="adm-kpi__sub">ausstehende Anfragen</div>
            </a>
            <a class="adm-kpi adm-kpi--green" href="/admin/vehicles">
                <div class="adm-kpi__num">@vehiclesAssigned</div>
                <div class="adm-kpi__label">Fahrzeuge</div>
                <div class="adm-kpi__sub">mit Zuweisung</div>
            </a>
            <a class="adm-kpi adm-kpi--purple" href="/admin/users">
                <div class="adm-kpi__num">@totalUsers</div>
                <div class="adm-kpi__label">Benutzer</div>
                <div class="adm-kpi__sub">registriert</div>
            </a>
            <a class="adm-kpi adm-kpi--red" href="/admin/appointments">
                <div class="adm-kpi__num">@cancelledCount</div>
                <div class="adm-kpi__label">Stornierungen</div>
                <div class="adm-kpi__sub">in aktiven Events</div>
            </a>
        </div>

        <!-- ── Sections ── -->
        <div class="adm-sections">

            <!-- Bereiche nach Auslastung -->
            <div class="adm-section">
                <h2 class="adm-section__title">📋 Bereiche nach Auslastung</h2>
                @if (!areaStats.Any())
                {
                    <p class="adm-empty">Keine aktiven Bereiche gefunden.</p>
                }
                else
                {
                    @foreach (var a in areaStats)
                    {
                        var pct = a.Cap > 0 ? Math.Min((double)a.Reg / a.Cap * 100, 100) : 0;
                        <div class="adm-area-row">
                            <div class="adm-area-row__info">
                                <span class="adm-area-row__name">@a.Name</span>
                                <span class="adm-area-row__date">@a.Date.ToString("ddd dd.MM", new System.Globalization.CultureInfo("de-CH"))</span>
                                <span class="adm-area-row__event">@a.EventName</span>
                            </div>
                            <div class="adm-area-row__bar-wrap">
                                <div class="adm-area-row__bar">
                                    <div class="adm-area-row__fill @(pct >= 100 ? "full" : pct >= 75 ? "warn" : "")"
                                         style="width:@pct.ToString("F0")%"></div>
                                </div>
                                <span class="adm-area-row__count">@a.Reg / @(a.Cap >= 999 ? "∞" : a.Cap.ToString())</span>
                            </div>
                        </div>
                    }
                }
            </div>

            <!-- Aktivitäts-Feed -->
            <div class="adm-section adm-section--feed">
                <h2 class="adm-section__title">
                    📋 Letzte Aktivitäten
                    <a href="/admin/appointments" class="adm-section__link">Alle →</a>
                </h2>
                @if (!activityFeed.Any())
                {
                    <p class="adm-empty">Noch keine Aktivitäten vorhanden.</p>
                }
                else
                {
                    @foreach (var dayGroup in activityFeed.GroupBy(a => a.Timestamp.Date).OrderByDescending(g => g.Key))
                    {
                        <div class="adm-feed-day">@DayLabel(dayGroup.Key)</div>
                        @foreach (var item in dayGroup.OrderByDescending(a => a.Timestamp))
                        {
                            <div class="adm-feed-item">
                                <div class="adm-feed-item__dot adm-feed-item__dot--@item.Type"></div>
                                <div class="adm-feed-item__body">
                                    <div class="adm-feed-item__time">@item.Timestamp.ToString("HH:mm")</div>
                                    <div class="adm-feed-item__icon">@FeedIcon(item.Type)</div>
                                    <div class="adm-feed-item__text">
                                        <strong>@item.PersonName</strong>
                                        <span class="adm-feed-item__action">@FeedAction(item.Type)</span>
                                        <br />
                                        <span class="adm-feed-item__detail">@item.Detail</span>
                                        @if (!string.IsNullOrEmpty(item.SubDetail))
                                        {
                                            <span class="adm-feed-item__sub"> · @item.SubDetail</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    }
                }
            </div>

            <!-- Neueste Möbel-Anfragen -->
            <div class="adm-section">
                <h2 class="adm-section__title">🛋️ Neueste Möbel-Anfragen</h2>
                @if (!recentPickups.Any())
                {
                    <p class="adm-empty">Keine ausstehenden Anfragen.</p>
                }
                else
                {
                    <table class="adm-mini-table">
                        <thead><tr><th>#</th><th>Person</th><th>Abholdatum</th><th>Status</th></tr></thead>
                        <tbody>
                            @foreach (var r in recentPickups)
                            {
                                <tr>
                                    <td>#@r.OrderNumber</td>
                                    <td>@r.FirstName @r.LastName</td>
                                    <td>@r.PickupDate.ToShortDateString()</td>
                                    <td>
                                        <span class="adm-status-badge adm-status-badge--@r.Status.ToString().ToLower()">
                                            @r.Status
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <a href="/admin/furniture-pickup" class="adm-link">Alle anzeigen →</a>
                }
            </div>

        </div>
    }
    else if (activeTab == DashTab.Stats)
    {
        <div class="stats-filter" style="margin-bottom:1.5rem">
            <div class="stats-filter__group">
                <label>Event</label>
                <select class="stats-select" @bind="selectedEventId" @bind:after="LoadAndRender">
                    <option value="0">Alle aktiven Events</option>
                    @foreach (var ev in events)
                    {
                        <option value="@ev.Id">@ev.Name (@ev.Date.ToShortDateString())</option>
                    }
                </select>
            </div>
        </div>

        <div class="stats-kpi-row">
            <div class="stats-kpi"><span class="stats-kpi__num">@statsTotalReg</span><span class="stats-kpi__label">Anmeldungen</span></div>
            <div class="stats-kpi"><span class="stats-kpi__num">@statsTotalCanc</span><span class="stats-kpi__label">Stornierungen</span></div>
            <div class="stats-kpi"><span class="stats-kpi__num">@Math.Round(fillRate,0)%</span><span class="stats-kpi__label">Ø Auslastung</span></div>
            <div class="stats-kpi"><span class="stats-kpi__num">@uniquePersons</span><span class="stats-kpi__label">Personen</span></div>
        </div>

        @if (statsLoading)
        {
            <div class="state-card state-card--info">
                <div class="state-card__icon">⏳</div>
                <div class="state-card__content"><h3>Daten werden geladen...</h3></div>
            </div>
        }
        else
        {
            <div class="stats-grid">
                <div class="stats-card stats-card--wide">
                    <h3 class="stats-card__title">📈 Anmeldungen über Zeit (letzte 30 Tage)</h3>
                    <div class="stats-chart-wrap" style="height:220px"><canvas id="chart-timeline"></canvas></div>
                </div>
                <div class="stats-card">
                    <h3 class="stats-card__title">🍩 Nach Kategorie</h3>
                    <div class="stats-chart-wrap" style="height:220px"><canvas id="chart-category"></canvas></div>
                </div>
                <div class="stats-card">
                    <h3 class="stats-card__title">👥 Nach Stufe</h3>
                    <div class="stats-chart-wrap" style="height:220px"><canvas id="chart-stufe"></canvas></div>
                </div>
                <div class="stats-card stats-card--wide">
                    <h3 class="stats-card__title">📊 Belegungsrate pro Bereich</h3>
                    <div class="stats-chart-wrap" style="height:@(Math.Max(180, areaLabels.Count * 36))px"><canvas id="chart-areas"></canvas></div>
                </div>
            </div>
        }
    }

</div>

@code {
    private enum DashTab { Overview, Stats }
    private DashTab activeTab = DashTab.Overview;

    private async Task SetTab(DashTab tab)
    {
        activeTab     = tab;
        statsRendered = false;
        if (tab == DashTab.Stats)
        {
            if (!statsLoaded)
            {
                statsLoading = true;
                StateHasChanged();
                await LoadStatsData();
                statsLoading = false;
                statsLoaded  = true;
            }
            StateHasChanged(); // DOM aufbauen lassen
            await Task.Delay(80);
            await RenderCharts();
            statsRendered = true;
        }
    }

    // ── Overview state ────────────────────────────────────────────────────────
    private bool isLoading = true;

    private int totalRegistered;
    private int openSlots;
    private int pendingPickups;
    private int vehiclesAssigned;
    private int totalUsers;
    private int cancelledCount;

    // ── Stats state ───────────────────────────────────────────────────────────
    private List<Event>  events        = new();
    private bool         statsLoading  = false;
    private bool         statsLoaded   = false;
    private bool         statsRendered = false;
    private int          selectedEventId = 0;
    private int          statsTotalReg;
    private int          statsTotalCanc;
    private double       fillRate;
    private int          uniquePersons;
    private List<string> timelineLabels = new();
    private List<int>    timelineReg    = new();
    private List<int>    timelineCanc   = new();
    private List<string> categoryLabels = new();
    private List<int>    categoryData   = new();
    private List<string> stufeLabels    = new();
    private List<int>    stufeData      = new();
    private List<string> areaLabels     = new();
    private List<int>    areaRegistered = new();
    private List<int>    areaCapacity   = new();

    private record AreaStat(string Name, string EventName, DateTime Date, int Reg, int Cap);
    private record ActivityItem(DateTime Timestamp, string Type, string PersonName, string Detail, string? SubDetail = null);

    private List<AreaStat>               areaStats     = new();
    private List<FurniturePickupRequest> recentPickups = new();
    private List<ActivityItem>           activityFeed  = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (activeTab == DashTab.Stats && statsLoaded && !statsRendered)
        {
            statsRendered = true;
            await RenderCharts();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        events = await Db.Events.Where(e => e.IsActive).OrderBy(e => e.Date).ToListAsync();

        var activeEventIds = await Db.Events
            .Where(e => e.IsActive)
            .Select(e => e.Id)
            .ToListAsync();

        totalRegistered = await Db.Appointments
            .Where(a => activeEventIds.Contains(a.Area.EventId)
                     && a.Status == AppointmentStatus.Registered)
            .CountAsync();

        cancelledCount = await Db.Appointments
            .Where(a => activeEventIds.Contains(a.Area.EventId)
                     && a.Status == AppointmentStatus.Cancelled)
            .CountAsync();

        var areas = await Db.Areas
            .Include(a => a.AreaTemplate)
            .Include(a => a.Event)
            .Include(a => a.Appointments)
            .Where(a => activeEventIds.Contains(a.EventId))
            .ToListAsync();

        openSlots = areas.Where(a => a.MaxCapacity < 999)
            .Sum(a => Math.Max(0, a.MaxCapacity -
                a.Appointments.Count(ap => ap.Status == AppointmentStatus.Registered)));

        areaStats = areas
            .Select(a => new AreaStat(
                a.AreaTemplate?.Name ?? "–",
                a.Event?.Name ?? "–",
                a.Date,
                a.Appointments.Count(ap => ap.Status == AppointmentStatus.Registered),
                a.MaxCapacity))
            .OrderByDescending(a => a.Cap < 999 ? (double)a.Reg / a.Cap : 0)
            .Take(8)
            .ToList();

        pendingPickups = await Db.FurniturePickupRequests
            .Where(r => r.Status == PickupRequestStatus.Pending)
            .CountAsync();

        recentPickups = await Db.FurniturePickupRequests
            .Where(r => r.Status == PickupRequestStatus.Pending)
            .OrderByDescending(r => r.CreatedAt)
            .Take(5)
            .ToListAsync();

        vehiclesAssigned = await Db.VehicleAssignments
            .Where(a => activeEventIds.Contains(a.EventId))
            .CountAsync();

        totalUsers = await Db.Users.CountAsync();

        // Aktivitäts-Feed aufbauen
        var feed = new List<ActivityItem>();

        var recentAppts = await Db.Appointments
            .Include(a => a.User)
            .Include(a => a.FamilyMember)
            .Include(a => a.Area).ThenInclude(ar => ar.AreaTemplate)
            .Include(a => a.Area).ThenInclude(ar => ar.Event)
            .OrderByDescending(a => a.CreatedAt)
            .Take(30)
            .AsNoTracking()
            .ToListAsync();

        foreach (var ap in recentAppts)
        {
            var person  = ap.FamilyMember != null
                ? $"{ap.FamilyMember.FirstName} {ap.FamilyMember.LastName}"
                : $"{ap.User?.FirstName} {ap.User?.LastName}";
            var area    = ap.Area?.AreaTemplate?.Name ?? "–";
            var date    = ap.Area?.Date.ToString("ddd dd.MM", new CultureInfo("de-CH")) ?? "";
            var ev      = ap.Area?.Event?.Name ?? "";
            var type    = ap.Status == AppointmentStatus.Cancelled ? "cancel" : "register";
            feed.Add(new ActivityItem(ap.CreatedAt, type, person, $"{area} · {date}", ev));
        }

        var recentPickupsAll = await Db.FurniturePickupRequests
            .Include(r => r.User)
            .OrderByDescending(r => r.CreatedAt)
            .Take(10)
            .AsNoTracking()
            .ToListAsync();

        foreach (var r in recentPickupsAll)
        {
            var person = $"{r.FirstName} {r.LastName}";
            feed.Add(new ActivityItem(r.CreatedAt, "pickup", person,
                $"Möbelabholung {r.PickupDate:dd.MM.yyyy}", r.Status.ToString()));
        }

        // Check-ins
        var recentCheckIns = await Db.Appointments
            .Include(a => a.User).Include(a => a.FamilyMember)
            .Include(a => a.Area).ThenInclude(ar => ar.AreaTemplate)
            .Include(a => a.Area).ThenInclude(ar => ar.Event)
            .Where(a => a.CheckedInAt.HasValue)
            .OrderByDescending(a => a.CheckedInAt)
            .Take(20)
            .AsNoTracking()
            .ToListAsync();

        foreach (var ap in recentCheckIns)
        {
            var person = ap.FamilyMember != null
                ? $"{ap.FamilyMember.FirstName} {ap.FamilyMember.LastName}"
                : $"{ap.User?.FirstName} {ap.User?.LastName}";
            var area = ap.Area?.AreaTemplate?.Name ?? "–";
            var date = ap.Area?.Date.ToString("ddd dd.MM", new CultureInfo("de-CH")) ?? "";
            var ev   = ap.Area?.Event?.Name ?? "";
            feed.Add(new ActivityItem(ap.CheckedInAt!.Value, "checkin", person, $"{area} · {date}", ev));
        }

        activityFeed = feed.OrderByDescending(a => a.Timestamp).Take(40).ToList();

        isLoading = false;
    }

    // ── Stats Methoden ────────────────────────────────────────────────────────
    private async Task LoadAndRender()
    {
        statsLoading  = true;
        statsRendered = false;
        StateHasChanged();
        await LoadStatsData();
        statsLoading = false;
        StateHasChanged();
        await Task.Delay(80);
        await RenderCharts();
        statsRendered = true;
    }

    private async Task LoadStatsData()
    {
        var activeIds = await Db.Events.Where(e => e.IsActive).Select(e => e.Id).ToListAsync();
        var query = Db.Appointments
            .Include(a => a.User).Include(a => a.FamilyMember)
            .Include(a => a.Area).ThenInclude(ar => ar.AreaTemplate).ThenInclude(t => t!.AreaCategory)
            .Include(a => a.Area).ThenInclude(ar => ar.Event)
            .AsQueryable();
        if (selectedEventId > 0) query = query.Where(a => a.Area.EventId == selectedEventId);
        else query = query.Where(a => activeIds.Contains(a.Area.EventId));
        var all = await query.AsNoTracking().ToListAsync();

        statsTotalReg  = all.Count(a => a.Status == AppointmentStatus.Registered);
        statsTotalCanc = all.Count(a => a.Status == AppointmentStatus.Cancelled);
        uniquePersons   = all.Where(a => a.Status == AppointmentStatus.Registered)
            .Select(a => a.FamilyMemberId.HasValue ? $"fm_{a.FamilyMemberId}" : $"u_{a.UserId}")
            .Distinct().Count();

        var areaQ = Db.Areas.Include(a => a.AreaTemplate).Include(a => a.Appointments).AsQueryable();
        if (selectedEventId > 0) areaQ = areaQ.Where(a => a.EventId == selectedEventId);
        else areaQ = areaQ.Where(a => activeIds.Contains(a.EventId));
        var areasData = await areaQ.AsNoTracking().ToListAsync();
        var capped = areasData.Where(a => a.MaxCapacity < 999).ToList();
        fillRate = capped.Any() ? capped.Average(a => a.MaxCapacity > 0
            ? (double)a.Appointments.Count(ap => ap.Status == AppointmentStatus.Registered) / a.MaxCapacity * 100 : 0) : 0;

        var since = DateTime.Today.AddDays(-29);
        timelineLabels = Enumerable.Range(0, 30).Select(i => since.AddDays(i).ToString("dd.MM", new CultureInfo("de-CH"))).ToList();
        timelineReg    = Enumerable.Range(0, 30).Select(i => all.Count(a => a.CreatedAt.Date == since.AddDays(i).Date && a.Status == AppointmentStatus.Registered)).ToList();
        timelineCanc   = Enumerable.Range(0, 30).Select(i => all.Count(a => a.CreatedAt.Date == since.AddDays(i).Date && a.Status == AppointmentStatus.Cancelled)).ToList();

        var byCat = all.Where(a => a.Status == AppointmentStatus.Registered).GroupBy(a => a.Area?.AreaTemplate?.AreaCategory?.Name ?? "Sonstiges").OrderByDescending(g => g.Count());
        categoryLabels = byCat.Select(g => g.Key).ToList();
        categoryData   = byCat.Select(g => g.Count()).ToList();

        var byStufe = all.Where(a => a.Status == AppointmentStatus.Registered).GroupBy(a => a.FamilyMember?.Stufe ?? a.User?.Stufe ?? "–").OrderByDescending(g => g.Count());
        stufeLabels = byStufe.Select(g => g.Key).ToList();
        stufeData   = byStufe.Select(g => g.Count()).ToList();

        var areaFill = areasData.Where(a => a.MaxCapacity < 999)
            .Select(a => new { Label = $"{a.AreaTemplate?.Name ?? "–"} · {a.Date:dd.MM}", Reg = a.Appointments.Count(ap => ap.Status == AppointmentStatus.Registered), Cap = a.MaxCapacity })
            .OrderByDescending(x => x.Cap > 0 ? (double)x.Reg / x.Cap : 0).Take(12).ToList();
        areaLabels     = areaFill.Select(x => x.Label).ToList();
        areaRegistered = areaFill.Select(x => x.Reg).ToList();
        areaCapacity   = areaFill.Select(x => x.Cap).ToList();
    }

    private async Task RenderCharts()
    {
        try
        {
            await JS.InvokeVoidAsync("flomiCharts.renderTimeline",   "chart-timeline", timelineLabels, timelineReg, timelineCanc);
            if (categoryLabels.Any()) await JS.InvokeVoidAsync("flomiCharts.renderCategoryDonut", "chart-category", categoryLabels, categoryData);
            if (stufeLabels.Any())    await JS.InvokeVoidAsync("flomiCharts.renderStufeBars",     "chart-stufe",    stufeLabels,    stufeData);
            if (areaLabels.Any())     await JS.InvokeVoidAsync("flomiCharts.renderAreaBars",      "chart-areas",    areaLabels,     areaRegistered, areaCapacity);
        }
        catch { }
    }

    private string DayLabel(DateTime date)
    {
        if (date == DateTime.Today)              return "Heute";
        if (date == DateTime.Today.AddDays(-1))  return "Gestern";
        return date.ToString("dddd, dd. MMMM", new CultureInfo("de-CH"));
    }

    private static string FeedIcon(string type) => type switch
    {
        "register" => "🟢",
        "cancel"   => "🔴",
        "pickup"   => "🛋️",
        "checkin"  => "🎫",
        _          => "📌"
    };

    private static string FeedAction(string type) => type switch
    {
        "register" => "hat sich angemeldet für",
        "cancel"   => "hat storniert:",
        "pickup"   => "beantragte Abholung:",
        "checkin"  => "wurde eingecheckt:",
        _          => ""
    };
}

@page "/admin/config"
@using FlomiApp.Data.Models
@using Microsoft.AspNetCore.Authorization
@inject IAreaService AreaService
@attribute [Authorize(Roles = "Admin")]

<PageTitle>Konfiguration – Admin</PageTitle>

<div class="dashboard-page">

    <!-- Hero -->
    <section class="dashboard-hero">
        <div class="dashboard-hero__content">
            <span class="dashboard-hero__badge">Administration</span>
            <h1>Konfiguration</h1>
            <p>Verwalte Events, Bereiche und Kategorien für den Flomi.</p>
        </div>
    </section>

    <!-- Tabs -->
    <div class="ac-tabs">
        <button class="ac-tab @(activeTab == Tab.Events ? "ac-tab--active" : "")"
                @onclick="() => SetTab(Tab.Events)">
            🎪 Events
            @if (events != null)
            {
                <span class="ac-tab__badge">@events.Count</span>
            }
        </button>
        <button class="ac-tab @(activeTab == Tab.Templates ? "ac-tab--active" : "")"
                @onclick="() => SetTab(Tab.Templates)">
            📋 Bereich-Vorlagen
            @if (templates != null)
            {
                <span class="ac-tab__badge">@templates.Count</span>
            }
        </button>
        <button class="ac-tab @(activeTab == Tab.Areas ? "ac-tab--active" : "")"
                @onclick="() => SetTab(Tab.Areas)">
            📌 Bereich-Zuweisungen
            @if (areas != null)
            {
                <span class="ac-tab__badge">@areas.Count</span>
            }
        </button>
        <button class="ac-tab @(activeTab == Tab.Categories ? "ac-tab--active" : "")"
                @onclick="() => SetTab(Tab.Categories)">
            🏷️ Kategorien
            @if (categories != null)
            {
                <span class="ac-tab__badge">@categories.Count</span>
            }
        </button>
    </div>

    <!-- ══════════════════════════════════════════════════
         TAB: EVENTS
    ══════════════════════════════════════════════════ -->
    @if (activeTab == Tab.Events)
    {
        <div class="ac-toolbar">
            <button class="ac-submit-btn" @onclick="ShowCreateEventForm">
                ＋ Neues Event
            </button>
        </div>

        @if (showEventForm)
        {
            <div class="ac-form-card">
                <div class="ac-form-card__header">
                    <h3>@(isEditingEvent ? "✏️ Event bearbeiten" : "➕ Neues Event erstellen")</h3>
                </div>
                <div class="ac-form-card__body">
                    <EditForm Model="currentEvent" OnValidSubmit="SubmitEventForm">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="ac-validation" />

                        <div class="ac-form-grid">
                            <div class="ac-field">
                                <label>Name</label>
                                <InputText @bind-Value="currentEvent.Name" class="ac-input" />
                            </div>
                            <div class="ac-field">
                                <label>Datum</label>
                                <InputDate @bind-Value="currentEvent.Date" class="ac-input" />
                            </div>
                        </div>

                        <div class="ac-field" style="margin-top:1rem">
                            <label>Beschreibung</label>
                            <InputTextArea @bind-Value="currentEvent.Description"
                                          class="ac-input ac-textarea" />
                        </div>

                        <div class="ac-checkbox-row">
                            <InputCheckbox @bind-Value="currentEvent.IsActive"
                                           id="activeCheck" class="ac-checkbox" />
                            <label for="activeCheck">Event aktiv</label>
                        </div>

                        <div class="ac-form-actions">
                            <button type="submit" class="ac-submit-btn">
                                @(isEditingEvent ? "💾 Aktualisieren" : "✅ Erstellen")
                            </button>
                            <button type="button" class="ac-cancel-btn"
                                    @onclick="CancelEventEdit">
                                Abbrechen
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        }

        @if (events == null)
        {
            <div class="ac-state-card ac-state-card--info">
                <div class="ac-state-card__icon">⏳</div>
                <div class="ac-state-card__content">
                    <h3>Events werden geladen...</h3>
                </div>
            </div>
        }
        else if (!events.Any())
        {
            <div class="ac-state-card ac-state-card--empty">
                <div class="ac-state-card__icon">📭</div>
                <div class="ac-state-card__content">
                    <h3>Keine Events vorhanden</h3>
                    <p>Erstelle ein neues Event mit dem Button oben.</p>
                </div>
            </div>
        }
        else
        {
            <table class="ac-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Datum</th>
                        <th>Beschreibung</th>
                        <th>Status</th>
                        <th>Aktionen</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var evt in events)
                    {
                        <tr>
                            <td><strong>@evt.Name</strong></td>
                            <td>@evt.Date.ToShortDateString()</td>
                            <td>@evt.Description</td>
                            <td>
                                @if (evt.IsActive)
                                {
                                    <span class="ac-badge ac-badge--active">✅ Aktiv</span>
                                }
                                else
                                {
                                    <span class="ac-badge ac-badge--inactive">🔴 Inaktiv</span>
                                }
                            </td>
                            <td>
                                <div class="ac-actions">
                                    <button class="ac-btn ac-btn--edit"
                                            @onclick="() => EditEvent(evt)">
                                        ✏️ Edit
                                    </button>
                                    <button class="ac-btn @(evt.IsActive ? "ac-btn--deactivate" : "ac-btn--activate")"
                                            @onclick="() => ToggleEventActive(evt.Id)">
                                        @(evt.IsActive ? "⏸ Deaktivieren" : "▶ Aktivieren")
                                    </button>
                                    <button class="ac-btn ac-btn--delete"
                                            @onclick="() => DeleteEvent(evt.Id)">
                                        🗑️ Löschen
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    }

    <!-- ══════════════════════════════════════════════════
         TAB: BEREICH-VORLAGEN (Stammdaten)
    ══════════════════════════════════════════════════ -->
    @if (activeTab == Tab.Templates)
    {
        <div class="ac-toolbar">
            <button class="ac-submit-btn" @onclick="ShowCreateTemplateForm">
                ＋ Neue Vorlage
            </button>
        </div>

        @if (showTemplateForm)
        {
            <div class="ac-form-card">
                <div class="ac-form-card__header">
                    <h3>@(isEditingTemplate ? "✏️ Vorlage bearbeiten" : "➕ Neue Bereich-Vorlage erstellen")</h3>
                </div>
                <div class="ac-form-card__body">
                    <EditForm Model="currentTemplate" OnValidSubmit="SubmitTemplateForm">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="ac-validation" />

                        <div class="ac-form-grid">
                            <div class="ac-field">
                                <label>Name *</label>
                                <InputText @bind-Value="currentTemplate.Name" class="ac-input"
                                           placeholder="z.B. Geschirr" />
                            </div>
                            <div class="ac-field">
                                <label>Kategorie</label>
                                <InputSelect @bind-Value="currentTemplate.AreaCategoryId" class="ac-input">
                                    <option value="0" disabled>– Bitte wählen –</option>
                                    @foreach (var cat in categories ?? new())
                                    {
                                        <option value="@cat.Id">@cat.Name</option>
                                    }
                                </InputSelect>
                            </div>
                            <div class="ac-field">
                                <label>Mindestalter</label>
                                <InputNumber @bind-Value="currentTemplate.MinAge" class="ac-input" />
                            </div>
                            <div class="ac-field">
                                <label>Standort</label>
                                <InputText @bind-Value="currentTemplate.Location" class="ac-input"
                                           placeholder="z.B. Ägerihalle" />
                            </div>
                            <div class="ac-field">
                                <label>
                                    Pflicht-Stufen für Hauptzeitslot
                                    <span style="font-size:.78rem;font-weight:400;color:var(--color-text-placeholder)">
                                        (kommagetrennt, leer = alle dürfen alternativ wählen)
                                    </span>
                                </label>
                                <InputText @bind-Value="currentTemplate.MandatoryStufen" class="ac-input"
                                           placeholder="z.B. Pfadi,Pio,Leiter" />
                            </div>
                        </div>

                        <div class="ac-form-actions">
                            <button type="submit" class="ac-submit-btn">
                                @(isEditingTemplate ? "💾 Aktualisieren" : "✅ Erstellen")
                            </button>
                            <button type="button" class="ac-cancel-btn"
                                    @onclick="CancelTemplateEdit">
                                Abbrechen
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        }

        @if (templates == null)
        {
            <div class="ac-state-card ac-state-card--info">
                <div class="ac-state-card__icon">⏳</div>
                <div class="ac-state-card__content">
                    <h3>Vorlagen werden geladen...</h3>
                </div>
            </div>
        }
        else if (!templates.Any())
        {
            <div class="ac-state-card ac-state-card--empty">
                <div class="ac-state-card__icon">📭</div>
                <div class="ac-state-card__content">
                    <h3>Keine Vorlagen vorhanden</h3>
                    <p>Erstelle eine Bereich-Vorlage mit dem Button oben.</p>
                </div>
            </div>
        }
        else
        {
            <table class="ac-table">
                <thead>
                    <tr>
                        <th class="ac-th-sort" @onclick='() => SortTemplateBy("Name")'>
                            Name <span class="ac-sort-icon">@TemplateSortIcon("Name")</span>
                        </th>
                        <th class="ac-th-sort" @onclick='() => SortTemplateBy("Kategorie")'>
                            Kategorie <span class="ac-sort-icon">@TemplateSortIcon("Kategorie")</span>
                        </th>
                        <th class="ac-th-sort" @onclick='() => SortTemplateBy("MinAlter")'>
                            Min. Alter <span class="ac-sort-icon">@TemplateSortIcon("MinAlter")</span>
                        </th>
                        <th class="ac-th-sort" @onclick='() => SortTemplateBy("Standort")'>
                            Standort <span class="ac-sort-icon">@TemplateSortIcon("Standort")</span>
                        </th>
                        <th>Pflicht-Stufen</th>
                        <th class="ac-th-sort" @onclick='() => SortTemplateBy("Zuweisungen")'>
                            Zuweisungen <span class="ac-sort-icon">@TemplateSortIcon("Zuweisungen")</span>
                        </th>
                        <th>Aktionen</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in DisplayedTemplates)
                    {
                        <tr>
                            <td><strong>@t.Name</strong></td>
                            <td>
                                <span class="ac-badge ac-badge--category">
                                    @(t.AreaCategory?.Name ?? "–")
                                </span>
                            </td>
                            <td>@t.MinAge</td>
                            <td>@t.Location</td>
                            <td>
                                @if (!string.IsNullOrEmpty(t.MandatoryStufen))
                                {
                                    @foreach (var s in t.MandatoryStufen.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                                    {
                                        <span class="ac-badge ac-badge--inactive" style="margin:.1rem .15rem">@s</span>
                                    }
                                }
                                else
                                {
                                    <span style="color:var(--color-text-placeholder);font-size:.82rem">–</span>
                                }
                            </td>
                            <td>
                                <span class="ac-badge ac-badge--category">
                                    @t.Areas.Count
                                </span>
                            </td>
                            <td>
                                <div class="ac-actions">
                                    <button class="ac-btn ac-btn--edit"
                                            @onclick="() => EditTemplate(t)">
                                        ✏️ Edit
                                    </button>
                                    <button class="ac-btn ac-btn--delete"
                                            @onclick="() => DeleteTemplate(t.Id)"
                                            disabled="@(t.Areas.Any())">
                                        🗑️ Löschen
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    }

    <!-- ══════════════════════════════════════════════════
         TAB: BEREICH-ZUWEISUNGEN
    ══════════════════════════════════════════════════ -->
    @if (activeTab == Tab.Areas)
    {
        <div class="ac-toolbar">
            <button class="ac-submit-btn"
                    @onclick="ShowCreateAreaForm"
                    disabled="@(events == null || !events.Any() || templates == null || !templates.Any())">
                ＋ Neue Zuweisung
            </button>
            <button class="ac-submit-btn" style="background:var(--color-success-bg);color:var(--color-success-text);border:1px solid var(--color-success-border)"
                    @onclick="() => showCopyForm = !showCopyForm"
                    disabled="@(events == null || events.Count < 2)">
                📋 Bereiche kopieren
            </button>
            @if (events != null && !events.Any())
            {
                <span class="ac-toolbar__hint">⚠️ Bitte erst ein Event anlegen.</span>
            }
            @if (templates != null && !templates.Any())
            {
                <span class="ac-toolbar__hint">⚠️ Bitte erst eine Bereich-Vorlage anlegen.</span>
            }
        </div>

        @if (showCopyForm && events != null && events.Count >= 2)
        {
            <div class="ac-form-card" style="border-left:4px solid var(--color-success-border)">
                <div class="ac-form-card__header" style="background:linear-gradient(135deg,#166534,#15803d)">
                    <h3>📋 Bereiche von Event kopieren</h3>
                </div>
                <div class="ac-form-card__body">
                    <p style="margin:0 0 1rem;font-size:.9rem;color:var(--color-text-medium)">
                        Alle Zuweisungen des Quell-Events werden ins Ziel-Event kopiert.
                        Datum wird auf das Ziel-Event-Datum gesetzt, alles andere bleibt gleich.
                    </p>
                    <div class="ac-form-grid">
                        <div class="ac-field">
                            <label>Quell-Event (von)</label>
                            <select class="ac-input" @bind="copySourceEventId">
                                <option value="0" disabled>– Bitte wählen –</option>
                                @foreach (var evt in events!)
                                {
                                    <option value="@evt.Id">@evt.Name (@evt.Date.ToShortDateString())</option>
                                }
                            </select>
                        </div>
                        <div class="ac-field">
                            <label>Ziel-Event (nach)</label>
                            <select class="ac-input" @bind="copyTargetEventId">
                                <option value="0" disabled>– Bitte wählen –</option>
                                @foreach (var evt in events!)
                                {
                                    <option value="@evt.Id">@evt.Name (@evt.Date.ToShortDateString())</option>
                                }
                            </select>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(copyMessage))
                    {
                        <div class="ac-state-card @(copySuccess ? "ac-state-card--success" : "ac-state-card--error")" style="margin-top:.75rem">
                            <div class="ac-state-card__icon">@(copySuccess ? "✅" : "⚠️")</div>
                            <div class="ac-state-card__content"><p>@copyMessage</p></div>
                        </div>
                    }
                    <div class="ac-form-actions" style="margin-top:1rem">
                        <button class="ac-submit-btn" @onclick="ExecuteCopy"
                                disabled="@(copySourceEventId == 0 || copyTargetEventId == 0 || copySourceEventId == copyTargetEventId || isCopying)">
                            @(isCopying ? "⏳ Wird kopiert..." : "📋 Jetzt kopieren")
                        </button>
                        <button class="ac-cancel-btn" @onclick="() => { showCopyForm = false; copyMessage = null; }">
                            Schliessen
                        </button>
                    </div>
                </div>
            </div>
        }

        @if (showAreaForm && events != null && events.Any() && templates != null && templates.Any())
        {
            <div class="ac-form-card">
                <div class="ac-form-card__header">
                    <h3>@(isEditingArea ? "✏️ Zuweisung bearbeiten" : "➕ Neue Bereich-Zuweisung erstellen")</h3>
                </div>
                <div class="ac-form-card__body">
                    <EditForm Model="currentArea" OnValidSubmit="SubmitAreaForm">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="ac-validation" />

                        <div class="ac-form-grid">
                            <div class="ac-field">
                                <label>Bereich-Vorlage *</label>
                                <InputSelect @bind-Value="currentArea.AreaTemplateId" class="ac-input">
                                    <option value="0" disabled>– Bitte wählen –</option>
                                    @foreach (var tmpl in templates!)
                                    {
                                        <option value="@tmpl.Id">
                                            @tmpl.Name (@(tmpl.AreaCategory?.Name ?? "–"))
                                        </option>
                                    }
                                </InputSelect>
                            </div>
                            <div class="ac-field">
                                <label>Event *</label>
                                <InputSelect @bind-Value="currentArea.EventId"
                                             @bind-Value:after="SyncAreaDateToEvent"
                                             class="ac-input">
                                    <option value="0" disabled>– Bitte wählen –</option>
                                    @foreach (var evt in events!)
                                    {
                                        <option value="@evt.Id">
                                            @evt.Name (@evt.Date.ToShortDateString())
                                        </option>
                                    }
                                </InputSelect>
                            </div>
                            <div class="ac-field">
                                <label>Datum</label>
                                <InputDate @bind-Value="currentArea.Date" class="ac-input" />
                            </div>
                            <div class="ac-field">
                                <label>Zeitslot</label>
                                <input type="text" class="ac-input"
                                       placeholder="z.B. 08:30-15:30"
                                       value="@currentArea.TimeSlot"
                                       @onchange="e => currentArea.TimeSlot = FlomiApp.Helpers.TimeHelper.FormatTimeSlot(e.Value?.ToString()) ?? string.Empty" />
                            </div>
                            <div class="ac-field">
                                <label>Max. Kapazität</label>
                                <InputNumber @bind-Value="currentArea.MaxCapacity" class="ac-input" />
                            </div>
                        </div>

                        <!-- Alternativer Zeitslot -->
                        <div style="margin-top:1rem;padding:1rem;border-radius:12px;background:var(--color-info-bg);border:1px solid var(--color-info-border)">
                            <p style="margin:0 0 .75rem;font-size:.85rem;font-weight:700;color:var(--color-info-text)">
                                ⏰ Alternativer Zeitslot (optional)
                            </p>
                            <div class="ac-form-grid">
                                <div class="ac-field">
                                    <label>Alternativer Zeitslot</label>
                                    <input type="text" class="ac-input"
                                           placeholder="z.B. 07:30-12:00"
                                           value="@currentArea.AlternativeTimeSlot"
                                           @onchange="e => currentArea.AlternativeTimeSlot = FlomiApp.Helpers.TimeHelper.FormatTimeSlot(e.Value?.ToString())" />
                                </div>
                                <div class="ac-field">
                                    <label>Alternative Max. Kapazität</label>
                                    <input type="number" class="ac-input" min="1"
                                           placeholder="z.B. 4"
                                           value="@(currentArea.AlternativeMaxCapacity?.ToString() ?? "")"
                                           @onchange="e => currentArea.AlternativeMaxCapacity = int.TryParse(e.Value?.ToString(), out var v) ? v : null" />
                                </div>
                            </div>
                        </div>

                        <div class="ac-form-actions">
                            <button type="submit" class="ac-submit-btn">
                                @(isEditingArea ? "💾 Aktualisieren" : "✅ Erstellen")
                            </button>
                            <button type="button" class="ac-cancel-btn"
                                    @onclick="CancelAreaEdit">
                                Abbrechen
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        }

        @if (areas == null)
        {
            <div class="ac-state-card ac-state-card--info">
                <div class="ac-state-card__icon">⏳</div>
                <div class="ac-state-card__content">
                    <h3>Zuweisungen werden geladen...</h3>
                </div>
            </div>
        }
        else if (!areas.Any())
        {
            <div class="ac-state-card ac-state-card--empty">
                <div class="ac-state-card__icon">📭</div>
                <div class="ac-state-card__content">
                    <h3>Keine Zuweisungen vorhanden</h3>
                    <p>Weise eine Bereich-Vorlage einem Event zu.</p>
                </div>
            </div>
        }
        else
        {
            <!-- Filter-Bar -->
            <div class="ac-filter-bar">
                <div class="ac-field">
                    <label>Event</label>
                    <select class="ac-input" @bind="areaFilterEventId">
                        <option value="0">Alle Events</option>
                        @foreach (var evt in events ?? new())
                        {
                            <option value="@evt.Id">@evt.Name</option>
                        }
                    </select>
                </div>
                <div class="ac-field">
                    <label>Kategorie</label>
                    <select class="ac-input" @bind="areaFilterCategoryId">
                        <option value="0">Alle Kategorien</option>
                        @foreach (var cat in categories ?? new())
                        {
                            <option value="@cat.Id">@cat.Name</option>
                        }
                    </select>
                </div>
                <div class="ac-field" style="align-self:flex-end">
                    <button class="ac-cancel-btn"
                            @onclick="() => { areaFilterEventId = 0; areaFilterCategoryId = 0; }">
                        ✕ Zurücksetzen
                    </button>
                </div>
                <div style="align-self:flex-end;margin-left:auto;font-size:.85rem;color:var(--color-text-medium)">
                    @DisplayedAreas.Count() von @areas!.Count Einträge
                </div>
            </div>

            @if (!DisplayedAreas.Any())
            {
                <div class="ac-state-card ac-state-card--empty">
                    <div class="ac-state-card__icon">🔍</div>
                    <div class="ac-state-card__content">
                        <h3>Keine Treffer</h3>
                        <p>Kein Eintrag passt zu den gewählten Filtern.</p>
                    </div>
                </div>
            }
            else
            {
                <table class="ac-table">
                    <thead>
                        <tr>
                            <th class="ac-th-sort" @onclick='() => SortAreaBy("Bereich")'>
                                Bereich <span class="ac-sort-icon">@AreaSortIcon("Bereich")</span>
                            </th>
                            <th class="ac-th-sort" @onclick='() => SortAreaBy("Kategorie")'>
                                Kategorie <span class="ac-sort-icon">@AreaSortIcon("Kategorie")</span>
                            </th>
                            <th>Min. Alter</th>
                            <th class="ac-th-sort" @onclick='() => SortAreaBy("Kapazität")'>
                                Kapazität <span class="ac-sort-icon">@AreaSortIcon("Kapazität")</span>
                            </th>
                            <th class="ac-th-sort" @onclick='() => SortAreaBy("Datum")'>
                                Datum <span class="ac-sort-icon">@AreaSortIcon("Datum")</span>
                            </th>
                            <th class="ac-th-sort" @onclick='() => SortAreaBy("Zeit")'>
                                Zeit <span class="ac-sort-icon">@AreaSortIcon("Zeit")</span>
                            </th>
                            <th class="ac-th-sort" @onclick='() => SortAreaBy("Event")'>
                                Event <span class="ac-sort-icon">@AreaSortIcon("Event")</span>
                            </th>
                            <th>Standort</th>
                            <th>Aktionen</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var area in DisplayedAreas)
                        {
                            <tr>
                                <td><strong>@(area.AreaTemplate?.Name ?? "–")</strong></td>
                                <td>
                                    <span class="ac-badge ac-badge--category">
                                        @(area.AreaTemplate?.AreaCategory?.Name ?? "–")
                                    </span>
                                </td>
                                <td>@(area.AreaTemplate?.MinAge ?? 0)</td>
                                <td>
                                    @if (area.MaxCapacity >= 999)
                                    {
                                        <span class="ac-badge ac-badge--unlimited">∞ Unbegrenzt</span>
                                    }
                                    else
                                    {
                                        @area.MaxCapacity
                                    }
                                </td>
                                <td>@area.Date.ToShortDateString()</td>
                                <td>@area.TimeSlot</td>
                                <td>
                                    <span class="ac-event-pill">🎪 @area.Event?.Name</span>
                                </td>
                                <td>@(area.AreaTemplate?.Location ?? "–")</td>
                                <td>
                                    <div class="ac-actions">
                                        <button class="ac-btn ac-btn--edit"
                                                @onclick="() => EditArea(area)">
                                            ✏️ Edit
                                        </button>
                                        <button class="ac-btn ac-btn--delete"
                                                @onclick="() => DeleteArea(area.Id)">
                                            🗑️ Löschen
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        }
    }

    <!-- ══════════════════════════════════════════════════
         TAB: KATEGORIEN
    ══════════════════════════════════════════════════ -->
    @if (activeTab == Tab.Categories)
    {
        <div class="ac-toolbar">
            <button class="ac-submit-btn" @onclick="ShowCreateCategoryForm">
                ＋ Neue Kategorie
            </button>
        </div>

        @if (showCategoryForm)
        {
            <div class="ac-form-card">
                <div class="ac-form-card__header">
                    <h3>@(isEditingCategory ? "✏️ Kategorie bearbeiten" : "➕ Neue Kategorie erstellen")</h3>
                </div>
                <div class="ac-form-card__body">
                    <EditForm Model="currentCategory" OnValidSubmit="SubmitCategoryForm">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="ac-validation" />

                        <div class="ac-form-grid">
                            <div class="ac-field">
                                <label>Name</label>
                                <InputText @bind-Value="currentCategory.Name" class="ac-input"
                                           placeholder="z.B. Verkauf" />
                            </div>
                        </div>

                        <div class="ac-form-actions">
                            <button type="submit" class="ac-submit-btn">
                                @(isEditingCategory ? "💾 Aktualisieren" : "✅ Erstellen")
                            </button>
                            <button type="button" class="ac-cancel-btn"
                                    @onclick="CancelCategoryEdit">
                                Abbrechen
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        }

        @if (categories == null)
        {
            <div class="ac-state-card ac-state-card--info">
                <div class="ac-state-card__icon">⏳</div>
                <div class="ac-state-card__content">
                    <h3>Kategorien werden geladen...</h3>
                </div>
            </div>
        }
        else if (!categories.Any())
        {
            <div class="ac-state-card ac-state-card--empty">
                <div class="ac-state-card__icon">📭</div>
                <div class="ac-state-card__content">
                    <h3>Keine Kategorien vorhanden</h3>
                    <p>Erstelle eine neue Kategorie mit dem Button oben.</p>
                </div>
            </div>
        }
        else
        {
            <table class="ac-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Vorlagen</th>
                        <th>Aktionen</th>
                    </tr>
                </thead>
                <tbody>
                    @{ var catList = (categories ?? new()).ToList(); }
                    @foreach (var cat in catList)
                    {
                        var templateCount = templates?.Count(t => t.AreaCategoryId == cat.Id) ?? 0;
                        var catIdx        = catList.IndexOf(cat);
                        <tr>
                            <td><strong>@cat.Name</strong></td>
                            <td>
                                <span class="ac-badge ac-badge--category">
                                    @templateCount Vorlagen
                                </span>
                            </td>
                            <td>
                                <div class="ac-actions">
                                    <button class="ac-btn ac-btn--edit" style="padding:.38rem .65rem"
                                            @onclick="() => MoveCategory(cat.Id, -1)"
                                            disabled="@(catIdx == 0)" title="Nach oben">
                                        ▲
                                    </button>
                                    <button class="ac-btn ac-btn--edit" style="padding:.38rem .65rem"
                                            @onclick="() => MoveCategory(cat.Id, 1)"
                                            disabled="@(catIdx == catList.Count - 1)" title="Nach unten">
                                        ▼
                                    </button>
                                    <button class="ac-btn ac-btn--edit"
                                            @onclick="() => EditCategory(cat)">
                                        ✏️ Edit
                                    </button>
                                    <button class="ac-btn ac-btn--delete"
                                            @onclick="() => DeleteCategory(cat.Id)"
                                            disabled="@(templateCount > 0)">
                                        🗑️ Löschen
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    }

</div>

@code {
    private enum Tab { Events, Templates, Areas, Categories }
    private Tab activeTab = Tab.Events;

    // ── Data ──────────────────────────────────────────────────────────────────
    private List<Event>?        events     = new();
    private List<AreaTemplate>? templates  = new();
    private List<Area>?         areas      = new();
    private List<AreaCategory>? categories = new();

    // ── Events ────────────────────────────────────────────────────────────────
    private Event currentEvent   = new();
    private bool  showEventForm  = false;
    private bool  isEditingEvent = false;

    // ── Templates ─────────────────────────────────────────────────────────────
    private AreaTemplate currentTemplate   = new();
    private bool         showTemplateForm  = false;
    private bool         isEditingTemplate = false;

    // ── Areas ─────────────────────────────────────────────────────────────────
    private Area currentArea   = new();
    private bool showAreaForm  = false;
    private bool isEditingArea = false;

    // ── Sort (Vorlagen) ───────────────────────────────────────────────────────
    private string templateSortColumn = "Name";
    private bool   templateSortAsc    = true;

    private IEnumerable<AreaTemplate> DisplayedTemplates
    {
        get
        {
            var result = (templates ?? new()).AsEnumerable();
            result = templateSortColumn switch
            {
                "Kategorie"    => templateSortAsc ? result.OrderBy(t => t.AreaCategory?.Name)  : result.OrderByDescending(t => t.AreaCategory?.Name),
                "MinAlter"     => templateSortAsc ? result.OrderBy(t => t.MinAge)              : result.OrderByDescending(t => t.MinAge),
                "Standort"     => templateSortAsc ? result.OrderBy(t => t.Location)            : result.OrderByDescending(t => t.Location),
                "Zuweisungen"  => templateSortAsc ? result.OrderBy(t => t.Areas.Count)         : result.OrderByDescending(t => t.Areas.Count),
                _              => templateSortAsc ? result.OrderBy(t => t.Name)                : result.OrderByDescending(t => t.Name),
            };
            return result;
        }
    }

    private void SortTemplateBy(string column)
    {
        if (templateSortColumn == column)
            templateSortAsc = !templateSortAsc;
        else
        {
            templateSortColumn = column;
            templateSortAsc    = true;
        }
    }

    private string TemplateSortIcon(string column) =>
        templateSortColumn != column ? "⇅" : templateSortAsc ? "▲" : "▼";

    // ── Filter & Sort (Zuweisungen) ───────────────────────────────────────────
    private int    areaFilterEventId    = 0;
    private int    areaFilterCategoryId = 0;
    private string areaSortColumn       = "Event";
    private bool   areaSortAsc          = true;

    private IEnumerable<Area> DisplayedAreas
    {
        get
        {
            var result = (areas ?? new()).AsEnumerable();
            if (areaFilterEventId > 0)
                result = result.Where(a => a.EventId == areaFilterEventId);
            if (areaFilterCategoryId > 0)
                result = result.Where(a => a.AreaTemplate?.AreaCategoryId == areaFilterCategoryId);
            result = areaSortColumn switch
            {
                "Bereich"   => areaSortAsc ? result.OrderBy(a => a.AreaTemplate?.Name)               : result.OrderByDescending(a => a.AreaTemplate?.Name),
                "Kategorie" => areaSortAsc ? result.OrderBy(a => a.AreaTemplate?.AreaCategory?.Name) : result.OrderByDescending(a => a.AreaTemplate?.AreaCategory?.Name),
                "Kapazität" => areaSortAsc ? result.OrderBy(a => a.MaxCapacity)                      : result.OrderByDescending(a => a.MaxCapacity),
                "Datum"     => areaSortAsc ? result.OrderBy(a => a.Date)                             : result.OrderByDescending(a => a.Date),
                "Zeit"      => areaSortAsc ? result.OrderBy(a => a.TimeSlot)                         : result.OrderByDescending(a => a.TimeSlot),
                "Event"     => areaSortAsc ? result.OrderBy(a => a.Event?.Name).ThenBy(a => a.Date)  : result.OrderByDescending(a => a.Event?.Name).ThenByDescending(a => a.Date),
                _           => result
            };
            return result;
        }
    }

    private void SortAreaBy(string column)
    {
        if (areaSortColumn == column)
            areaSortAsc = !areaSortAsc;
        else
        {
            areaSortColumn = column;
            areaSortAsc    = true;
        }
    }

    private string AreaSortIcon(string column) =>
        areaSortColumn != column ? "⇅" : areaSortAsc ? "▲" : "▼";

    // ── Copy ──────────────────────────────────────────────────────────────────
    private bool    showCopyForm      = false;
    private int     copySourceEventId = 0;
    private int     copyTargetEventId = 0;
    private string? copyMessage       = null;
    private bool    copySuccess       = false;
    private bool    isCopying         = false;

    // ── Categories ────────────────────────────────────────────────────────────
    private AreaCategory currentCategory   = new();
    private bool         showCategoryForm  = false;
    private bool         isEditingCategory = false;

    // ── Init ──────────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        events     = await AreaService.GetAllEventsAsync();
        templates  = await AreaService.GetAllAreaTemplatesAsync();
        areas      = await AreaService.GetAllAreasAsync();
        categories = await AreaService.GetAllCategoriesAsync();
    }

    private void SetTab(Tab tab)
    {
        activeTab        = tab;
        showEventForm    = false;
        showTemplateForm = false;
        showAreaForm     = false;
        showCategoryForm = false;
        showCopyForm     = false;
        copyMessage      = null;
    }

    // ── Events CRUD ───────────────────────────────────────────────────────────
    private void ShowCreateEventForm()
    {
        showEventForm  = true;
        isEditingEvent = false;
        currentEvent   = new Event { Date = DateTime.Today, IsActive = true };
    }

    private void CancelEventEdit()
    {
        showEventForm  = false;
        isEditingEvent = false;
        currentEvent   = new Event();
    }

    private async Task SubmitEventForm()
    {
        if (isEditingEvent)
            await AreaService.UpdateEventAsync(currentEvent);
        else
            await AreaService.CreateEventAsync(currentEvent);

        events = await AreaService.GetAllEventsAsync();
        CancelEventEdit();
    }

    private void EditEvent(Event evt)
    {
        isEditingEvent = true;
        showEventForm  = true;
        currentEvent   = new Event
        {
            Id          = evt.Id,
            Name        = evt.Name,
            Date        = evt.Date,
            Description = evt.Description,
            IsActive    = evt.IsActive
        };
    }

    private async Task ToggleEventActive(int id)
    {
        var evt = await AreaService.GetEventByIdAsync(id);
        evt.IsActive = !evt.IsActive;
        await AreaService.UpdateEventAsync(evt);
        events = await AreaService.GetAllEventsAsync();
    }

    private async Task DeleteEvent(int id)
    {
        await AreaService.DeleteEventAsync(id);
        events = await AreaService.GetAllEventsAsync();
    }

    // ── Templates CRUD ────────────────────────────────────────────────────────
    private void ShowCreateTemplateForm()
    {
        showTemplateForm  = true;
        isEditingTemplate = false;
        currentTemplate   = new AreaTemplate
        {
            AreaCategoryId = categories?.FirstOrDefault()?.Id ?? 0
        };
    }

    private void CancelTemplateEdit()
    {
        showTemplateForm  = false;
        isEditingTemplate = false;
        currentTemplate   = new AreaTemplate();
    }

    private async Task SubmitTemplateForm()
    {
        if (isEditingTemplate)
            await AreaService.UpdateAreaTemplateAsync(currentTemplate);
        else
            await AreaService.CreateAreaTemplateAsync(currentTemplate);

        templates = await AreaService.GetAllAreaTemplatesAsync();
        CancelTemplateEdit();
    }

    private void EditTemplate(AreaTemplate t)
    {
        isEditingTemplate = true;
        showTemplateForm  = true;
        currentTemplate   = new AreaTemplate
        {
            Id              = t.Id,
            Name            = t.Name,
            MinAge          = t.MinAge,
            Location        = t.Location,
            AreaCategoryId  = t.AreaCategoryId,
            MandatoryStufen = t.MandatoryStufen
        };
    }

    private async Task DeleteTemplate(int id)
    {
        await AreaService.DeleteAreaTemplateAsync(id);
        templates = await AreaService.GetAllAreaTemplatesAsync();
    }

    // ── Areas CRUD ────────────────────────────────────────────────────────────
    private async Task ExecuteCopy()
    {
        if (copySourceEventId == 0 || copyTargetEventId == 0 || copySourceEventId == copyTargetEventId)
            return;

        isCopying   = true;
        copyMessage = null;
        StateHasChanged();

        try
        {
            var count = await AreaService.CopyAreasToEventAsync(copySourceEventId, copyTargetEventId);
            areas       = await AreaService.GetAllAreasAsync();
            templates   = await AreaService.GetAllAreaTemplatesAsync();
            copySuccess = true;
            var targetName = events?.FirstOrDefault(e => e.Id == copyTargetEventId)?.Name ?? "";
            copyMessage = $"{count} Zuweisung(en) erfolgreich nach «{targetName}» kopiert.";
        }
        catch (Exception ex)
        {
            copySuccess = false;
            copyMessage = $"Fehler: {ex.Message}";
        }
        finally
        {
            isCopying = false;
        }
    }

    private void ShowCreateAreaForm()
    {
        showAreaForm  = true;
        isEditingArea = false;
        var firstEvent = events?.FirstOrDefault();
        currentArea   = new Area
        {
            Date           = firstEvent?.Date ?? DateTime.Today,
            EventId        = firstEvent?.Id ?? 0,
            AreaTemplateId = templates?.FirstOrDefault()?.Id ?? 0
        };
    }

    private void SyncAreaDateToEvent()
    {
        var ev = events?.FirstOrDefault(e => e.Id == currentArea.EventId);
        if (ev != null)
            currentArea.Date = ev.Date;
    }

    private void CancelAreaEdit()
    {
        showAreaForm  = false;
        isEditingArea = false;
        currentArea   = new Area();
    }

    private async Task SubmitAreaForm()
    {
        if (isEditingArea)
            await AreaService.UpdateAreaAsync(currentArea);
        else
            await AreaService.CreateAreaAsync(currentArea);

        areas     = await AreaService.GetAllAreasAsync();
        templates = await AreaService.GetAllAreaTemplatesAsync();
        CancelAreaEdit();
    }

    private void EditArea(Area area)
    {
        isEditingArea = true;
        showAreaForm  = true;
        currentArea   = new Area
        {
            Id                       = area.Id,
            AreaTemplateId           = area.AreaTemplateId,
            MaxCapacity              = area.MaxCapacity,
            Date                     = area.Date,
            TimeSlot                 = area.TimeSlot,
            EventId                  = area.EventId,
            AlternativeTimeSlot      = area.AlternativeTimeSlot,
            AlternativeMaxCapacity   = area.AlternativeMaxCapacity
        };
    }

    private async Task DeleteArea(int id)
    {
        await AreaService.DeleteAreaAsync(id);
        areas     = await AreaService.GetAllAreasAsync();
        templates = await AreaService.GetAllAreaTemplatesAsync();
    }

    // ── Categories CRUD ───────────────────────────────────────────────────────
    private void ShowCreateCategoryForm()
    {
        showCategoryForm  = true;
        isEditingCategory = false;
        currentCategory   = new AreaCategory();
    }

    private void CancelCategoryEdit()
    {
        showCategoryForm  = false;
        isEditingCategory = false;
        currentCategory   = new AreaCategory();
    }

    private async Task SubmitCategoryForm()
    {
        if (isEditingCategory)
            await AreaService.UpdateCategoryAsync(currentCategory);
        else
            await AreaService.CreateCategoryAsync(currentCategory);

        categories = await AreaService.GetAllCategoriesAsync();
        CancelCategoryEdit();
    }

    private void EditCategory(AreaCategory cat)
    {
        isEditingCategory = true;
        showCategoryForm  = true;
        currentCategory   = new AreaCategory
        {
            Id   = cat.Id,
            Name = cat.Name
        };
    }

    private async Task DeleteCategory(int id)
    {
        await AreaService.DeleteCategoryAsync(id);
        categories = await AreaService.GetAllCategoriesAsync();
        templates  = await AreaService.GetAllAreaTemplatesAsync();
    }

    private async Task MoveCategory(int id, int direction)
    {
        await AreaService.MoveCategoryAsync(id, direction);
        categories = await AreaService.GetAllCategoriesAsync();
    }
}

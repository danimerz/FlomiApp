@page "/admin/stats"
@using FlomiApp.Data.Models
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using System.Globalization
@using System.Text.Json
@inject FlomiApp.Data.ApplicationDbContext Db
@inject IJSRuntime JS
@using FlomiApp.Security
@attribute [Authorize(Roles = Roles.Admin)]

<PageTitle>Statistiken – Admin</PageTitle>

<!-- Chart.js CDN -->
<HeadContent>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
</HeadContent>

<div class="dashboard-page">

    <section class="dashboard-hero">
        <div class="dashboard-hero__content">
            <span class="dashboard-hero__badge">Administration</span>
            <h1>Statistiken</h1>
            <p>Auswertungen und Diagramme für den Flomi-Betrieb.</p>
        </div>
    </section>

    <!-- Filter -->
    <div class="stats-filter">
        <div class="stats-filter__group">
            <label>Event</label>
            <select class="stats-select" @bind="selectedEventId" @bind:after="LoadAndRender">
                <option value="0">Alle aktiven Events</option>
                @foreach (var ev in events)
                {
                    <option value="@ev.Id">@ev.Name (@ev.Date.ToShortDateString())</option>
                }
            </select>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="state-card state-card--info">
            <div class="state-card__icon">⏳</div>
            <div class="state-card__content"><h3>Daten werden geladen...</h3></div>
        </div>
    }
    else
    {
        <!-- KPI-Zeile -->
        <div class="stats-kpi-row">
            <div class="stats-kpi">
                <span class="stats-kpi__num">@totalRegistered</span>
                <span class="stats-kpi__label">Anmeldungen</span>
            </div>
            <div class="stats-kpi">
                <span class="stats-kpi__num">@totalCancelled</span>
                <span class="stats-kpi__label">Stornierungen</span>
            </div>
            <div class="stats-kpi">
                <span class="stats-kpi__num">@Math.Round(fillRate, 0)%</span>
                <span class="stats-kpi__label">Ø Auslastung</span>
            </div>
            <div class="stats-kpi">
                <span class="stats-kpi__num">@uniquePersons</span>
                <span class="stats-kpi__label">Personen</span>
            </div>
        </div>

        <!-- Charts Grid -->
        <div class="stats-grid">

            <!-- Timeline -->
            <div class="stats-card stats-card--wide">
                <h3 class="stats-card__title">📈 Anmeldungen über Zeit (letzte 30 Tage)</h3>
                <div class="stats-chart-wrap" style="height:220px">
                    <canvas id="chart-timeline"></canvas>
                </div>
            </div>

            <!-- Kategorie Donut -->
            <div class="stats-card">
                <h3 class="stats-card__title">🍩 Nach Kategorie</h3>
                <div class="stats-chart-wrap" style="height:220px">
                    <canvas id="chart-category"></canvas>
                </div>
            </div>

            <!-- Stufe Bar -->
            <div class="stats-card">
                <h3 class="stats-card__title">👥 Nach Stufe</h3>
                <div class="stats-chart-wrap" style="height:220px">
                    <canvas id="chart-stufe"></canvas>
                </div>
            </div>

            <!-- Bereich Auslastung -->
            <div class="stats-card stats-card--wide">
                <h3 class="stats-card__title">📊 Belegungsrate pro Bereich</h3>
                <div class="stats-chart-wrap" style="height: @(Math.Max(180, areaLabels.Count * 36))px">
                    <canvas id="chart-areas"></canvas>
                </div>
            </div>

        </div>
    }

</div>

@code {
    private List<Event> events          = new();
    private int         selectedEventId = 0;
    private bool        isLoading       = true;
    private bool        chartsReady     = false;

    // KPIs
    private int    totalRegistered;
    private int    totalCancelled;
    private double fillRate;
    private int    uniquePersons;

    // Chart data
    private List<string> timelineLabels    = new();
    private List<int>    timelineReg       = new();
    private List<int>    timelineCanc      = new();
    private List<string> categoryLabels    = new();
    private List<int>    categoryData      = new();
    private List<string> stufeLabels       = new();
    private List<int>    stufeData         = new();
    private List<string> areaLabels        = new();
    private List<int>    areaRegistered    = new();
    private List<int>    areaCapacity      = new();

    protected override async Task OnInitializedAsync()
    {
        events = await Db.Events.Where(e => e.IsActive).OrderBy(e => e.Date).ToListAsync();
        await LoadData();
        isLoading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!isLoading && !chartsReady)
        {
            chartsReady = true;
            await RenderCharts();
        }
    }

    private async Task LoadAndRender()
    {
        isLoading   = true;
        chartsReady = false;
        StateHasChanged();
        await LoadData();
        isLoading = false;
        StateHasChanged();
        await Task.Delay(50);
        await RenderCharts();
    }

    private async Task LoadData()
    {
        var query = Db.Appointments
            .Include(a => a.User)
            .Include(a => a.FamilyMember)
            .Include(a => a.Area)
                .ThenInclude(ar => ar.AreaTemplate)
                    .ThenInclude(t => t!.AreaCategory)
            .Include(a => a.Area)
                .ThenInclude(ar => ar.Event)
            .AsQueryable();

        if (selectedEventId > 0)
            query = query.Where(a => a.Area.EventId == selectedEventId);
        else
        {
            var activeIds = await Db.Events.Where(e => e.IsActive).Select(e => e.Id).ToListAsync();
            query = query.Where(a => activeIds.Contains(a.Area.EventId));
        }

        var all = await query.AsNoTracking().ToListAsync();

        totalRegistered = all.Count(a => a.Status == AppointmentStatus.Registered);
        totalCancelled  = all.Count(a => a.Status == AppointmentStatus.Cancelled);
        uniquePersons   = all.Where(a => a.Status == AppointmentStatus.Registered)
                             .Select(a => a.FamilyMemberId.HasValue
                                 ? $"fm_{a.FamilyMemberId}"
                                 : $"u_{a.UserId}")
                             .Distinct().Count();

        // Areas for fill rate
        var areaQuery = Db.Areas
            .Include(a => a.AreaTemplate)
            .Include(a => a.Appointments)
            .AsQueryable();
        if (selectedEventId > 0)
            areaQuery = areaQuery.Where(a => a.EventId == selectedEventId);
        else
        {
            var activeIds = await Db.Events.Where(e => e.IsActive).Select(e => e.Id).ToListAsync();
            areaQuery = areaQuery.Where(a => activeIds.Contains(a.EventId));
        }
        var areas = await areaQuery.AsNoTracking().ToListAsync();
        var capped = areas.Where(a => a.MaxCapacity < 999).ToList();
        fillRate = capped.Any()
            ? capped.Average(a => a.MaxCapacity > 0
                ? (double)a.Appointments.Count(ap => ap.Status == AppointmentStatus.Registered) / a.MaxCapacity * 100
                : 0)
            : 0;

        // Timeline (letzte 30 Tage)
        var since = DateTime.Today.AddDays(-29);
        timelineLabels = Enumerable.Range(0, 30)
            .Select(i => since.AddDays(i).ToString("dd.MM", new CultureInfo("de-CH")))
            .ToList();
        timelineReg  = Enumerable.Range(0, 30)
            .Select(i => all.Count(a => a.CreatedAt.Date == since.AddDays(i).Date
                                     && a.Status == AppointmentStatus.Registered))
            .ToList();
        timelineCanc = Enumerable.Range(0, 30)
            .Select(i => all.Count(a => a.CreatedAt.Date == since.AddDays(i).Date
                                     && a.Status == AppointmentStatus.Cancelled))
            .ToList();

        // Kategorie
        var byCat = all.Where(a => a.Status == AppointmentStatus.Registered)
            .GroupBy(a => a.Area?.AreaTemplate?.AreaCategory?.Name ?? "Sonstiges")
            .OrderByDescending(g => g.Count());
        categoryLabels = byCat.Select(g => g.Key).ToList();
        categoryData   = byCat.Select(g => g.Count()).ToList();

        // Stufe
        var byStufe = all.Where(a => a.Status == AppointmentStatus.Registered)
            .GroupBy(a => a.FamilyMember?.Stufe ?? a.User?.Stufe ?? "–")
            .OrderByDescending(g => g.Count());
        stufeLabels = byStufe.Select(g => g.Key).ToList();
        stufeData   = byStufe.Select(g => g.Count()).ToList();

        // Bereiche
        var areaFill = areas
            .Where(a => a.MaxCapacity < 999)
            .Select(a => new {
                Label = $"{a.AreaTemplate?.Name ?? "–"} · {a.Date:dd.MM}",
                Reg   = a.Appointments.Count(ap => ap.Status == AppointmentStatus.Registered),
                Cap   = a.MaxCapacity
            })
            .OrderByDescending(x => x.Cap > 0 ? (double)x.Reg / x.Cap : 0)
            .Take(12)
            .ToList();
        areaLabels     = areaFill.Select(x => x.Label).ToList();
        areaRegistered = areaFill.Select(x => x.Reg).ToList();
        areaCapacity   = areaFill.Select(x => x.Cap).ToList();
    }

    private async Task RenderCharts()
    {
        try
        {
            await JS.InvokeVoidAsync("flomiCharts.renderTimeline",
                "chart-timeline", timelineLabels, timelineReg, timelineCanc);

            if (categoryLabels.Any())
                await JS.InvokeVoidAsync("flomiCharts.renderCategoryDonut",
                    "chart-category", categoryLabels, categoryData);

            if (stufeLabels.Any())
                await JS.InvokeVoidAsync("flomiCharts.renderStufeBars",
                    "chart-stufe", stufeLabels, stufeData);

            if (areaLabels.Any())
                await JS.InvokeVoidAsync("flomiCharts.renderAreaBars",
                    "chart-areas", areaLabels, areaRegistered, areaCapacity);
        }
        catch { /* Chart.js noch nicht geladen */ }
    }
}

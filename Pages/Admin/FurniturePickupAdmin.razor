@page "/admin/furniture-pickup"
@using FlomiApp.Data.Models
@using Microsoft.AspNetCore.Authorization
@inject IFurniturePickupService FurniturePickupService
@attribute [Authorize(Roles = "Admin")]

<PageTitle>Möbel Abholungen – Admin</PageTitle>

<div class="dashboard-page">

    <!-- Hero -->
    <section class="dashboard-hero">
        <div class="dashboard-hero__content">
            <span class="dashboard-hero__badge">Administration</span>
            <h1>Möbel Abholungen</h1>
            <p>Alle eingegangenen Abholungsanfragen im Überblick.</p>
        </div>
    </section>

    <!-- Tabs -->
    <div class="afp-tabs">
        <button class="afp-tab @(activeTab == Tab.Requests ? "afp-tab--active" : "")"
                @onclick="() => activeTab = Tab.Requests">
            📋 Anfragen
            @if (requests != null)
            {
                <span class="afp-tab__badge">@requests.Count</span>
            }
        </button>
        <button class="afp-tab @(activeTab == Tab.Settings ? "afp-tab--active" : "")"
                @onclick="() => activeTab = Tab.Settings">
            ⚙️ Einstellungen
        </button>
    </div>

    <!-- ══════════════════════════════════════════════════
         TAB: ANFRAGEN
    ══════════════════════════════════════════════════ -->
    @if (activeTab == Tab.Requests)
    {
        @if (requests == null)
        {
            <div class="state-card state-card--info">
                <div class="state-card__icon">⏳</div>
                <div class="state-card__content">
                    <h3>Anfragen werden geladen...</h3>
                </div>
            </div>
        }
        else if (!requests.Any())
        {
            <div class="state-card state-card--empty">
                <div class="state-card__icon">📭</div>
                <div class="state-card__content">
                    <h3>Keine Anfragen vorhanden</h3>
                    <p>Es wurden noch keine Abholungsanfragen eingereicht.</p>
                </div>
            </div>
        }
        else
        {
            <!-- Filter -->
            <div class="afp-filter-row">
                <button class="btn @(filterStatus == null ? "btn-primary" : "btn-secondary")"
                        @onclick="() => SetFilter(null)">
                    Alle (@requests.Count)
                </button>
                @foreach (var status in Enum.GetValues<PickupRequestStatus>())
                {
                    <button class="btn @(filterStatus == status ? "btn-primary" : "btn-secondary")"
                            @onclick="() => SetFilter(status)">
                        @StatusLabel(status) (@requests.Count(r => r.Status == status))
                    </button>
                }
            </div>

            <table class="afp-table">
                <thead>
                    <tr>
                        <th class="afp-th-sort" @onclick='() => SortBy("#")'>
                            # <span class="afp-sort-icon">@SortIcon("#")</span>
                        </th>
                        <th class="afp-th-sort" @onclick='() => SortBy("Name")'>
                            Name <span class="afp-sort-icon">@SortIcon("Name")</span>
                        </th>
                        <th>Adresse</th>
                        <th class="afp-th-sort" @onclick='() => SortBy("Datum")'>
                            Abholdatum <span class="afp-sort-icon">@SortIcon("Datum")</span>
                        </th>
                        <th class="afp-th-sort" @onclick='() => SortBy("Event")'>
                            Event <span class="afp-sort-icon">@SortIcon("Event")</span>
                        </th>
                        <th class="afp-th-sort" @onclick='() => SortBy("Status")'>
                            Status <span class="afp-sort-icon">@SortIcon("Status")</span>
                        </th>
                        <th class="afp-th-sort" @onclick='() => SortBy("Bilder")'>
                            Bilder <span class="afp-sort-icon">@SortIcon("Bilder")</span>
                        </th>
                        <th>Aktionen</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var req in SortedRequests)
                    {
                        <tr>
                            <td><strong>#@req.OrderNumber</strong></td>
                            <td>
                                @req.FirstName @req.LastName<br />
                                <small>@req.Email</small>
                            </td>
                            <td>@req.Street, @req.PostalCode @req.City</td>
                            <td>@req.PickupDate.ToShortDateString()</td>
                            <td>
                                @if (req.EventId.HasValue)
                                {
                                    var ev = availableEvents?.FirstOrDefault(e => e.Id == req.EventId);
                                    <span class="afp-event-pill">
                                        🎪 @(ev?.Name ?? $"Event #{req.EventId}")
                                    </span>
                                }
                                else
                                {
                                    <span class="afp-event-pill afp-event-pill--none">–</span>
                                }
                            </td>
                            <td>
                                <span class="status-pill">@StatusLabel(req.Status)</span>
                            </td>
                            <td>@req.Images.Count Bild(er)</td>
                            <td>
                                <button class="afp-btn afp-btn--detail"
                                        @onclick="() => OpenDetail(req)">
                                    ✏️ Details
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    }

    <!-- ══════════════════════════════════════════════════
         TAB: EINSTELLUNGEN
    ══════════════════════════════════════════════════ -->
    @if (activeTab == Tab.Settings)
    {
        @if (settingsList == null)
        {
            <div class="state-card state-card--info">
                <div class="state-card__icon">⏳</div>
                <div class="state-card__content">
                    <h3>Einstellungen werden geladen...</h3>
                </div>
            </div>
        }
        else
        {
            @if (settingsSuccess != null)
            {
                <div class="state-card state-card--success">
                    <div class="state-card__icon">✅</div>
                    <div class="state-card__content">
                        <h3>Gespeichert!</h3>
                        <p>@settingsSuccess</p>
                    </div>
                </div>
            }

            @if (settingsError != null)
            {
                <div class="state-card state-card--error">
                    <div class="state-card__icon">⚠️</div>
                    <div class="state-card__content">
                        <h3>Fehler</h3>
                        <p>@settingsError</p>
                    </div>
                </div>
            }

            <!-- ── Pro-Event Settings Liste ── -->
            <div class="afp-settings-list">
                @foreach (var s in settingsList)
                {
                    var ev = availableEvents?.FirstOrDefault(e => e.Id == s.EventId);

                    <div class="afp-block">
                        <div class="afp-block__header">
                            <h3>
                                🎪 @(ev?.Name ?? "Kein Event zugewiesen")
                                @if (ev != null)
                                {
                                    <span class="afp-block__header-date">
                                        · @ev.Date.ToString("dd. MMMM yyyy",
                                            new System.Globalization.CultureInfo("de-CH"))
                                    </span>
                                }
                            </h3>
                        </div>
                        <div class="afp-block__body">

                            <!-- Event Zuweisung -->
                            <div class="afp-field" style="margin-bottom:1.25rem">
                                <label>Verknüpfter Event</label>
                                <select class="afp-input"
                                        value="@s.EventId"
                                        @onchange="e => OnEventChanged(s, e)">
                                    <option value="">– Kein Event –</option>
                                    @if (availableEvents != null)
                                    {
                                        @foreach (var evOpt in availableEvents)
                                        {
                                            <option value="@evOpt.Id"
                                                    selected="@(s.EventId == evOpt.Id)">
                                                @evOpt.Name (@evOpt.Date.ToShortDateString())
                                            </option>
                                        }
                                    }
                                </select>
                            </div>

                            <!-- Toggle -->
                            <div class="afp-toggle-row">
                                <div class="afp-toggle-info">
                                    <span class="afp-toggle-label">Abholservice aktiv</span>
                                    <span class="afp-toggle-desc">
                                        Wenn deaktiviert, können Benutzer für diesen Event keine Anfragen einreichen.
                                    </span>
                                </div>
                                <label class="afp-toggle">
                                    <input type="checkbox"
                                           checked="@s.IsEnabled"
                                           @onchange="e => s.IsEnabled = (bool)(e.Value ?? false)" />
                                    <span class="afp-toggle__track">
                                        <span class="afp-toggle__thumb"></span>
                                    </span>
                                </label>
                            </div>

                            <div class="afp-status-badge @(s.IsEnabled ? "afp-status-badge--on" : "afp-status-badge--off")"
                                 style="margin-bottom:1.25rem">
                                @if (s.IsEnabled)
                                {
                                    <span>🟢 Service ist aktiv</span>
                                }
                                else
                                {
                                    <span>🔴 Service ist deaktiviert</span>
                                }
                            </div>

                            <!-- Datumsspanne -->
                            <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.5rem;margin-bottom:.5rem">
                                <p class="afp-hint" style="margin:0">
                                    Lege fest, in welchem Zeitraum Benutzer ein Abholdatum wählen dürfen.
                                </p>
                                @if (s.EventId.HasValue)
                                {
                                    var evBtn = availableEvents?.FirstOrDefault(x => x.Id == s.EventId);
                                    @if (evBtn != null)
                                    {
                                        <button type="button"
                                                class="afp-btn afp-btn--detail"
                                                style="font-size:.8rem;padding:.3rem .75rem"
                                                @onclick="() => AutoFillDatesFromEvent(s, evBtn)">
                                            📅 Aus Event (−8 / −1 Tag)
                                        </button>
                                    }
                                }
                            </div>

                            <div class="afp-date-grid">
                                <div class="afp-field">
                                    <label>Frühestes Abholdatum</label>
                                    <input type="date"
                                           class="afp-input"
                                           value="@(s.PickupDateFrom?.ToString("yyyy-MM-dd") ?? "")"
                                           @onchange="e => OnDateFromChanged(s, e)" />
                                </div>

                                <div class="afp-date-arrow">→</div>

                                <div class="afp-field">
                                    <label>Spätestes Abholdatum</label>
                                    <input type="date"
                                           class="afp-input"
                                           value="@(s.PickupDateTo?.ToString("yyyy-MM-dd") ?? "")"
                                           @onchange="e => OnDateToChanged(s, e)" />
                                </div>
                            </div>

                            @if (s.PickupDateFrom.HasValue && s.PickupDateTo.HasValue)
                            {
                                @if (s.PickupDateTo < s.PickupDateFrom)
                                {
                                    <div class="state-card state-card--error" style="margin-top:1rem">
                                        <div class="state-card__icon">⚠️</div>
                                        <div class="state-card__content">
                                            <p>Das Enddatum darf nicht vor dem Startdatum liegen.</p>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <div class="afp-date-preview">
                                        📦 Abholungen möglich vom
                                        <strong>@s.PickupDateFrom.Value.ToShortDateString()</strong>
                                        bis
                                        <strong>@s.PickupDateTo.Value.ToShortDateString()</strong>
                                    </div>
                                }
                            }

                            <!-- Aktionen -->
                            <div class="afp-settings-actions">
                                <button class="afp-submit-btn"
                                        disabled="@(isSaving || IsDateRangeInvalid(s))"
                                        @onclick="() => SaveSingleSettings(s)">
                                    @if (isSaving)
                                    {
                                        <span>⏳ Wird gespeichert...</span>
                                    }
                                    else
                                    {
                                        <span>💾 Speichern</span>
                                    }
                                </button>

                                <button class="afp-delete-btn"
                                        @onclick="() => DeleteSettings(s)">
                                    🗑️ Entfernen
                                </button>
                            </div>

                        </div>
                    </div>
                }
            </div>

            <!-- Neue Einstellung hinzufügen -->
            <button class="afp-add-btn" @onclick="AddNewSettings">
                ＋ Neuen Event-Pickup hinzufügen
            </button>
        }
    }

</div>

<!-- ══════════════════════════════════════════════════
     DETAIL MODAL
══════════════════════════════════════════════════ -->
@if (selectedRequest != null)
{
    <div class="afp-modal-backdrop" @onclick="CloseDetail">
        <div class="afp-modal" @onclick:stopPropagation="true">

            <div class="afp-modal__header">
                <h3>Anfrage #@selectedRequest.OrderNumber</h3>
                <button class="afp-modal__close" @onclick="CloseDetail">✕</button>
            </div>

            <div class="afp-modal__body">

                <div class="appointment-info-list">
                    <div class="appointment-info-item">
                        <span class="label">Name</span>
                        <span class="value">@selectedRequest.FirstName @selectedRequest.LastName</span>
                    </div>
                    <div class="appointment-info-item">
                        <span class="label">E-Mail</span>
                        <span class="value">@selectedRequest.Email</span>
                    </div>
                    <div class="appointment-info-item">
                        <span class="label">Telefon</span>
                        <span class="value">@(selectedRequest.PhoneNumber ?? "–")</span>
                    </div>
                    <div class="appointment-info-item">
                        <span class="label">Adresse</span>
                        <span class="value">
                            @selectedRequest.Street,
                            @selectedRequest.PostalCode @selectedRequest.City
                        </span>
                    </div>
                    <div class="appointment-info-item">
                        <span class="label">Abholdatum</span>
                        <span class="value">@selectedRequest.PickupDate.ToShortDateString()</span>
                    </div>
                    @if (selectedRequest.EventId.HasValue)
                    {
                        var ev = availableEvents?.FirstOrDefault(e => e.Id == selectedRequest.EventId);
                        <div class="appointment-info-item">
                            <span class="label">Event</span>
                            <span class="value">🎪 @(ev?.Name ?? $"Event #{selectedRequest.EventId}")</span>
                        </div>
                    }
                    <div class="appointment-info-item">
                        <span class="label">Beschreibung</span>
                        <span class="value">@selectedRequest.Description</span>
                    </div>
                </div>

                <!-- Bilder -->
                @if (selectedRequest.Images.Any())
                {
                    <h4 style="margin-top:1.25rem; margin-bottom:.75rem">📷 Fotos</h4>
                    <div class="afp-modal__images">
                        @foreach (var img in selectedRequest.Images)
                        {
                            var src = $"data:{img.ContentType};base64,{Convert.ToBase64String(img.ImageData)}";
                            <img src="@src" alt="@img.FileName"
                                 @onclick="() => OpenImageModal(src)" />
                        }
                    </div>
                }

                <!-- Admin-Notiz -->
                <div class="form-group" style="margin-top:1.25rem">
                    <label>Admin-Notiz (optional)</label>
                    <textarea class="form-control" rows="3"
                              @bind="adminNote"
                              placeholder="z.B. Termin bestätigt für..."></textarea>
                </div>

            </div>

            <div class="afp-modal__footer">
                <button class="btn btn-success"
                        @onclick="() => UpdateStatus(PickupRequestStatus.Accepted)">
                    ✅ Akzeptieren
                </button>
                <button class="btn btn-danger"
                        @onclick="() => UpdateStatus(PickupRequestStatus.Rejected)">
                    ❌ Ablehnen
                </button>
                    <!-- ✅ NEU: Admin kann löschen -->
                <button class="btn btn-dark"
                        @onclick="AdminDeleteRequest">
                    🗑️ Löschen
                </button>
                <button class="btn btn-secondary"
                        @onclick="CloseDetail">
                    Schliessen
                </button>
            </div>

        </div>
    </div>
}

<!-- Bild-Vollansicht -->
@if (fullImageSrc != null)
{
    <div class="afp-image-backdrop" @onclick="CloseImageModal">
        <img src="@fullImageSrc" alt="Vollansicht" />
    </div>
}

@code {
    // ── Enums ────────────────────────────────────────────────────────────────
    private enum Tab { Requests, Settings }
    private Tab activeTab = Tab.Requests;

    // ── Anfragen ─────────────────────────────────────────────────────────────
    private List<FurniturePickupRequest>? requests;
    private FurniturePickupRequest?       selectedRequest;
    private PickupRequestStatus?          filterStatus = null;
    private string?                       adminNote;
    private string?                       fullImageSrc;

    private List<FurniturePickupRequest> FilteredRequests =>
        filterStatus == null
            ? requests!
            : requests!.Where(r => r.Status == filterStatus).ToList();

    // ── Sort ──────────────────────────────────────────────────────────────────
    private string sortColumn = "Datum";
    private bool   sortAsc    = true;

    private IEnumerable<FurniturePickupRequest> SortedRequests
    {
        get
        {
            var r = FilteredRequests.AsEnumerable();
            return sortColumn switch
            {
                "#"      => sortAsc ? r.OrderBy(x => x.OrderNumber)      : r.OrderByDescending(x => x.OrderNumber),
                "Name"   => sortAsc ? r.OrderBy(x => x.LastName)         : r.OrderByDescending(x => x.LastName),
                "Datum"  => sortAsc ? r.OrderBy(x => x.PickupDate)       : r.OrderByDescending(x => x.PickupDate),
                "Event"  => sortAsc ? r.OrderBy(x => x.EventId)          : r.OrderByDescending(x => x.EventId),
                "Status" => sortAsc ? r.OrderBy(x => x.Status)           : r.OrderByDescending(x => x.Status),
                "Bilder" => sortAsc ? r.OrderBy(x => x.Images.Count)     : r.OrderByDescending(x => x.Images.Count),
                _        => r
            };
        }
    }

    private void SortBy(string column)
    {
        if (sortColumn == column) sortAsc = !sortAsc;
        else { sortColumn = column; sortAsc = true; }
    }

    private string SortIcon(string col) =>
        sortColumn != col ? "⇅" : sortAsc ? "▲" : "▼";

    // ── Einstellungen ────────────────────────────────────────────────────────
    private List<FurniturePickupSettings>? settingsList;
    private List<Event>?                   availableEvents;
    private bool    isSaving        = false;
    private string? settingsSuccess = null;
    private string? settingsError   = null;

    // ── Init ─────────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        requests        = await FurniturePickupService.GetAllRequestsAsync();
        availableEvents = await FurniturePickupService.GetAvailableEventsAsync();

        // Alle bestehenden Settings laden
        settingsList    = await FurniturePickupService.GetAllSettingsAsync();
    }

    // ── Filter ───────────────────────────────────────────────────────────────
    private void SetFilter(PickupRequestStatus? status) => filterStatus = status;

    // ── Detail Modal ─────────────────────────────────────────────────────────
    private void OpenDetail(FurniturePickupRequest req)
    {
        selectedRequest = req;
        adminNote       = req.AdminNote;
    }

    private void CloseDetail()
    {
        selectedRequest = null;
        adminNote       = null;
    }

    private async Task UpdateStatus(PickupRequestStatus status)
    {
        if (selectedRequest == null) return;

        await FurniturePickupService.UpdateStatusAsync(
            selectedRequest.Id, status, adminNote);

        requests = await FurniturePickupService.GetAllRequestsAsync();
        CloseDetail();
    }

    // ── Bild Modal ───────────────────────────────────────────────────────────
    private void OpenImageModal(string src) => fullImageSrc = src;
    private void CloseImageModal()          => fullImageSrc = null;

    // ── Settings – Event Dropdown ─────────────────────────────────────────────
    private void OnEventChanged(FurniturePickupSettings s, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var id) && id > 0)
        {
            s.EventId = id;
            var ev = availableEvents?.FirstOrDefault(x => x.Id == id);
            if (ev != null)
            {
                s.PickupDateFrom = ev.Date.AddDays(-8);
                s.PickupDateTo   = ev.Date.AddDays(-1);
            }
        }
        else
        {
            s.EventId        = null;
            s.PickupDateFrom = null;
            s.PickupDateTo   = null;
        }
    }

    // ── Settings – Datum ──────────────────────────────────────────────────────
    private void AutoFillDatesFromEvent(FurniturePickupSettings s, Event ev)
    {
        s.PickupDateFrom = ev.Date.AddDays(-8);
        s.PickupDateTo   = ev.Date.AddDays(-1);
    }

    private void OnDateFromChanged(FurniturePickupSettings s, ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var d))
            s.PickupDateFrom = d;
        else
            s.PickupDateFrom = null;
    }

    private void OnDateToChanged(FurniturePickupSettings s, ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var d))
            s.PickupDateTo = d;
        else
            s.PickupDateTo = null;
    }

    // ── Settings – Speichern ──────────────────────────────────────────────────
    private bool IsDateRangeInvalid(FurniturePickupSettings s) =>
        s.PickupDateFrom.HasValue &&
        s.PickupDateTo.HasValue   &&
        s.PickupDateTo < s.PickupDateFrom;

    private async Task SaveSingleSettings(FurniturePickupSettings s)
    {
        isSaving        = true;
        settingsSuccess = null;
        settingsError   = null;

        try
        {
            await FurniturePickupService.SaveSettingsAsync(s);
            settingsSuccess = $"Einstellungen erfolgreich gespeichert.";
        }
        catch (Exception ex)
        {
            settingsError = $"Fehler beim Speichern: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    // ── Settings – Neu hinzufügen ─────────────────────────────────────────────
    private void AddNewSettings()
    {
        settingsList!.Add(new FurniturePickupSettings
        {
            IsEnabled      = false,
            PickupDateFrom = null,
            PickupDateTo   = null,
            EventId        = null
        });
    }

    // ── Settings – Entfernen ──────────────────────────────────────────────────
   private async Task DeleteSettings(FurniturePickupSettings s)
    {
        if (s.Id > 0)
        {
            // 👇 neu – sauberes Löschen über Service
            await FurniturePickupService.DeleteSettingsAsync(s.Id);
        }

        settingsList!.Remove(s);
    }

    // ── Status Label ─────────────────────────────────────────────────────────
    private string StatusLabel(PickupRequestStatus s) => s switch
    {
        PickupRequestStatus.Pending  => "⏳ Ausstehend",
        PickupRequestStatus.Accepted => "✅ Akzeptiert",
        PickupRequestStatus.Rejected => "❌ Abgelehnt",
        PickupRequestStatus.Deleted => "🗑️ Gelöscht",
        _                            => s.ToString()
    };
    // ── Admin: Anfrage löschen ────────────────────────────────────────────────
private async Task AdminDeleteRequest()
{
    if (selectedRequest == null) return;

    await FurniturePickupService.DeleteRequestAsync(selectedRequest.Id);
    requests = await FurniturePickupService.GetAllRequestsAsync();
    CloseDetail();
}
}
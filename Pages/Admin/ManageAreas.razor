@page "/admin/areas"
@using FlomiApp.Data.Models
@using Microsoft.AspNetCore.Authorization
@inject IAreaService AreaService
@attribute [Authorize(Roles = "Admin")]

<PageTitle>Manage Areas</PageTitle>

<h3>Manage Areas</h3>

<button class="btn btn-primary" @onclick="ShowCreateForm" disabled="@(events == null || !events.Any())">Add New Area</button>
@if (events != null && !events.Any())
{
    <p class="text-warning">Bitte erst ein Event anlegen, bevor Bereiche erstellt werden.</p>
}

@if ((isEditing || showCreateForm) && events != null && events.Any())
{
    <EditForm Model="currentArea" OnValidSubmit="SubmitAreaForm">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="form-group">
            <label>Name</label>
            <InputText @bind-Value="currentArea.Name" class="form-control" />
        </div>
        <div class="form-group">
            <label>Max Capacity</label>
            <InputNumber @bind-Value="currentArea.MaxCapacity" class="form-control" />
        </div>
        <div class="form-group">
            <label>Date</label>
            <InputDate @bind-Value="currentArea.Date" class="form-control" />
        </div>
        <div class="form-group">
            <label>Time Slot</label>
            <InputText @bind-Value="currentArea.TimeSlot" class="form-control" />
        </div>
        <div class="form-group">
            <label>Location</label>
            <InputText @bind-Value="currentArea.Location" class="form-control" />
        </div>
        <div class="form-group">
            <label>Category</label>
            <InputSelect @bind-Value="currentArea.Category" class="form-control">
                <option value="@AreaCategory.Sammeln">Sammeln</option>
                <option value="@AreaCategory.Sortieren">Sortieren</option>
                <option value="@AreaCategory.Verkauf">Verkauf</option>
                <option value="@AreaCategory.Sonstiges">Sonstiges</option>
            </InputSelect>
        </div>
        <div class="form-group">
            <label>Mindestalter</label>
            <InputNumber @bind-Value="currentArea.MinAge" class="form-control" />
        </div>
        <div class="form-group">
            <label>Event</label>
            <InputSelect @bind-Value="currentArea.EventId" class="form-control">
                @foreach (var evt in events)
                {
                    <option value="@evt.Id">@evt.Name (@evt.Date.ToShortDateString())</option>
                }
            </InputSelect>
        </div>

        <button type="submit" class="btn btn-success">@(isEditing ? "Update" : "Create")</button>
        <button type="button" class="btn btn-secondary" @onclick="CancelEdit">Cancel</button>
    </EditForm>
}

@if (areas == null)
{
    <p>Loading areas...</p>
}
else if (!areas.Any())
{
    <p>No areas have been configured yet.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Category</th>
                <th>Min Age</th>
                <th>Max Capacity</th>
                <th>Date</th>
                <th>Time</th>
                <th>Event</th>
                <th>Location</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var area in areas)
            {
                <tr>
                    <td>@area.Name</td>
                    <td>@area.Category</td>
                    <td>@area.MinAge</td>
                    <td>@area.MaxCapacity</td>
                    <td>@area.Date.ToShortDateString()</td>
                    <td>@area.TimeSlot</td>
                    <td>@area.Event?.Name</td>
                    <td>@area.Location</td>
                    <td>
                        <button class="btn btn-warning" @onclick="() => EditArea(area)">Edit</button>
                        <button class="btn btn-danger" @onclick="() => DeleteArea(area.Id)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Area> areas = new();
    private List<Event> events = new();
    private Area currentArea = new();
    private bool showCreateForm = false;
    private bool isEditing = false;

    protected override async Task OnInitializedAsync()
    {
        events = await AreaService.GetAllEventsAsync();
        areas = await AreaService.GetAllAreasAsync();
    }

    private void ShowCreateForm()
    {
        showCreateForm = true;
        isEditing = false;
        currentArea = new Area
        {
            Date = DateTime.Today,
            EventId = events.FirstOrDefault()?.Id ?? 0
        };
    }

    private void CancelEdit()
    {
        showCreateForm = false;
        isEditing = false;
        currentArea = new Area();
    }

    private async Task SubmitAreaForm()
    {
        if (isEditing)
        {
            await AreaService.UpdateAreaAsync(currentArea);
        }
        else
        {
            await AreaService.CreateAreaAsync(currentArea);
        }

        areas = await AreaService.GetAllAreasAsync();
        showCreateForm = false;
        isEditing = false;
        currentArea = new Area();
        StateHasChanged();
    }

    private void EditArea(Area area)
    {
        isEditing = true;
        showCreateForm = true;
        currentArea = new Area
        {
            Id = area.Id,
            Name = area.Name,
            MaxCapacity = area.MaxCapacity,
            Date = area.Date,
            TimeSlot = area.TimeSlot,
            Category = area.Category,
            MinAge = area.MinAge,
            EventId = area.EventId,
            Location = area.Location
        };
    }

    private async Task DeleteArea(int id)
    {
        await AreaService.DeleteAreaAsync(id);
        areas = await AreaService.GetAllAreasAsync();
        StateHasChanged();
    }
}
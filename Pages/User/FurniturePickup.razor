@page "/user/furniture-pickup"
@page "/furniture-pickup"
@using FlomiApp.Data.Models
@using Microsoft.AspNetCore.Components.Forms
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IFurniturePickupService FurniturePickupService
@inject Microsoft.AspNetCore.Identity.UserManager<ApplicationUser> UserManager

<PageTitle>Möbel Abholservice</PageTitle>

<div class="pickup-page">

    <!-- Hero -->
    <section class="pickup-hero">
        <div class="pickup-hero__content">
            <span class="pickup-hero__badge">Service</span>
            <h1>Möbel Abholservice</h1>
            <p>Melde deine Möbel zur Abholung an. Wir kommen zu dir!</p>
        </div>
    </section>

    @if (!isLoggedIn)
    {
        <div class="state-card state-card--info" style="margin-bottom:1rem">
            <div class="state-card__icon">💡</div>
            <div class="state-card__content">
                <h3>Nicht angemeldet</h3>
                <p>Du kannst das Formular auch ohne Konto ausfüllen. <a href="/Identity/Account/Login?returnUrl=/furniture-pickup">Melde dich an</a>, damit deine Kontaktdaten automatisch eingetragen werden.</p>
            </div>
        </div>
    }

    @if (availableEvents == null)
    {
        <div class="state-card state-card--info">
            <div class="state-card__icon">⏳</div>
            <div class="state-card__content">
                <h3>Wird geladen...</h3>
                <p>Bitte warte einen Moment.</p>
            </div>
        </div>
    }
    else if (!availableEvents.Any())
    {
        <div class="state-card state-card--info">
            <div class="state-card__icon">⏳</div>
            <div class="state-card__content">
                <h3>Daten werden geladen…</h3>
                <p>Der Möbel-Abholservice steht momentan für keinen Event zur Verfügung.</p>
            </div>
        </div>
    }
    else if (selectedEventId == null)
    {
        <div class="pickup-block">
            <div class="pickup-block__header">
                <h3>🎪 Für welchen Event möchtest du Möbel anmelden?</h3>
            </div>
            <div class="pickup-block__body">
                <div class="pickup-event-list">
                    @foreach (var ev in availableEvents)
                    {
                        <button class="pickup-event-card"
                                @onclick="() => SelectEvent(ev.Id)">
                            <span class="pickup-event-card__icon">🎪</span>
                            <span class="pickup-event-card__name">@ev.Name</span>
                            <span class="pickup-event-card__date">
                                @ev.Date.ToString("dd. MMMM yyyy",
                                    new System.Globalization.CultureInfo("de-CH"))
                            </span>
                            <span class="pickup-event-card__arrow">→</span>
                        </button>
                    }
                </div>
            </div>
        </div>
    }
    else if (activeSettings == null)
    {
        <div class="state-card state-card--error">
            <div class="state-card__icon">🔴</div>
            <div class="state-card__content">
                <h3>Für diesen Event nicht verfügbar</h3>
                <p>Der Möbel-Abholservice ist für den gewählten Event nicht aktiv.</p>
            </div>
            <button class="pickup-submit-btn"
                    style="max-width:220px; margin-top:.75rem"
                    @onclick="ResetEventSelection">
                ← Zurück
            </button>
        </div>
    }
    else if (submitted)
    {
        <div class="state-card state-card--success">
            <div class="state-card__icon">✅</div>
            <div class="state-card__content">
                <h3>Anfrage erfolgreich eingereicht!</h3>
                <p>Deine Auftragsnummer: <strong>#@createdOrderNumber</strong></p>
                <p>Wir melden uns sobald deine Anfrage bearbeitet wurde.</p>
            </div>
        </div>

        <button class="pickup-submit-btn"
                style="max-width:260px"
                @onclick="ResetForm">
            ＋ Neue Anfrage stellen
        </button>
    }
    else
    {
        <!-- Gewählter Event Banner -->
        <div class="pickup-selected-event">
            <span class="pickup-selected-event__label">Event:</span>
            <span class="pickup-selected-event__name">
                @availableEvents.First(e => e.Id == selectedEventId).Name
            </span>
            <button class="pickup-selected-event__change"
                    @onclick="ResetEventSelection">
                ✎ Ändern
            </button>
        </div>

        <!-- Formular -->
        <EditForm Model="model" OnValidSubmit="SubmitRequest">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <!-- ── Persönliche Daten ── -->
            <div class="pickup-block">
                <div class="pickup-block__header">
                    <h3>👤 Persönliche Daten</h3>
                </div>
                <div class="pickup-block__body">
                    <div class="pickup-grid pickup-grid--2">

                        <div class="pickup-field">
                            <label>Vorname</label>
                            <InputText @bind-Value="model.FirstName"
                                       class="form-control-modern"
                                       readonly="@isLoggedIn"
                                       placeholder="z.B. Max" />
                        </div>

                        <div class="pickup-field">
                            <label>Nachname</label>
                            <InputText @bind-Value="model.LastName"
                                       class="form-control-modern"
                                       readonly="@isLoggedIn"
                                       placeholder="z.B. Mustermann" />
                        </div>

                        <div class="pickup-field">
                            <label>E-Mail</label>
                            <InputText @bind-Value="model.Email"
                                       class="form-control-modern"
                                       readonly="@isLoggedIn"
                                       placeholder="z.B. max@beispiel.ch" />
                        </div>

                        <div class="pickup-field">
                            <label>Telefon</label>
                            <input type="text"
                                   class="form-control-modern"
                                   placeholder="z.B. +41 79 123 45 67"
                                   value="@model.PhoneNumber"
                                   @onchange="e => model.PhoneNumber = FlomiApp.Helpers.PhoneHelper.FormatSwissPhone(e.Value?.ToString()) ?? string.Empty" />
                        </div>

                    </div>
                </div>
            </div>

            <!-- ── Abholadresse ── -->
            <div class="pickup-block">
                <div class="pickup-block__header">
                    <h3>📍 Abholadresse</h3>
                </div>
                <div class="pickup-block__body">
                    <div class="pickup-grid pickup-grid--2">

                        <div class="pickup-field pickup-field--full">
                            <label>Strasse &amp; Hausnummer</label>
                            <InputText @bind-Value="model.Street"
                                       class="form-control-modern"
                                       placeholder="z.B. Musterstrasse 12" />
                        </div>

                        <div class="pickup-field">
                            <label>PLZ</label>
                            <InputText @bind-Value="model.PostalCode"
                                       class="form-control-modern"
                                       placeholder="z.B. 8000" />
                        </div>

                        <div class="pickup-field">
                            <label>Ort</label>
                            <InputText @bind-Value="model.City"
                                       class="form-control-modern"
                                       placeholder="z.B. Zürich" />
                        </div>

                    </div>
                </div>
            </div>

            <!-- ── Möbel-Details ── -->
            <div class="pickup-block">
                <div class="pickup-block__header">
                    <h3>🛋️ Möbel-Details</h3>
                </div>
                <div class="pickup-block__body">
                    <div class="pickup-grid pickup-grid--2">

                        <div class="pickup-field pickup-field--full">
                            <label>Beschreibung der Möbel</label>
                            <InputTextArea @bind-Value="model.Description"
                                           class="form-control-modern"
                                           rows="4"
                                           placeholder="z.B. 1 Stuhl, 2 Hocker, 1 Holztisch..." />
                        </div>

                        <div class="pickup-field">
                            <label>
                                Gewünschtes Abholdatum
                                @if (pickupDateMin != null && pickupDateMax != null)
                                {
                                    <span class="pickup-label-hint pickup-label-hint--block">
                                        (@DateTime.Parse(pickupDateMin).ToShortDateString()
                                        – @DateTime.Parse(pickupDateMax).ToShortDateString())
                                    </span>
                                }
                            </label>
                            <InputDate @bind-Value="model.PickupDate"
                                       @bind-Value:after="CheckDateCapacity"
                                       class="form-control-modern"
                                       min="@pickupDateMin"
                                       max="@pickupDateMax" />
                            @if (dateCapacityMessage != null)
                            {
                                <small class="@(dateIsFull ? "pickup-date-full" : "pickup-date-available")">
                                    @dateCapacityMessage
                                </small>
                            }
                        </div>

                        <!-- Bilder Upload -->
                        <div class="pickup-field pickup-field--full">
                            <label>
                                Fotos der Möbel
                                <span class="pickup-label-hint">(max. 5 Bilder, je max. 5 MB)</span>
                            </label>

                            <label class="pickup-file-label">
                                <span>📁 Bilder auswählen</span>
                                <InputFile OnChange="HandleImageUpload"
                                           multiple
                                           accept="image/*"
                                           class="pickup-file-input" />
                            </label>

                            @if (imageError != null)
                            {
                                <div class="state-card state-card--error" style="margin-top:.75rem">
                                    <div class="state-card__icon">⚠️</div>
                                    <div class="state-card__content">
                                        <p>@imageError</p>
                                    </div>
                                </div>
                            }

                            @if (uploadedImages.Count > 0)
                            {
                                <div class="pickup-image-preview">
                                    @foreach (var img in uploadedImages)
                                    {
                                        <div class="pickup-image-thumb">
                                            <img src="@img.PreviewUrl" alt="@img.FileName" />
                                            <button type="button"
                                                    class="pickup-image-remove"
                                                    @onclick="() => RemoveImage(img)">
                                                ✕
                                            </button>
                                            <span class="pickup-image-name">@img.FileName</span>
                                        </div>
                                    }
                                </div>
                            }
                        </div>

                    </div>
                </div>
            </div>

            <!-- ── ✅ NEU: Einverständnis Entsorgungsgebühren ── -->
            <div class="pickup-block pickup-block--consent">
                <div class="pickup-block__body">
                    <label class="pickup-consent">
                        <input type="checkbox"
                               class="pickup-consent__checkbox"
                               @bind="model.AcceptsDisposalFee" />
                        <span class="pickup-consent__text">
                            Ich bestätige, dass ich im Falle eines <strong>Nicht-Verkaufs</strong>
                            meiner Möbel die anfallenden
                            <strong>Entsorgungsgebühren selbst trage</strong>.
                            Der Pfadiflomi übernimmt keine Kosten für die Entsorgung
                            nicht verkaufter Gegenstände.
                        </span>
                    </label>

                    @if (showConsentError)
                    {
                        <div class="pickup-consent__error">
                            ⚠️ Bitte bestätige die Bedingungen, um fortzufahren.
                        </div>
                    }
                </div>
            </div>

            <!-- ── Submit ── -->
            <button type="submit"
                    class="pickup-submit-btn"
                    disabled="@(isSubmitting || dateIsFull)">
                @if (isSubmitting)
                {
                    <span>⏳ Wird eingereicht...</span>
                }
                else
                {
                    <span>📦 Abholung anmelden</span>
                }
            </button>

        </EditForm>
    }

</div>

@code {
    // ── Formular ──────────────────────────────────────────────────────────────
    private FurniturePickupRequest model       = new();
    private bool    submitted                  = false;
    private bool    isSubmitting               = false;
    private bool    showConsentError           = false;
    private bool    isLoggedIn                 = false;
    private int     createdOrderNumber         = 0;
    private string? imageError;

    // Profildaten separat gespeichert, damit ResetForm ein frisches Model bauen kann
    private string? _userId;
    private string  _firstName   = string.Empty;
    private string  _lastName    = string.Empty;
    private string  _email       = string.Empty;
    private string? _phoneNumber;
    private string? _pfadiname;

    private FurniturePickupRequest CreateFreshModel() => new FurniturePickupRequest
    {
        UserId      = _userId,
        FirstName   = _firstName,
        LastName    = _lastName,
        Email       = _email,
        PhoneNumber = _phoneNumber,
        Pfadiname   = _pfadiname,
    };

    // ── Event-Auswahl ─────────────────────────────────────────────────────────
    private List<Event>?             availableEvents = null;
    private int?                     selectedEventId = null;
    private FurniturePickupSettings? activeSettings  = null;

    // ── Settings ──────────────────────────────────────────────────────────────
    private string? pickupDateMin        = null;
    private string? pickupDateMax        = null;
    private string? dateCapacityMessage  = null;
    private bool    dateIsFull           = false;

    // ── Bild-Vorschau ─────────────────────────────────────────────────────────
    private class ImagePreview
    {
        public string FileName    { get; set; } = string.Empty;
        public string ContentType { get; set; } = string.Empty;
        public byte[] Data        { get; set; } = Array.Empty<byte>();
        public string PreviewUrl  { get; set; } = string.Empty;
    }

    private List<ImagePreview> uploadedImages = new();

    // ── Init ──────────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        var allEvents    = await FurniturePickupService.GetAvailableEventsAsync();
        var activeEvents = new List<Event>();

        foreach (var ev in allEvents)
        {
            var settings = await FurniturePickupService.GetSettingsByEventIdAsync(ev.Id);
            if (settings != null)
                activeEvents.Add(ev);
        }

        availableEvents = activeEvents;

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user      = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            isLoggedIn = true;
            var userId  = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value
                          ?? string.Empty;
            var appUser = await UserManager.FindByIdAsync(userId);

            if (appUser != null)
            {
                _userId      = userId;
                _firstName   = appUser.FirstName;
                _lastName    = appUser.LastName;
                _email       = appUser.Email ?? string.Empty;
                _phoneNumber = appUser.PhoneNumber;
                _pfadiname   = appUser.Pfadiname;
                model        = CreateFreshModel();
            }
        }
    }

    // ── Event auswählen ───────────────────────────────────────────────────────
    private async Task CheckDateCapacity()
    {
        dateCapacityMessage = null;
        dateIsFull          = false;
        if (activeSettings?.MaxPickupsPerDay == null || selectedEventId == 0) return;

        var count    = await FurniturePickupService.GetPickupCountForDateAsync(selectedEventId!.Value, model.PickupDate);
        var max      = activeSettings.MaxPickupsPerDay.Value;
        var freeSlots = max - count;

        if (freeSlots <= 0)
        {
            dateIsFull          = true;
            dateCapacityMessage = $"Dieser Tag ist bereits voll ({count}/{max} Abholungen). Bitte wähle einen anderen Tag.";
        }
        else
        {
            dateCapacityMessage = $"Noch {freeSlots} von {max} Plätzen frei für diesen Tag.";
        }
    }

    private async Task SelectEvent(int eventId)
    {
        selectedEventId     = eventId;
        dateCapacityMessage = null;
        dateIsFull          = false;
        activeSettings      = await FurniturePickupService.GetSettingsByEventIdAsync(eventId);

        if (activeSettings != null)
        {
            pickupDateMin = activeSettings.PickupDateFrom?.ToString("yyyy-MM-dd");
            pickupDateMax = activeSettings.PickupDateTo?.ToString("yyyy-MM-dd");

            var defaultDate = DateTime.Today.AddDays(7);

            if (activeSettings.PickupDateFrom.HasValue && defaultDate < activeSettings.PickupDateFrom.Value)
                defaultDate = activeSettings.PickupDateFrom.Value;

            if (activeSettings.PickupDateTo.HasValue && defaultDate > activeSettings.PickupDateTo.Value)
                defaultDate = activeSettings.PickupDateTo.Value;

            model.PickupDate = defaultDate;
            model.EventId    = eventId;

            await CheckDateCapacity();
        }
    }

    private void ResetEventSelection()
    {
        selectedEventId = null;
        activeSettings  = null;
        pickupDateMin   = null;
        pickupDateMax   = null;
    }

    // ── Bild Upload ───────────────────────────────────────────────────────────
    private static readonly HashSet<string> AllowedImageMimes =
        new(StringComparer.OrdinalIgnoreCase) { "image/jpeg", "image/png", "image/webp", "image/gif" };

    private async Task HandleImageUpload(InputFileChangeEventArgs e)
    {
        imageError = null;
        const int  maxImages    = 5;
        const long maxSizeBytes = 5 * 1024 * 1024;

        var newFiles = e.GetMultipleFiles(maxImages);

        if (uploadedImages.Count + newFiles.Count > maxImages)
        {
            imageError = $"Maximal {maxImages} Bilder erlaubt.";
            return;
        }

        foreach (var file in newFiles)
        {
            if (file.Size > maxSizeBytes)
            {
                imageError = $"'{file.Name}' ist zu gross (max. 5 MB).";
                continue;
            }

            if (!AllowedImageMimes.Contains(file.ContentType))
            {
                imageError = $"'{file.Name}' ist kein erlaubtes Bildformat (JPEG, PNG, WebP, GIF).";
                continue;
            }

            using var stream = file.OpenReadStream(maxSizeBytes);
            using var ms     = new MemoryStream();
            await stream.CopyToAsync(ms);
            var bytes = ms.ToArray();

            uploadedImages.Add(new ImagePreview
            {
                FileName    = file.Name,
                ContentType = file.ContentType,
                Data        = bytes,
                PreviewUrl  = $"data:{file.ContentType};base64,{Convert.ToBase64String(bytes)}"
            });
        }
    }

    private void RemoveImage(ImagePreview img) => uploadedImages.Remove(img);

    // ── Submit ────────────────────────────────────────────────────────────────
    private async Task SubmitRequest()
    {
        // ✅ Einverständnis prüfen
        if (!model.AcceptsDisposalFee)
        {
            showConsentError = true;
            return;
        }

        showConsentError = false;
        isSubmitting     = true;

        var images = uploadedImages
            .Select(i => (i.Data, i.ContentType, i.FileName))
            .ToList();

        var created        = await FurniturePickupService.CreateRequestAsync(model, images);
        createdOrderNumber = created.OrderNumber;
        submitted          = true;
        isSubmitting       = false;
    }

    // ── Reset ─────────────────────────────────────────────────────────────────
    private void ResetForm()
    {
        submitted        = false;
        uploadedImages   = new();
        imageError       = null;
        showConsentError = false;
        model            = CreateFreshModel(); // frisches Objekt, Id=0, kein EF-Tracking-Konflikt

        ResetEventSelection();
    }
}
@page "/user/register"
@using FlomiApp.Data.Models
@using Microsoft.AspNetCore.Identity
@inject IAreaService AreaService
@inject IAppointmentService AppointmentService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IJSRuntime JS
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Navigation

<PageTitle>Terminbuchung</PageTitle>

<div class="register-page">
    <section class="register-hero">
        <div class="register-hero__content">
            <span class="register-hero__badge">Anmeldung</span>
            <h1>Terminbuchung</h1>
            <p>
                Wähle ein Event, bestimme die Person und registriere dich für einen verfügbaren Bereich.
            </p>
        </div>
    </section>

    @if (events == null)
    {
        <div class="state-card state-card--info">
            <div class="state-card__icon">ℹ️</div>
            <div class="state-card__content">
                <h3>Events werden geladen</h3>
                <p>Bitte einen kleinen Moment Geduld.</p>
            </div>
        </div>
    }
    else if (!events.Any())
    {
        <div class="state-card state-card--empty">
            <div class="state-card__icon">📭</div>
            <div class="state-card__content">
                <h3>Keine Events verfügbar</h3>
                <p>Aktuell stehen keine aktiven Events zur Auswahl bereit.</p>
            </div>
        </div>
    }
    else
    {
        <section class="selection-panel">
            <div class="selection-card">
                <label for="event-select">Event auswählen</label>
                <select id="event-select" class="custom-select" value="@selectedEventId"
                        @onchange="OnEventChanged">
                    @foreach (var evt in events)
                    {
                        <option value="@evt.Id">@evt.Name (@evt.Date.ToShortDateString())</option>
                    }
                </select>
            </div>

            <div class="selection-card">
                <label for="person-select">Registrieren als</label>
                <select id="person-select" class="custom-select" value="@selectedMemberId"
                        @onchange="OnPersonChanged">
                    <option value="0">Ich selbst</option>
                    @foreach (var member in familyMembers)
                    {
                        <option value="@member.Id">
                            @member.FirstName @member.LastName (@member.Stufe)
                        </option>
                    }
                </select>
            </div>
        </section>

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="state-card state-card--success">
                <div class="state-card__icon">✅</div>
                <div class="state-card__content">
                    <h3>Registrierung erfolgreich</h3>
                    <p>@successMessage</p>
                </div>
            </div>
        }

        @if (selectedEvent != null)
        {
            <section class="event-summary">
                <div class="event-summary__topline">Ausgewähltes Event</div>
                <h2>@selectedEvent.Name</h2>
                <div class="event-summary__meta">
                    <span class="event-pill">📅 @selectedEvent.Date.ToShortDateString()</span>
                </div>
                <p>@selectedEvent.Description</p>
            </section>
        }

        @if (areas == null)
        {
            <div class="state-card state-card--info">
                <div class="state-card__icon">⏳</div>
                <div class="state-card__content">
                    <h3>Bereiche werden geladen</h3>
                    <p>Die verfügbaren Bereiche für das gewählte Event werden vorbereitet.</p>
                </div>
            </div>
        }
        else if (!areas.Any())
        {
            <div class="state-card state-card--empty">
                <div class="state-card__icon">🗂️</div>
                <div class="state-card__content">
                    <h3>Keine Bereiche verfügbar</h3>
                    <p>Für dieses Event sind derzeit keine Bereiche hinterlegt.</p>
                </div>
            </div>
        }
        else
        {
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="state-card state-card--error">
                    <div class="state-card__icon">⚠️</div>
                    <div class="state-card__content">
                        <h3>Aktion nicht möglich</h3>
                        <p>@errorMessage</p>
                    </div>
                </div>
            }

            @foreach (var group in areas
                .OrderBy(a => a.AreaTemplate?.AreaCategory?.SortOrder ?? 999)
                .ThenBy(a => a.AreaTemplate?.AreaCategory?.Name)
                .GroupBy(a => a.AreaTemplate?.AreaCategory?.Name ?? "Sonstiges"))
            {
                var categoryKey = group.Key;
                var isCollapsed = collapsedCategories.Contains(categoryKey);

                <section class="category-block @(isCollapsed ? "is-collapsed" : "")">
                    <div class="category-block__header"
                         @onclick="() => ToggleCategory(categoryKey)">
                        <h3>🎪 @group.Key</h3>
                        <div class="category-block__header-right">
                            <span class="category-block__count">@group.Count() Bereiche</span>
                            <span class="category-block__toggle-icon">▾</span>
                        </div>
                    </div>

                    <div class="category-block__body">
                        @foreach (var dateGroup in group
                            .OrderBy(a => a.Date)
                            .GroupBy(a => a.Date.ToShortDateString()))
                        {
                            <div class="date-subgroup">
                                <h4>📅 @GetGermanDayName(dateGroup.Key), @dateGroup.Key</h4>
                                <div class="area-grid">
                                    @foreach (var area in dateGroup)
                                    {
                                        <article class="area-card">
                                            <div class="area-card__body">
                                                <div class="area-card__header">
                                                    <h4>@area.AreaTemplate?.Name</h4>
                                                    <span class="area-category">
                                                        @(area.AreaTemplate?.AreaCategory?.Name ?? "–")
                                                    </span>
                                                </div>

                                                <div class="area-info-list">
                                                    <div class="area-info-item">
                                                        <span class="label">Datum</span>
                                                        <span class="value">@area.Date.ToShortDateString()</span>
                                                    </div>
                                                    <div class="area-info-item">
                                                        <span class="label">Zeit</span>
                                                        <span class="value">@area.TimeSlot</span>
                                                    </div>
                                                    <div class="area-info-item">
                                                        <span class="label">Belegt</span>
                                                        <span class="value">
                                                            <span class="capacity-chip">
                                                                @currentRegistrations[area.Id] / @area.MaxCapacity
                                                            </span>
                                                        </span>
                                                    </div>
                                                    @if ((area.AreaTemplate?.MinAge ?? 0) > 0)
                                                    {
                                                        <div class="area-info-item">
                                                            <span class="label">Mindestalter</span>
                                                            <span class="value">@area.AreaTemplate!.MinAge Jahre</span>
                                                        </div>
                                                    }
                                                    @if (!string.IsNullOrEmpty(area.AreaTemplate?.Location))
                                                    {
                                                        <div class="area-info-item">
                                                            <span class="label">Standort</span>
                                                            <span class="value">@area.AreaTemplate!.Location</span>
                                                        </div>
                                                    }
                                                </div>

                                                @* ── Register Button mit Loading ── *@
                                                @if (registeringAreaId == area.Id)
                                                {
                                                    <div class="btn-loading btn-loading--register">
                                                        <span class="btn-spinner btn-spinner--white"></span>
                                                        <span>Wird registriert...</span>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <button class="register-btn"
                                                            @onclick="() => OpenConfirmModal(area)"
                                                            disabled="@(!canRegister[area.Id] || registeringAreaId.HasValue)">
                                                        Jetzt registrieren
                                                    </button>
                                                }

                                                @if (!string.IsNullOrEmpty(GetRegistrationNote(area)))
                                                {
                                                    <p class="registration-note">
                                                        @GetRegistrationNote(area)
                                                    </p>
                                                }
                                            </div>
                                        </article>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </section>
            }
        }
    }
</div>

@* ── Bestätigungs-Modal ── *@
@if (confirmArea != null)
{
    <div class="reg-modal-backdrop" @onclick="CloseConfirmModal">
        <div class="reg-modal" @onclick:stopPropagation="true">
            <div class="reg-modal__header">
                <h3>📋 Anmeldung bestätigen</h3>
                <button class="reg-modal__close" @onclick="CloseConfirmModal">✕</button>
            </div>
            <div class="reg-modal__body">
                <div class="reg-modal__info">
                    <div class="reg-modal__info-row">
                        <span class="reg-modal__label">Bereich</span>
                        <span class="reg-modal__value"><strong>@confirmArea.AreaTemplate?.Name</strong></span>
                    </div>
                    <div class="reg-modal__info-row">
                        <span class="reg-modal__label">Datum</span>
                        <span class="reg-modal__value">@confirmArea.Date.ToString("dddd, dd.MM.yyyy", new System.Globalization.CultureInfo("de-CH"))</span>
                    </div>
                    <div class="reg-modal__info-row">
                        <span class="reg-modal__label">Zeit</span>
                        <span class="reg-modal__value">@confirmArea.TimeSlot</span>
                    </div>
                    @if (selectedMemberId > 0)
                    {
                        var member = familyMembers.FirstOrDefault(m => m.Id == selectedMemberId);
                        @if (member != null)
                        {
                            <div class="reg-modal__info-row">
                                <span class="reg-modal__label">Person</span>
                                <span class="reg-modal__value">@member.FirstName @member.LastName</span>
                            </div>
                        }
                    }
                </div>

                <div class="reg-modal__comment">
                    <label for="reg-comment">Kommentar <span class="reg-modal__optional">(optional)</span></label>
                    <textarea id="reg-comment"
                              class="reg-modal__textarea"
                              rows="3"
                              maxlength="500"
                              placeholder="z.B. «Komme mit eigenem Auto», «Bringe Helfer mit», ..."
                              @bind="confirmComment"></textarea>
                </div>
            </div>
            <div class="reg-modal__footer">
                <button class="register-btn" @onclick="ConfirmRegistration"
                        disabled="@registeringAreaId.HasValue">
                    @if (registeringAreaId.HasValue)
                    {
                        <span>⏳ Wird registriert...</span>
                    }
                    else
                    {
                        <span>✅ Jetzt registrieren</span>
                    }
                </button>
                <button class="reg-modal__cancel-btn" @onclick="CloseConfirmModal">
                    Abbrechen
                </button>
            </div>
        </div>
    </div>
}

@code {
    // ── State ─────────────────────────────────────────────────────────────────
    private List<Event>?         events               = null;
    private Event?               selectedEvent;
    private int                  selectedEventId;
    private List<Area>?          areas;
    private List<FamilyMember>   familyMembers        = new();
    private int                  selectedMemberId     = 0;
    private Dictionary<int, int> currentRegistrations = new();
    private Dictionary<int,bool> canRegister          = new();
    private string               userId               = string.Empty;
    private ApplicationUser?     currentUser;
    private int?                 selectedPersonAge;
    private string               errorMessage         = string.Empty;
    private string               successMessage       = string.Empty;
    private CancellationTokenSource? successMessageCts;
    private HashSet<string>      collapsedCategories  = new();

    // ── Loading State ─────────────────────────────────────────────────────────
    private int? registeringAreaId = null;

    // ── Bestätigungs-Modal ────────────────────────────────────────────────────
    private Area?   confirmArea    = null;
    private string  confirmComment = string.Empty;

    private void OpenConfirmModal(Area area)
    {
        confirmArea    = area;
        confirmComment = string.Empty;
    }

    private void CloseConfirmModal()
    {
        confirmArea    = null;
        confirmComment = string.Empty;
    }

    private async Task ConfirmRegistration()
    {
        if (confirmArea == null) return;
        var areaId  = confirmArea.Id;
        var comment = confirmComment;   // Kommentar sichern bevor Modal schliesst
        CloseConfirmModal();
        await RegisterAppointment(areaId, comment);
    }

    // ── Init ──────────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user      = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            userId        = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value
                            ?? string.Empty;
            currentUser   = await UserManager.GetUserAsync(user);
            familyMembers = await AppointmentService.GetFamilyMembersAsync(userId);
            UpdateSelectedPersonAge();

            events = (await AreaService.GetAllEventsAsync())
                .Where(e => e.IsActive)
                .OrderBy(e => e.Date)
                .ToList();

            if (events.Any())
            {
                selectedEventId = events[0].Id;
                selectedEvent   = events[0];
                await LoadAreasForSelectedEvent();
            }
        }
    }

    // ── Event-Wechsel ─────────────────────────────────────────────────────────
    private async Task OnEventChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var eventId))
        {
            selectedEventId = eventId;
            selectedEvent   = events?.FirstOrDefault(evt => evt.Id == selectedEventId);
            successMessage  = string.Empty;
            await LoadAreasForSelectedEvent();
            StateHasChanged();
        }
    }

    // ── Person-Wechsel ────────────────────────────────────────────────────────
    private async Task OnPersonChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var memberId))
        {
            selectedMemberId = memberId;
            UpdateSelectedPersonAge();
            successMessage = string.Empty;
            await LoadAreasForSelectedEvent();
            StateHasChanged();
        }
    }

    private void UpdateSelectedPersonAge()
    {
        if (selectedMemberId == 0)
        {
            selectedPersonAge = currentUser?.Birthday.HasValue == true
                ? CalculateAge(currentUser!.Birthday!.Value, DateTime.Today)
                : null;
            return;
        }

        var selectedMember = familyMembers.FirstOrDefault(m => m.Id == selectedMemberId);
        selectedPersonAge  = selectedMember != null
            ? CalculateAge(selectedMember.Birthday, DateTime.Today)
            : null;
    }

    // ── Bereiche laden ────────────────────────────────────────────────────────
    private async Task LoadAreasForSelectedEvent()
    {
        errorMessage = string.Empty;
        areas        = await AreaService.GetAreasByEventAsync(selectedEventId) ?? new List<Area>();

        currentRegistrations.Clear();
        canRegister.Clear();

        foreach (var area in areas)
        {
            currentRegistrations[area.Id] = await AreaService.GetCurrentRegistrationsAsync(area.Id);
            canRegister[area.Id]          = await AppointmentService.CanRegisterAsync(
                userId, area.Id,
                selectedMemberId == 0 ? null : selectedMemberId);
        }

        collapsedCategories = areas
            .Select(a => a.AreaTemplate?.AreaCategory?.Name ?? "Sonstiges")
            .ToHashSet();
    }

    // ── Registrierung mit Loading ─────────────────────────────────────────────
    private async Task RegisterAppointment(int areaId, string? comment = null)
    {
        registeringAreaId = areaId;
        StateHasChanged();

        try
        {
            await AppointmentService.RegisterForAppointmentAsync(
                userId, areaId,
                selectedMemberId == 0 ? null : selectedMemberId,
                comment);

            errorMessage = string.Empty;
            await LoadAreasForSelectedEvent();
            await JS.InvokeVoidAsync("scrollToTop");
            await ShowTemporarySuccessMessageAsync(
                "Du wurdest erfolgreich für den Bereich registriert.");
        }
        catch (Exception ex)
        {
            errorMessage   = ex.Message;
            successMessage = string.Empty;
            successMessageCts?.Cancel();
        }
        finally
        {
            registeringAreaId = null;
            StateHasChanged();
        }
    }

    private async Task ShowTemporarySuccessMessageAsync(string message)
    {
        successMessageCts?.Cancel();
        successMessageCts = new CancellationTokenSource();

        successMessage = message;
        StateHasChanged();

        try
        {
            await Task.Delay(3000, successMessageCts.Token);
            successMessage = string.Empty;
            StateHasChanged();
        }
        catch (TaskCanceledException) { }
    }

    // ── Kategorie ein-/ausklappen ─────────────────────────────────────────────
    private void ToggleCategory(string categoryKey)
    {
        if (collapsedCategories.Contains(categoryKey))
            collapsedCategories.Remove(categoryKey);
        else
            collapsedCategories.Add(categoryKey);
    }

    // ── Hinweis-Text pro Area-Karte ───────────────────────────────────────────
    private string GetRegistrationNote(Area area)
    {
        if (canRegister.TryGetValue(area.Id, out var can) && can)
            return string.Empty;

        var minAge = area.AreaTemplate?.MinAge ?? 0;
        if (minAge > 0 && selectedPersonAge.HasValue && selectedPersonAge.Value < minAge)
            return $"Mindestalter {minAge} Jahre erforderlich.";

        if (area.AreaTemplate?.AreaCategory?.Name == "Verkauf")
            return "Nur eine Verkauf-Registrierung ist möglich.";

        if (currentRegistrations.TryGetValue(area.Id, out var current) && current >= area.MaxCapacity)
            return "Bereich ist derzeit voll.";

        return "Registrierung aktuell nicht möglich.";
    }

    // ── Hilfsmethoden ─────────────────────────────────────────────────────────
    private int CalculateAge(DateTime birthDate, DateTime referenceDate)
    {
        var age = referenceDate.Year - birthDate.Year;
        if (referenceDate < birthDate.AddYears(age)) age--;
        return age;
    }

    private string GetGermanDayName(string dateString)
    {
        if (DateTime.TryParse(dateString, out var date))
        {
            var culture = new System.Globalization.CultureInfo("de-DE");
            return culture.DateTimeFormat.GetDayName(date.DayOfWeek);
        }
        return string.Empty;
    }
}
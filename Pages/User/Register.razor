@page "/user/register"
@using FlomiApp.Data.Models
@using Microsoft.AspNetCore.Identity
@inject IAreaService AreaService
@inject IAppointmentService AppointmentService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IJSRuntime JS
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Navigation

<PageTitle>Terminbuchung</PageTitle>

<div class="register-page">
    <section class="register-hero">
        <div class="register-hero__content">
            <span class="register-hero__badge">Anmeldung</span>
            <h1>Terminbuchung</h1>
            <p>
                Wähle ein Event, bestimme die Person und registriere dich für einen verfügbaren Bereich.
            </p>
        </div>
    </section>

    @if (events == null)
    {
        <div class="state-card state-card--info">
            <div class="state-card__icon">ℹ️</div>
            <div class="state-card__content">
                <h3>Events werden geladen</h3>
                <p>Bitte einen kleinen Moment Geduld.</p>
            </div>
        </div>
    }
    else if (!events.Any())
    {
        <div class="state-card state-card--empty">
            <div class="state-card__icon">📭</div>
            <div class="state-card__content">
                <h3>Keine Events verfügbar</h3>
                <p>Aktuell stehen keine aktiven Events zur Auswahl bereit.</p>
            </div>
        </div>
    }
    else
    {
        <section class="selection-panel">
            <div class="selection-card">
                <label for="event-select">Event auswählen</label>
                <select id="event-select" class="custom-select" value="@selectedEventId" @onchange="OnEventChanged">
                    @foreach (var evt in events)
                    {
                        <option value="@evt.Id">@evt.Name (@evt.Date.ToShortDateString())</option>
                    }
                </select>
            </div>

            <div class="selection-card">
                <label for="person-select">Registrieren als</label>
                <select id="person-select" class="custom-select" value="@selectedMemberId" @onchange="OnPersonChanged">
                    <option value="0">Ich selbst</option>
                    @foreach (var member in familyMembers)
                    {
                        <option value="@member.Id">@member.FirstName @member.LastName (@member.Stufe)</option>
                    }
                </select>
            </div>
        </section>

@if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="state-card state-card--success">
            <div class="state-card__icon">✅</div>
            <div class="state-card__content">
                <h3>Registrierung erfolgreich</h3>
                <p>@successMessage</p>
            </div>
        </div>
    }

    @if (selectedEvent != null)
        {
            <section class="event-summary">
                <div class="event-summary__topline">Ausgewähltes Event</div>
                <h2>@selectedEvent.Name</h2>
                <div class="event-summary__meta">
                    <span class="event-pill">📅 @selectedEvent.Date.ToShortDateString()</span>
                </div>
                <p>@selectedEvent.Description</p>
            </section>
        }

        @if (areas == null)
        {
            <div class="state-card state-card--info">
                <div class="state-card__icon">⏳</div>
                <div class="state-card__content">
                    <h3>Bereiche werden geladen</h3>
                    <p>Die verfügbaren Bereiche für das gewählte Event werden vorbereitet.</p>
                </div>
            </div>
        }
        else if (!areas.Any())
        {
            <div class="state-card state-card--empty">
                <div class="state-card__icon">🗂️</div>
                <div class="state-card__content">
                    <h3>Keine Bereiche verfügbar</h3>
                    <p>Für dieses Event sind derzeit keine Bereiche hinterlegt.</p>
                </div>
            </div>
        }
        else
        {
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="state-card state-card--error">
                    <div class="state-card__icon">⚠️</div>
                    <div class="state-card__content">
                        <h3>Aktion nicht möglich</h3>
                        <p>@errorMessage</p>
                    </div>
                </div>
            }

            @foreach (var group in areas.OrderBy(a => a.Category).GroupBy(a => a.Category))
            {
                <section class="category-block">
                    <div class="category-block__header">
                        <h3>@group.Key</h3>
                        <span class="category-block__count">@group.Count() Bereiche</span>
                    </div>

                    @foreach (var dateGroup in group.OrderBy(a => a.Date).GroupBy(a => a.Date.ToShortDateString()))
                    {
                        <div class="date-subgroup">
                            <h4>📅 @dateGroup.Key</h4>
                            <div class="area-grid">
                                @foreach (var area in dateGroup)
                                {
                                    <article class="area-card">
                                <div class="area-card__body">
                                    <div class="area-card__header">
                                        <h4>@area.Name</h4>
                                        <span class="area-category">@area.Category</span>
                                    </div>

                                    <div class="area-info-list">
                                        <div class="area-info-item">
                                            <span class="label">Datum</span>
                                            <span class="value">@area.Date.ToShortDateString()</span>
                                        </div>
                                        <div class="area-info-item">
                                            <span class="label">Zeit</span>
                                            <span class="value">@area.TimeSlot</span>
                                        </div>
                                        <div class="area-info-item">
                                            <span class="label">Belegt</span>
                                            <span class="value">
                                                <span class="capacity-chip">
                                                    @currentRegistrations[area.Id] / @area.MaxCapacity
                                                </span>
                                            </span>
                                        </div>
                                    </div>

                                    <button class="register-btn"
                                            @onclick="() => RegisterAppointment(area.Id)"
                                            disabled="@(!canRegister[area.Id])">
                                        Jetzt registrieren
                                    </button>

                                    @if (!string.IsNullOrEmpty(GetRegistrationNote(area)))
                                    {
                                        <p class="registration-note">@GetRegistrationNote(area)</p>
                                    }
                                </div>
                            </article>
                        }
                    </div>
                        </div>
                    }
                </section>
            }
        }
    }
</div>

@code {
    private List<Event> events = new();
    private Event? selectedEvent;
    private int selectedEventId;
    private List<Area>? areas;
    private List<FamilyMember> familyMembers = new();
    private int selectedMemberId = 0;
    private Dictionary<int, int> currentRegistrations = new();
    private Dictionary<int, bool> canRegister = new();
    private string userId = string.Empty;
    private ApplicationUser? currentUser;
    private int? selectedPersonAge;
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;
    private CancellationTokenSource? successMessageCts;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? string.Empty;
            currentUser = await UserManager.GetUserAsync(user);
            familyMembers = await AppointmentService.GetFamilyMembersAsync(userId);
            UpdateSelectedPersonAge();
            events = (await AreaService.GetAllEventsAsync()).Where(e => e.IsActive).OrderBy(e => e.Date).ToList();
            if (events.Any())
            {
                selectedEventId = events[0].Id;
                selectedEvent = events[0];
                await LoadAreasForSelectedEvent();
            }
        }
    }

    private async Task OnEventChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var eventId))
        {
            selectedEventId = eventId;
            selectedEvent = events.FirstOrDefault(evt => evt.Id == selectedEventId);
            successMessage = string.Empty;
            await LoadAreasForSelectedEvent();
            StateHasChanged();
        }
    }

    private void UpdateSelectedPersonAge()
    {
        if (selectedMemberId == 0)
        {
            selectedPersonAge = currentUser?.Birthday.HasValue == true
                ? CalculateAge(currentUser!.Birthday.Value, DateTime.Today)
                : null;
            return;
        }

        var selectedMember = familyMembers.FirstOrDefault(m => m.Id == selectedMemberId);
        selectedPersonAge = selectedMember != null
            ? CalculateAge(selectedMember.Birthday, DateTime.Today)
            : null;
    }

    private async Task LoadAreasForSelectedEvent()
    {
        errorMessage = string.Empty;
        areas = await AreaService.GetAreasByEventAsync(selectedEventId) ?? new List<Area>();

        currentRegistrations.Clear();
        canRegister.Clear();

        foreach (var area in areas)
        {
            currentRegistrations[area.Id] = await AreaService.GetCurrentRegistrationsAsync(area.Id);
            canRegister[area.Id] = await AppointmentService.CanRegisterAsync(userId, area.Id, selectedMemberId == 0 ? null : selectedMemberId);
        }
    }

    private async Task OnPersonChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var memberId))
        {
            selectedMemberId = memberId;
            UpdateSelectedPersonAge();
            successMessage = string.Empty;
            await LoadAreasForSelectedEvent();
            StateHasChanged();
        }
    }

    private async Task RegisterAppointment(int areaId)
    {
        try
        {
            await AppointmentService.RegisterForAppointmentAsync(userId, areaId, selectedMemberId == 0 ? null : selectedMemberId);
            errorMessage = string.Empty;
            await LoadAreasForSelectedEvent();
            await JS.InvokeVoidAsync("scrollToTop");
            await ShowTemporarySuccessMessageAsync("Du wurdest erfolgreich für den Bereich registriert.");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            successMessage = string.Empty;
            successMessageCts?.Cancel();
        }
    }

    private async Task ShowTemporarySuccessMessageAsync(string message)
    {
        successMessageCts?.Cancel();
        successMessageCts = new CancellationTokenSource();

        successMessage = message;
        StateHasChanged();

        try
        {
            await Task.Delay(3000, successMessageCts.Token);
            successMessage = string.Empty;
            StateHasChanged();
        }
        catch (TaskCanceledException)
        {
            // Ignore cancellation when a new message arrives or an error occurs.
        }
    }

    private string GetRegistrationNote(Area area)
    {
        if (canRegister.TryGetValue(area.Id, out var can) && can)
        {
            return string.Empty;
        }

        if (area.MinAge > 0 && selectedPersonAge.HasValue && selectedPersonAge.Value < area.MinAge)
        {
            return $"Mindestalter {area.MinAge} Jahre erforderlich.";
        }

        if (area.Category == AreaCategory.Verkauf)
        {
            return "Nur eine Verkauf-Registrierung ist möglich.";
        }

        if (currentRegistrations.TryGetValue(area.Id, out var current) && current >= area.MaxCapacity)
        {
            return "Bereich ist derzeit voll.";
        }

        return "Registrierung aktuell nicht möglich.";
    }

    private int CalculateAge(DateTime birthDate, DateTime referenceDate)
    {
        var age = referenceDate.Year - birthDate.Year;
        if (referenceDate < birthDate.AddYears(age))
        {
            age--;
        }

        return age;
    }
}
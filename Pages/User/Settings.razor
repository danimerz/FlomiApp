@page "/user/settings"
@using FlomiApp.Data.Models
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IAppointmentService AppointmentService

<PageTitle>Settings</PageTitle>

<div class="settings-page">
    <section class="settings-hero">
        <div class="settings-hero__content">
            <span class="settings-hero__badge">Einstellungen</span>
            <h1>Benutzereinstellungen</h1>
            <p>
                Verwalte deine persönlichen Daten, Familienmitglieder und dein Passwort zentral an einem Ort.
            </p>
        </div>
    </section>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="state-card state-card--error">
            <div class="state-card__icon">⚠️</div>
            <div class="state-card__content">
                <h3>Fehler</h3>
                <p>@errorMessage</p>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="state-card state-card--success">
            <div class="state-card__icon">✅</div>
            <div class="state-card__content">
                <h3>Erfolgreich</h3>
                <p>@successMessage</p>
            </div>
        </div>
    }

    <div class="settings-layout">
        <div class="settings-column">
            <section class="settings-card">
                <div class="settings-card__header">
                    <div>
                        <div class="settings-card__topline">Profil</div>
                        <h2>Persönliche Daten</h2>
                    </div>
                </div>

                <div class="settings-card__body">
                    <EditForm Model="user" OnValidSubmit="UpdateUser">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="validation-summary" />

                        <div class="form-grid">
                            <div class="form-group">
                                <label for="firstName">Vorname</label>
                                <InputText id="firstName" @bind-Value="user.FirstName" class="form-control-modern" />
                            </div>

                            <div class="form-group">
                                <label for="lastName">Nachname</label>
                                <InputText id="lastName" @bind-Value="user.LastName" class="form-control-modern" />
                            </div>

                            <div class="form-group">
                                <label for="pfadiname">Pfadiname</label>
                                <InputText id="pfadiname" @bind-Value="user.Pfadiname" class="form-control-modern" />
                            </div>

                            <div class="form-group">
                                <label for="stufe">Stufe</label>
                                <InputSelect id="stufe" @bind-Value="user.Stufe" class="form-control-modern">
                                    <option value="">Select stage</option>
                                    <option value="Biber">Biber</option>
                                    <option value="Wolf">Wolf</option>
                                    <option value="Pfadi">Pfadi</option>
                                    <option value="Pio">Pio</option>
                                    <option value="Leiter">Leiter</option>
                                    <option value="Sonstiges">Sonstiges</option>
                                </InputSelect>
                            </div>

                            <div class="form-group">
                                <label for="birthday">Geburtstag</label>
                                <InputDate id="birthday" @bind-Value="user.Birthday" class="form-control-modern" />
                            </div>

                            <div class="form-group">
                                <label for="phoneNumber">Telefonnummer</label>
                                <InputText id="phoneNumber" @bind-Value="user.PhoneNumber" class="form-control-modern" placeholder="+41 41 750 06 49" />
                            </div>

                            <div class="form-group form-group--full">
                                <label for="email">Email</label>
                                <InputText id="email" @bind-Value="user.Email" class="form-control-modern" />
                            </div>
                        </div>

                        <div class="form-actions">
                            <button type="submit" class="primary-btn">Daten speichern</button>
                        </div>
                    </EditForm>
                </div>
            </section>

            <section class="settings-card">
                <div class="settings-card__header">
                    <div>
                        <div class="settings-card__topline">Familie</div>
                        <h2>Familienmitglieder</h2>
                    </div>
                </div>

                <div class="settings-card__body">
                    <EditForm Model="familyMemberForm" OnValidSubmit="SaveFamilyMember">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="validation-summary" />

                        <div class="form-grid">
                            <div class="form-group">
                                <label for="familyFirstName">Vorname</label>
                                <InputText id="familyFirstName" @bind-Value="familyMemberForm.FirstName" class="form-control-modern" />
                            </div>

                            <div class="form-group">
                                <label for="familyLastName">Nachname</label>
                                <InputText id="familyLastName" @bind-Value="familyMemberForm.LastName" class="form-control-modern" />
                            </div>

                            <div class="form-group">
                                <label for="familyPfadiname">Pfadiname</label>
                                <InputText id="familyPfadiname" @bind-Value="familyMemberForm.Pfadiname" class="form-control-modern" />
                            </div>

                            <div class="form-group">
                                <label for="familyStufe">Stufe</label>
                                <InputSelect id="familyStufe" @bind-Value="familyMemberForm.Stufe" class="form-control-modern">
                                    <option value="">Select stage</option>
                                    <option value="Biber">Biber</option>
                                    <option value="Wolf">Wolf</option>
                                    <option value="Pfadi">Pfadi</option>
                                    <option value="Pio">Pio</option>
                                    <option value="Leiter">Leiter</option>
                                    <option value="Sonstiges">Sonstiges</option>
                                </InputSelect>
                            </div>

                            <div class="form-group">
                                <label for="familyBirthday">Geburtstag</label>
                                <InputDate id="familyBirthday" @bind-Value="familyMemberForm.Birthday" class="form-control-modern" />
                            </div>
                        </div>

                        <div class="form-actions">
                            <button type="submit" class="secondary-btn">
                                @(isEditingFamilyMember ? "Familienmitglied speichern" : "Familienmitglied hinzufügen")
                            </button>
                            @if (isEditingFamilyMember)
                            {
                                <button type="button" class="secondary-btn" @onclick="CancelFamilyEdit">Abbrechen</button>
                            }
                        </div>
                    </EditForm>

                    @if (familyMembers.Any())
                    {
                        <div class="member-list">
                            @foreach (var member in familyMembers)
                            {
                                <article class="member-card">
                                    <div class="member-card__content">
                                        <div class="member-card__header">
                                            <h3>@member.FirstName @member.LastName</h3>
                                            <span class="member-stage">@member.Stufe</span>
                                        </div>

                                        <div class="member-info-list">
                                            <div class="member-info-item">
                                                <span class="label">Pfadiname</span>
                                                <span class="value">@member.Pfadiname</span>
                                            </div>
                                            <div class="member-info-item">
                                                <span class="label">Geburtstag</span>
                                                <span class="value">@member.Birthday.ToShortDateString()</span>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="member-card__actions">
                                        <button class="secondary-btn" @onclick="() => EditFamilyMember(member)">Bearbeiten</button>
                                        <button class="danger-btn" @onclick="() => RemoveFamilyMember(member.Id)">Löschen</button>
                                    </div>
                                </article>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="inline-empty-state">
                            <p>Noch keine Familienmitglieder hinterlegt.</p>
                        </div>
                    }
                </div>
            </section>
        </div>

        <div class="settings-column">
            <section class="settings-card">
                <div class="settings-card__header">
                    <div>
                        <div class="settings-card__topline">Sicherheit</div>
                        <h2>Passwort ändern</h2>
                    </div>
                </div>

                <div class="settings-card__body">
                    <EditForm Model="passwordModel" OnValidSubmit="ChangePassword">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="validation-summary" />

                        <div class="form-grid form-grid--single">
                            <div class="form-group">
                                <label for="currentPassword">Aktuelles Passwort</label>
                                <InputText id="currentPassword" @bind-Value="passwordModel.CurrentPassword" type="password" class="form-control-modern" />
                            </div>

                            <div class="form-group">
                                <label for="newPassword">Neues Passwort</label>
                                <InputText id="newPassword" @bind-Value="passwordModel.NewPassword" type="password" class="form-control-modern" />
                            </div>

                            <div class="form-group">
                                <label for="confirmPassword">Neues Passwort bestätigen</label>
                                <InputText id="confirmPassword" @bind-Value="passwordModel.ConfirmPassword" type="password" class="form-control-modern" />
                            </div>
                        </div>

                        <div class="form-actions">
                            <button type="submit" class="primary-btn">Passwort ändern</button>
                        </div>
                    </EditForm>
                </div>
            </section>
        </div>
    </div>
</div>

@code {
    private ApplicationUser user = new();
    private PasswordChangeModel passwordModel = new();
    private FamilyMember familyMemberForm = new();
    private bool isEditingFamilyMember = false;
    private List<FamilyMember> familyMembers = new();
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var currentUser = authState.User;
        if (currentUser.Identity?.IsAuthenticated == true)
        {
            var foundUser = await UserManager.GetUserAsync(currentUser);
            if (foundUser is not null)
            {
                user = foundUser;
                familyMembers = await AppointmentService.GetFamilyMembersAsync(user.Id);
            }
        }
    }

    private async Task SaveFamilyMember()
    {
        if (user.Id == null)
        {
            errorMessage = "User not found.";
            return;
        }

        if (isEditingFamilyMember && familyMemberForm.Id != 0)
        {
            await AppointmentService.UpdateFamilyMemberAsync(familyMemberForm.Id, user.Id, familyMemberForm);
            successMessage = "Familienmitglied aktualisiert.";
        }
        else
        {
            await AppointmentService.AddFamilyMemberAsync(user.Id, familyMemberForm);
            successMessage = "Familienmitglied hinzugefügt.";
        }

        familyMembers = await AppointmentService.GetFamilyMembersAsync(user.Id);
        familyMemberForm = new FamilyMember();
        isEditingFamilyMember = false;
        errorMessage = string.Empty;
    }

    private void EditFamilyMember(FamilyMember member)
    {
        familyMemberForm = new FamilyMember
        {
            Id = member.Id,
            UserId = member.UserId,
            FirstName = member.FirstName,
            LastName = member.LastName,
            Pfadiname = member.Pfadiname,
            Stufe = member.Stufe,
            Birthday = member.Birthday
        };
        isEditingFamilyMember = true;
        successMessage = string.Empty;
        errorMessage = string.Empty;
    }

    private void CancelFamilyEdit()
    {
        familyMemberForm = new FamilyMember();
        isEditingFamilyMember = false;
        errorMessage = string.Empty;
        successMessage = string.Empty;
    }

    private async Task RemoveFamilyMember(int familyMemberId)
    {
        if (user.Id == null)
        {
            errorMessage = "User not found.";
            return;
        }

        await AppointmentService.DeleteFamilyMemberAsync(familyMemberId, user.Id);
        familyMembers = await AppointmentService.GetFamilyMembersAsync(user.Id);
    }

    private async Task UpdateUser()
    {
        try
        {
            var result = await UserManager.UpdateAsync(user);
            if (result.Succeeded)
            {
                successMessage = "Data updated successfully.";
                errorMessage = string.Empty;
            }
            else
            {
                errorMessage = string.Join(" ", result.Errors.Select(e => e.Description));
            }
        }
        catch
        {
            errorMessage = "Failed to update data.";
            successMessage = string.Empty;
        }
    }

    private async Task ChangePassword()
    {
        errorMessage = string.Empty;
        successMessage = string.Empty;

        if (passwordModel.NewPassword != passwordModel.ConfirmPassword)
        {
            errorMessage = "Passwords do not match.";
            return;
        }

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var currentUser = authState.User;
        var foundUser = await UserManager.GetUserAsync(currentUser);

        if (foundUser == null)
        {
            errorMessage = "User not found.";
            return;
        }

        var result = await UserManager.ChangePasswordAsync(foundUser, passwordModel.CurrentPassword, passwordModel.NewPassword);
        if (result.Succeeded)
        {
            successMessage = "Password changed successfully.";
            passwordModel = new PasswordChangeModel();
        }
        else
        {
            errorMessage = string.Join(" ", result.Errors.Select(e => e.Description));
        }
    }

    private class PasswordChangeModel
    {
        public string CurrentPassword { get; set; } = string.Empty;
        public string NewPassword { get; set; } = string.Empty;
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
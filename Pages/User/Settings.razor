@page "/user/settings"
@using FlomiApp.Data.Models
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IAppointmentService AppointmentService

<PageTitle>Settings</PageTitle>

<h3>User Settings</h3>

<div class="row">
    <div class="col-md-6">
        <h4>Update Email</h4>
        <EditForm Model="user" OnValidSubmit="UpdateUser">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="form-group">
                <label for="firstName">Vorname</label>
                <InputText id="firstName" @bind-Value="user.FirstName" class="form-control" />
            </div>
            <div class="form-group">
                <label for="lastName">Nachname</label>
                <InputText id="lastName" @bind-Value="user.LastName" class="form-control" />
            </div>
            <div class="form-group">
                <label for="pfadiname">Pfadiname</label>
                <InputText id="pfadiname" @bind-Value="user.Pfadiname" class="form-control" />
            </div>
            <div class="form-group">
                <label for="stufe">Stufe</label>
                <InputSelect id="stufe" @bind-Value="user.Stufe" class="form-control">
                    <option value="">Select stage</option>
                    <option value="Biber">Biber</option>
                    <option value="Wolf">Wolf</option>
                    <option value="Pfadi">Pfadi</option>
                    <option value="Pio">Pio</option>
                    <option value="Leiter">Leiter</option>
                    <option value="Sonstiges">Sonstiges</option>
                </InputSelect>
            </div>
            <div class="form-group">
                <label for="birthday">Geburtstag</label>
                <InputDate id="birthday" @bind-Value="user.Birthday" class="form-control" />
            </div>
            <div class="form-group">
                <label for="phoneNumber">Telefonnummer</label>
                <InputText id="phoneNumber" @bind-Value="user.PhoneNumber" class="form-control" placeholder="+41 41 750 06 49" />
            </div>
            <div class="form-group">
                <label for="email">Email</label>
                <InputText id="email" @bind-Value="user.Email" class="form-control" />
            </div>

            <button type="submit" class="btn btn-primary">Update Email</button>
        </EditForm>

        <div class="mt-5">
            <h4>Familienmitglieder</h4>
            <EditForm Model="newFamilyMember" OnValidSubmit="AddFamilyMember">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="form-group">
                    <label for="familyFirstName">Vorname</label>
                    <InputText id="familyFirstName" @bind-Value="newFamilyMember.FirstName" class="form-control" />
                </div>
                <div class="form-group">
                    <label for="familyLastName">Nachname</label>
                    <InputText id="familyLastName" @bind-Value="newFamilyMember.LastName" class="form-control" />
                </div>
                <div class="form-group">
                    <label for="familyPfadiname">Pfadiname</label>
                    <InputText id="familyPfadiname" @bind-Value="newFamilyMember.Pfadiname" class="form-control" />
                </div>
                <div class="form-group">
                    <label for="familyStufe">Stufe</label>
                    <InputSelect id="familyStufe" @bind-Value="newFamilyMember.Stufe" class="form-control">
                        <option value="">Select stage</option>
                        <option value="Biber">Biber</option>
                        <option value="Wolf">Wolf</option>
                        <option value="Pfadi">Pfadi</option>
                        <option value="Pio">Pio</option>
                        <option value="Leiter">Leiter</option>
                        <option value="Sonstiges">Sonstiges</option>
                    </InputSelect>
                </div>
                <div class="form-group">
                    <label for="familyBirthday">Geburtstag</label>
                    <InputDate id="familyBirthday" @bind-Value="newFamilyMember.Birthday" class="form-control" />
                </div>
                <button type="submit" class="btn btn-secondary">Familienmitglied hinzufügen</button>
            </EditForm>

            @if (familyMembers.Any())
            {
                <table class="table mt-4">
                    <thead>
                        <tr>
                            <th>Vorname</th>
                            <th>Nachname</th>
                            <th>Pfadiname</th>
                            <th>Stufe</th>
                            <th>Geburtstag</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var member in familyMembers)
                        {
                            <tr>
                                <td>@member.FirstName</td>
                                <td>@member.LastName</td>
                                <td>@member.Pfadiname</td>
                                <td>@member.Stufe</td>
                                <td>@member.Birthday.ToShortDateString()</td>
                                <td><button class="btn btn-danger btn-sm" @onclick="() => RemoveFamilyMember(member.Id)">Löschen</button></td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>

    <div class="col-md-6">
        <h4>Change Password</h4>
        <EditForm Model="passwordModel" OnValidSubmit="ChangePassword">
            <DataAnnotationsValidator />
            <ValidationSummary />

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger">@errorMessage</div>
            }

            @if (!string.IsNullOrEmpty(successMessage))
            {
                <div class="alert alert-success">@successMessage</div>
            }

            <div class="form-group">
                <label for="currentPassword">Current Password</label>
                <InputText id="currentPassword" @bind-Value="passwordModel.CurrentPassword" type="password" class="form-control" />
            </div>

            <div class="form-group">
                <label for="newPassword">New Password</label>
                <InputText id="newPassword" @bind-Value="passwordModel.NewPassword" type="password" class="form-control" />
            </div>

            <div class="form-group">
                <label for="confirmPassword">Confirm New Password</label>
                <InputText id="confirmPassword" @bind-Value="passwordModel.ConfirmPassword" type="password" class="form-control" />
            </div>

            <button type="submit" class="btn btn-primary">Change Password</button>
        </EditForm>
    </div>
</div>

@code {
    private ApplicationUser user = new();
    private PasswordChangeModel passwordModel = new();
    private FamilyMember newFamilyMember = new();
    private List<FamilyMember> familyMembers = new();
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var currentUser = authState.User;
        if (currentUser.Identity?.IsAuthenticated == true)
        {
            var foundUser = await UserManager.GetUserAsync(currentUser);
            if (foundUser is not null)
            {
                user = foundUser;
                familyMembers = await AppointmentService.GetFamilyMembersAsync(user.Id);
            }
        }
    }

    private async Task AddFamilyMember()
    {
        if (user.Id == null)
        {
            errorMessage = "User not found.";
            return;
        }

        await AppointmentService.AddFamilyMemberAsync(user.Id, newFamilyMember);
        familyMembers = await AppointmentService.GetFamilyMembersAsync(user.Id);
        newFamilyMember = new FamilyMember();
        successMessage = "Familienmitglied hinzugefügt.";
        errorMessage = string.Empty;
    }

    private async Task RemoveFamilyMember(int familyMemberId)
    {
        if (user.Id == null)
        {
            errorMessage = "User not found.";
            return;
        }

        await AppointmentService.DeleteFamilyMemberAsync(familyMemberId, user.Id);
        familyMembers = await AppointmentService.GetFamilyMembersAsync(user.Id);
    }

    private async Task UpdateUser()
    {
        try
        {
            var result = await UserManager.UpdateAsync(user);
            if (result.Succeeded)
            {
                successMessage = "Email updated successfully.";
                errorMessage = string.Empty;
            }
            else
            {
                errorMessage = string.Join(" ", result.Errors.Select(e => e.Description));
            }
        }
        catch
        {
            errorMessage = "Failed to update email.";
            successMessage = string.Empty;
        }
    }

    private async Task ChangePassword()
    {
        errorMessage = string.Empty;
        successMessage = string.Empty;

        if (passwordModel.NewPassword != passwordModel.ConfirmPassword)
        {
            errorMessage = "Passwords do not match.";
            return;
        }

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var currentUser = authState.User;
        var foundUser = await UserManager.GetUserAsync(currentUser);

        if (foundUser == null)
        {
            errorMessage = "User not found.";
            return;
        }

        var result = await UserManager.ChangePasswordAsync(foundUser, passwordModel.CurrentPassword, passwordModel.NewPassword);
        if (result.Succeeded)
        {
            successMessage = "Password changed successfully.";
            passwordModel = new PasswordChangeModel();
        }
        else
        {
            errorMessage = string.Join(" ", result.Errors.Select(e => e.Description));
        }
    }

    private class PasswordChangeModel
    {
        public string CurrentPassword { get; set; } = string.Empty;
        public string NewPassword { get; set; } = string.Empty;
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
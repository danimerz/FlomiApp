    // ── ICS Download ──────────────────────────────────────────────────────────
    private async Task DownloadIcs(Appointment appointment)
    {
        var icsContent = BuildIcsContent(appointment);
        var bytes      = Encoding.UTF8.GetBytes(icsContent);
        var base64     = Convert.ToBase64String(bytes);
        var fileName   = $"Termin_{appointment.Area.AreaTemplate?.Name}_{appointment.Area.Date:yyyyMMdd}.ics";

        await JS.InvokeVoidAsync("downloadFile", fileName, "text/calendar", base64);
    }

    private string BuildIcsContent(Appointment appointment)
    {
        var timeSlot = appointment.UseAlternativeSlot && !string.IsNullOrEmpty(appointment.Area?.AlternativeTimeSlot)
            ? appointment.Area!.AlternativeTimeSlot!
            : appointment.Area?.TimeSlot ?? string.Empty;
        var (startTime, endTime) = ParseTimeSlot(timeSlot, appointment.Area?.Date ?? DateTime.Today);

        var now     = DateTime.UtcNow.ToString("yyyyMMddTHHmmssZ");
        var dtStart = startTime.ToString("yyyyMMddTHHmmssZ");
        var dtEnd   = endTime.ToString("yyyyMMddTHHmmssZ");

        var personName = appointment.FamilyMember != null
            ? $"{appointment.FamilyMember.FirstName} {appointment.FamilyMember.LastName}"
            : $"{appointment.User.FirstName} {appointment.User.LastName}";

        var sb = new StringBuilder();
        sb.AppendLine("BEGIN:VCALENDAR");
        sb.AppendLine("VERSION:2.0");
        sb.AppendLine("PRODID:-//FlomiApp//Terminbuchung//DE");
        sb.AppendLine("CALSCALE:GREGORIAN");
        sb.AppendLine("METHOD:PUBLISH");
        sb.AppendLine("BEGIN:VEVENT");
        sb.AppendLine($"UID:{appointment.Id}-{appointment.Area.Id}@flomiapp");
        sb.AppendLine($"DTSTAMP:{now}");
        sb.AppendLine($"DTSTART:{dtStart}");
        sb.AppendLine($"DTEND:{dtEnd}");
        sb.AppendLine($"SUMMARY:{appointment.Area.Event?.Name} – {appointment.Area.AreaTemplate?.Name}");
        sb.AppendLine($"DESCRIPTION:Bereich: {appointment.Area.AreaTemplate?.Name}\\nPerson: {personName}");
        sb.AppendLine($"LOCATION:{appointment.Area.AreaTemplate?.Location}");
        sb.AppendLine("STATUS:CONFIRMED");
        sb.AppendLine("END:VEVENT");
        sb.AppendLine("END:VCALENDAR");

        return sb.ToString();
    }

    private (DateTime start, DateTime end) ParseTimeSlot(string timeSlot, DateTime date)
    {
        try
        {
            var normalized = timeSlot.Replace(":", "").Trim();
            var parts      = normalized.Split('-');

            if (parts.Length == 2
                && int.TryParse(parts[0], out var startRaw)
                && int.TryParse(parts[1], out var endRaw))
            {
                var startHour = startRaw / 100;
                var startMin  = startRaw % 100;
                var endHour   = endRaw  / 100;
                var endMin    = endRaw  % 100;

                var start = new DateTime(date.Year, date.Month, date.Day,
                                startHour, startMin, 0, DateTimeKind.Local)
                            .ToUniversalTime();

                var end = new DateTime(date.Year, date.Month, date.Day,
                                endHour, endMin, 0, DateTimeKind.Local)
                          .ToUniversalTime();

                return (start, end);
            }
        }
        catch { }

        var fallbackStart = date.Date.ToUniversalTime();
        var fallbackEnd   = date.Date.AddHours(8).ToUniversalTime();
        return (fallbackStart, fallbackEnd);
    }

    private string StatusLabel(PickupRequestStatus s) => s switch
    {
        PickupRequestStatus.Pending  => "⏳ Ausstehend",
        PickupRequestStatus.Accepted => "✅ Akzeptiert",
        PickupRequestStatus.Rejected => "❌ Abgelehnt",
        PickupRequestStatus.Deleted  => "🗑️ Gelöscht",
        _                            => s.ToString()
    };

    private string Truncate(string? text, int maxLength = 20)
    {
        if (string.IsNullOrEmpty(text)) return string.Empty;
        return text.Length <= maxLength ? text : text[..maxLength] + "...";
    }

    // ── Einsatz-Übersicht per Mail ────────────────────────────────────────────
    private async Task SendOverviewMailAsync()
    {
        if (sendingMail || currentUser == null) return;

        sendingMail = true;
        StateHasChanged();

        var items = FilteredAppointments
            .Where(a => a.Status == AppointmentStatus.Registered)
            .OrderBy(a => a.Area?.Date)
            .Select(a => new AppointmentSummaryItem
            {
                EventName = a.Area?.Event?.Name ?? "–",
                AreaName  = a.Area?.AreaTemplate?.Name ?? "–",
                Date      = a.Area?.Date ?? DateTime.MinValue,
                TimeSlot  = a.UseAlternativeSlot && !string.IsNullOrEmpty(a.Area?.AlternativeTimeSlot)
                                ? a.Area!.AlternativeTimeSlot!
                                : a.Area?.TimeSlot ?? "–",
                Category  = a.Area?.AreaTemplate?.AreaCategory?.Name ?? string.Empty,
                Location  = a.Area?.AreaTemplate?.Location,
                ForPerson = a.FamilyMember != null
                                ? $"{a.FamilyMember.FirstName} {a.FamilyMember.LastName}"
                                : null
            })
            .ToList();

        var toEmail = currentUser.Email ?? string.Empty;
        var toName  = $"{currentUser.FirstName} {currentUser.LastName}".Trim();

        MailQueue.Enqueue(m => m.SendAppointmentSummaryAsync(toEmail, toName, items));

        sendingMail = false;
        mailSent    = true;
        StateHasChanged();

        await Task.Delay(2500);
        mailSent = false;
        StateHasChanged();
    }


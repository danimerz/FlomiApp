@page "/user/dashboard"
@using FlomiApp.Data.Models
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IAppointmentService AppointmentService

<PageTitle>Dashboard</PageTitle>

<h3>Deine Anmeldungen</h3>

@if (appointments == null)
{
    <p>Loading...</p>
}
else if (!appointments.Any())
{
    <p>Keine Anmeldungen gefunden.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Person</th>
                <th>Bereich</th>
                <th>Event</th>
                <th>Datum</th>
                <th>Zeit</th>
                <th>Status</th>
                <th>Aktionen</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var appointment in appointments)
            {
                <tr>
                    <td>@(appointment.FamilyMember != null ? $"{appointment.FamilyMember.FirstName} {appointment.FamilyMember.LastName}" : $"{appointment.User.FirstName} {appointment.User.LastName}")</td>
                    <td>@appointment.Area.Name</td>
                    <td>@appointment.Area.Event?.Name</td>
                    <td>@appointment.Area.Date.ToShortDateString()</td>
                    <td>@appointment.Area.TimeSlot</td>
                    <td>@appointment.Status</td>
                    <td>
                        @if (appointment.Status == AppointmentStatus.Registered)
                        {
                            <button class="btn btn-danger" @onclick="() => CancelAppointment(appointment.Id)">Absagen</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Appointment> appointments = new();
    private string userId = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? string.Empty;
            appointments = await AppointmentService.GetUserAppointmentsAsync(userId);
        }
    }

    private async Task CancelAppointment(int appointmentId)
    {
        await AppointmentService.CancelAppointmentAsync(appointmentId, userId);
        appointments = await AppointmentService.GetUserAppointmentsAsync(userId);
        StateHasChanged();
    }
}
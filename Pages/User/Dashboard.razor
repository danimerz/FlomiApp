@page "/user/dashboard"
@using FlomiApp.Data.Models
@using System.Text
@using Microsoft.AspNetCore.Identity
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IAppointmentService AppointmentService
@inject IJSRuntime JS
@inject IFurniturePickupService FurniturePickupService
@inject IVehicleService VehicleService
@inject IMailQueue MailQueue
@inject UserManager<ApplicationUser> UserManager
@using QRCoder

<PageTitle>Dashboard</PageTitle>

<div class="dashboard-page">
    <section class="dashboard-hero">
        <div class="dashboard-hero__content">
            <span class="dashboard-hero__badge">Dashboard</span>
            <h1>Deine Anmeldungen</h1>
            <p>
                Hier findest du alle aktuellen Registrierungen übersichtlich an einem Ort.
            </p>
        </div>
    </section>

    @if (appointments == null)
    {
        <div class="state-card state-card--info">
            <div class="state-card__icon">⏳</div>
            <div class="state-card__content">
                <h3>Anmeldungen werden geladen</h3>
                <p>Bitte warte einen kleinen Moment.</p>
            </div>
        </div>
    }
    else if (!appointments.Any() && !pickupRequests.Any())
    {
        <div class="state-card state-card--empty">
            <div class="state-card__icon">📭</div>
            <div class="state-card__content">
                <h3>Keine Anmeldungen gefunden</h3>
                <p>Aktuell sind noch keine Registrierungen vorhanden.</p>
            </div>
        </div>
    }
    else
    {
        <section class="appointments-section">

            <div class="appointments-section__header">
                <h2>Übersicht</h2>
                <div class="appointments-section__controls">
                    <span class="appointments-section__count">
                        @FilteredAppointments.Count Anmeldungen
                    </span>
                    <button class="ics-icon-btn dash-mail-btn"
                            title="@(mailSent ? "Mail wurde versendet ✅" : "Einsatz-Übersicht per Mail erhalten")"
                            @onclick="SendOverviewMailAsync"
                            disabled="@sendingMail">
                        @if (sendingMail)
                        {
                            <span class="btn-spinner btn-spinner--blue"></span>
                        }
                        else if (mailSent)
                        {
                            <span>✅</span>
                        }
                        else
                        {
                            <span>📧</span>
                        }
                    </button>
                    <span class="cal-view-toggle" title="Abgesagte anzeigen">
                        <span class="cal-view-toggle__icon">🚫</span>
                        <label class="toggle-switch">
                            <input type="checkbox" @bind="showCancelledAppointments" />
                            <span class="slider round"></span>
                        </label>
                    </span>
                    <span class="cal-view-toggle" title="Kalenderansicht">
                        <span class="cal-view-toggle__icon">📅</span>
                        <label class="toggle-switch">
                            <input type="checkbox"
                                   checked="@showCalendarView"
                                   @onchange="ToggleCalendarView" />
                            <span class="slider round"></span>
                        </label>
                    </span>
                </div>
            </div>

            @if (!showCalendarView)
            {
                @foreach (var eventKey in AllEventKeys)
                {
                var eventOpen = IsEventOpen(eventKey);

                var dateGroups = GroupedAppointments.ContainsKey(eventKey)
                    ? GroupedAppointments[eventKey]
                    : new Dictionary<DateTime, List<Appointment>>();

                var eventPickups = PickupsByEvent.ContainsKey(eventKey)
                    ? PickupsByEvent[eventKey]
                    : new List<FurniturePickupRequest>();

                var totalCount = dateGroups.Sum(d => d.Value.Count) + eventPickups.Count;

                <div class="group-event">
                    <button class="group-event__toggle"
                            @onclick="() => ToggleEvent(eventKey)">
                        <span class="group-event__icon">🎪</span>
                        <span class="group-event__name">@eventKey</span>
                        <span class="group-event__count">@totalCount Einträge</span>
                        <span class="group-chevron @(eventOpen ? "group-chevron--open" : "")">▾</span>
                    </button>

                    @if (eventOpen)
                    {
                        <div class="group-event__body">

                            @foreach (var dateGroup in dateGroups)
                            {
                                var dateKey  = dateGroup.Key;
                                var dateOpen = IsDateOpen(eventKey, dateKey);

                                <div class="group-date">
                                    <button class="group-date__toggle"
                                            @onclick="() => ToggleDate(eventKey, dateKey)">
                                        <span class="group-date__icon">📅</span>
                                        <span class="group-date__name">
                                            @dateKey.ToString("dddd, dd. MMMM yyyy",
                                                new System.Globalization.CultureInfo("de-CH"))
                                        </span>
                                        <span class="group-date__count">@dateGroup.Value.Count Einträge</span>
                                        <span class="group-chevron @(dateOpen ? "group-chevron--open" : "")">▾</span>
                                    </button>

                                    @if (dateOpen)
                                    {
                                        <div class="appointments-grid">
                                            @foreach (var appointment in dateGroup.Value)
                                            {
                                                <article class="appointment-card">
                                                    <div class="appointment-card__body">

                                                        <div class="appointment-card__header">
                                                            <div>
                                                                <div class="appointment-card__topline">Anmeldung</div>
                                                                <h3>@appointment.Area?.AreaTemplate?.Name</h3>
                                                            </div>
                                                            <div class="appointment-card__header-right">
                                                                <span class="status-badge">@appointment.Status</span>
                                                            </div>
                                                        </div>

                                                        <div class="appointment-info-list">
                                                            <div class="appointment-info-item">
                                                                <span class="label">Person</span>
                                                                <span class="value">
                                                                    @(appointment.FamilyMember != null
                                                                        ? $"{appointment.FamilyMember.FirstName} {appointment.FamilyMember.LastName}"
                                                                        : $"{appointment.User.FirstName} {appointment.User.LastName}")
                                                                </span>
                                                            </div>
                                                            <div class="appointment-info-item">
                                                                <span class="label">Zeit</span>
                                                                <span class="value">
                                                                    @(appointment.UseAlternativeSlot && !string.IsNullOrEmpty(appointment.Area?.AlternativeTimeSlot)
                                                                        ? appointment.Area!.AlternativeTimeSlot
                                                                        : appointment.Area?.TimeSlot)
                                                                    @if (appointment.UseAlternativeSlot)
                                                                    {
                                                                        <span style="font-size:.72rem;color:var(--color-info-text);font-weight:700;margin-left:.3rem">
                                                                            (Halber Tag)
                                                                        </span>
                                                                    }
                                                                </span>
                                                            </div>
                                                            <div class="appointment-info-item">
                                                                <span class="label">Ort</span>
                                                                <span class="value">@appointment.Area?.AreaTemplate?.Location</span>
                                                            </div>
                                                            @{ var va = VehicleForAppointment(appointment); }
                                                            @if (va != null)
                                                            {
                                                                <div class="appointment-info-item">
                                                                    <span class="label">Fahrzeug</span>
                                                                    <span class="value">🚗 @va.Assignment.Vehicle.OwnerName</span>
                                                                </div>
                                                            }
                                                            @if (appointment.Area?.Event?.CheckInEnabled == true
                                                                 && appointment.Area?.AreaTemplate?.AreaCategory?.Name == "Verkauf"
                                                                 && appointment.CheckedInAt == null)
                                                            {
                                                                <div class="appointment-qr">
                                                                    <div class="appointment-qr__label">🎫 Einlass-QR</div>
                                                                    <img src="@GetQrDataUrl(appointment.Id)"
                                                                         class="appointment-qr__img"
                                                                         alt="QR Check-in" />
                                                                    <small>Beim Einlass scannen lassen</small>
                                                                </div>
                                                            }
                                                            @if (appointment.CheckedInAt.HasValue)
                                                            {
                                                                <div class="appointment-info-item">
                                                                    <span class="label">✅ Eingecheckt</span>
                                                                    <span class="value">@appointment.CheckedInAt?.ToString("HH:mm") Uhr</span>
                                                                </div>
                                                            }
                                                            @if (appointment.CheckedOutAt.HasValue)
                                                            {
                                                                <div class="appointment-info-item">
                                                                    <span class="label">🏁 Ausgecheckt</span>
                                                                    <span class="value">@appointment.CheckedOutAt?.ToString("HH:mm") Uhr</span>
                                                                </div>
                                                            }
                                                            <div class="appointment-info-item">
                                                                <span class="label">Status</span>
                                                                <span class="value">
                                                                    <span class="status-pill">@appointment.Status</span>
                                                                </span>
                                                            </div>
                                                            @if (!string.IsNullOrEmpty(appointment.Comment))
                                                            {
                                                                <div class="appointment-info-item appointment-info-item--comment">
                                                                    <span class="label">Kommentar</span>
                                                                    <span class="value">@appointment.Comment</span>
                                                                </div>
                                                            }
                                                        </div>

                                                        <div class="appointment-actions">
                                                            @if (appointment.Status == AppointmentStatus.Registered)
                                                            {
                                                                @* ── Loading-Overlay für diese Karte ── *@
                                                                @if (cancellingId == appointment.Id)
                                                                {
                                                                    <div class="btn-loading">
                                                                        <span class="btn-spinner"></span>
                                                                        <span>Wird abgesagt...</span>
                                                                    </div>
                                                                }
                                                                else
                                                                {
                                                                    <button class="cancel-btn"
                                                                            disabled="@(cancellingId.HasValue)"
                                                                            @onclick="() => CancelAppointment(appointment.Id)">
                                                                        Absagen
                                                                    </button>
                                                                    <button class="ics-icon-btn"
                                                                            title="Zum Kalender hinzufügen"
                                                                            @onclick="() => DownloadIcs(appointment)">
                                                                        📅
                                                                    </button>
                                                                }
                                                            }
                                                        </div>

                                                    </div>
                                                </article>
                                            }
                                        </div>
                                    }
                                </div>
                            }

                            @if (eventPickups.Any())
                            {
                                <div class="group-date group-date--pickup">
                                    <button class="group-date__toggle group-date__toggle--pickup"
                                            @onclick="() => TogglePickupGroup(eventKey)">
                                        <span class="group-date__icon">🛋️</span>
                                        <span class="group-date__name">Möbel Abholungen</span>
                                        <span class="group-date__count">@eventPickups.Count Anfrage(n)</span>
                                        <span class="group-chevron group-chevron--dark @(IsPickupGroupOpen(eventKey) ? "group-chevron--open" : "")">▾</span>
                                    </button>

                                    @if (IsPickupGroupOpen(eventKey))
                                    {
                                        <div class="appointments-grid">
                                            @foreach (var req in eventPickups)
                                            {
                                                <article class="appointment-card appointment-card--pickup">
                                                    <div class="appointment-card__body">
                                                        <div class="appointment-card__header">
                                                            <div>
                                                                <div class="appointment-card__topline appointment-card__topline--pickup">Abholung</div>
                                                                <h3>Auftrag #@req.OrderNumber</h3>
                                                            </div>
                                                            <span class="status-badge status-badge--pickup">@StatusLabel(req.Status)</span>
                                                        </div>
                                                        <div class="appointment-info-list">
                                                            <div class="appointment-info-item">
                                                                <span class="label">Adresse</span>
                                                                <span class="value">@req.Street, @req.PostalCode @req.City</span>
                                                            </div>
                                                            <div class="appointment-info-item">
                                                                <span class="label">Was</span>
                                                                <span class="value" title="@req.Description">@Truncate(req.Description)</span>
                                                            </div>
                                                            <div class="appointment-info-item">
                                                                <span class="label">Abholdatum</span>
                                                                <span class="value">@req.PickupDate.ToShortDateString()</span>
                                                            </div>
                                                            <div class="appointment-info-item">
                                                                <span class="label">Eingereicht</span>
                                                                <span class="value">@req.CreatedAt.ToShortDateString()</span>
                                                            </div>
                                                            @if (!string.IsNullOrEmpty(req.AdminNote))
                                                            {
                                                                <div class="appointment-info-item">
                                                                    <span class="label">Notiz</span>
                                                                    <span class="value">@req.AdminNote</span>
                                                                </div>
                                                            }
                                                        </div>
                                                        @if (req.Status == PickupRequestStatus.Pending)
                                                        {
                                                            <div class="appointment-actions">
                                                                @if (deletingPickupId == req.Id)
                                                                {
                                                                    <div class="btn-loading">
                                                                        <span class="btn-spinner"></span>
                                                                        <span>Wird gelöscht...</span>
                                                                    </div>
                                                                }
                                                                else
                                                                {
                                                                    <button class="cancel-btn"
                                                                            disabled="@(deletingPickupId.HasValue)"
                                                                            @onclick="() => DeletePickupRequest(req.Id)">
                                                                        🗑️ Löschen
                                                                    </button>
                                                                }
                                                            </div>
                                                        }
                                                    </div>
                                                </article>
                                            }
                                        </div>
                                    }
                                </div>
                            }

                        </div>
                    }
                </div>
            }

                @if (UnassignedPickups.Any())
                {
                    <section class="appointments-section" style="margin-top:1.5rem">
                        <div class="appointments-section__header">
                            <h2>🛋️ Weitere Abholungen</h2>
                            <div class="appointments-section__controls">
                                <span class="appointments-section__count">@UnassignedPickups.Count Anfrage(n)</span>
                                <button class="pickup-collapse-btn" @onclick="ToggleUnassignedPickup">
                                    <span class="group-chevron group-chevron--dark @(unassignedPickupOpen ? "group-chevron--open" : "")">▾</span>
                                </button>
                            </div>
                        </div>
                        @if (unassignedPickupOpen)
                        {
                            <div class="appointments-grid">
                                @foreach (var req in UnassignedPickups)
                                {
                                    <article class="appointment-card appointment-card--pickup">
                                        <div class="appointment-card__body">
                                            <div class="appointment-card__header">
                                                <div>
                                                    <div class="appointment-card__topline appointment-card__topline--pickup">Abholung</div>
                                                    <h3>Auftrag #@req.OrderNumber</h3>
                                                </div>
                                                <span class="status-badge status-badge--pickup">@StatusLabel(req.Status)</span>
                                            </div>
                                            <div class="appointment-info-list">
                                                <div class="appointment-info-item">
                                                    <span class="label">Adresse</span>
                                                    <span class="value">@req.Street, @req.PostalCode @req.City</span>
                                                </div>
                                                <div class="appointment-info-item">
                                                    <span class="label">Abholdatum</span>
                                                    <span class="value">@req.PickupDate.ToShortDateString()</span>
                                                </div>
                                                <div class="appointment-info-item">
                                                    <span class="label">Eingereicht</span>
                                                    <span class="value">@req.CreatedAt.ToShortDateString()</span>
                                                </div>
                                                @if (!string.IsNullOrEmpty(req.AdminNote))
                                                {
                                                    <div class="appointment-info-item">
                                                        <span class="label">Notiz</span>
                                                        <span class="value">@req.AdminNote</span>
                                                    </div>
                                                }
                                            </div>
                                            @if (req.Status == PickupRequestStatus.Pending)
                                            {
                                                <div class="appointment-actions">
                                                    @if (deletingPickupId == req.Id)
                                                    {
                                                        <div class="btn-loading">
                                                            <span class="btn-spinner"></span>
                                                            <span>Wird gelöscht...</span>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <button class="cancel-btn"
                                                                disabled="@(deletingPickupId.HasValue)"
                                                                @onclick="() => DeletePickupRequest(req.Id)">
                                                            🗑️ Löschen
                                                        </button>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    </article>
                                }
                            </div>
                        }
                    </section>
                }
            }
            else
            {
                <!-- ── Kalenderansicht ── -->
                <div class="cal-nav">
                    <button class="cal-nav-btn" @onclick="CalPrev">‹</button>
                    <span class="cal-nav-title">
                        @(new DateTime(calYear, calMonth, 1)
                            .ToString("MMMM yyyy", new System.Globalization.CultureInfo("de-CH")))
                    </span>
                    <button class="cal-nav-btn" @onclick="CalNext">›</button>
                </div>

                <div class="cal-grid">
                    @foreach (var d in new[] { "Mo","Di","Mi","Do","Fr","Sa","So" })
                    {
                        <div class="cal-dow">@d</div>
                    }
                    @foreach (var cell in CalendarCells)
                    {
                        <div class="cal-cell @(cell.IsCurrentMonth ? "" : "cal-cell--other") @(cell.IsToday ? "cal-cell--today" : "")">
                            <span class="cal-cell__day">@cell.Date.Day</span>
                            @foreach (var apt in cell.Appointments)
                            {
                                <div class="cal-chip cal-chip--apt" title="@apt.Area?.AreaTemplate?.Name @apt.Area?.TimeSlot">
                                    @apt.Area?.AreaTemplate?.Name
                                </div>
                            }
                            @foreach (var req in cell.Pickups)
                            {
                                <div class="cal-chip cal-chip--pickup" title="Abholung #@req.OrderNumber">
                                    🛋️ #@req.OrderNumber
                                </div>
                            }
                        </div>
                    }
                </div>
            }

        </section>
    }


</div>

@code {
    private List<Appointment> appointments = new();
    private string userId = string.Empty;
    private bool showCancelledAppointments = false;
    private bool showCalendarView          = false;

    // ── Kalender ──────────────────────────────────────────────────────────────
    private int calMonth = DateTime.Today.Month;
    private int calYear  = DateTime.Today.Year;

    private record CalCell(
        DateTime Date, bool IsCurrentMonth, bool IsToday,
        List<Appointment> Appointments, List<FurniturePickupRequest> Pickups);

    private List<CalCell> CalendarCells
    {
        get
        {
            var first   = new DateTime(calYear, calMonth, 1);
            // Monday-based: 0=Mon..6=Sun
            var startOffset = ((int)first.DayOfWeek + 6) % 7;
            var cellStart   = first.AddDays(-startOffset);
            // always 6 weeks = 42 cells
            var cells = new List<CalCell>(42);
            var today = DateTime.Today;

            for (int i = 0; i < 42; i++)
            {
                var d = cellStart.AddDays(i);
                var apts = FilteredAppointments
                    .Where(a => a.Area?.Date.Date == d && a.Status != AppointmentStatus.Cancelled)
                    .ToList();
                var picks = pickupRequests
                    .Where(r => r.PickupDate.Date == d)
                    .ToList();
                cells.Add(new CalCell(d, d.Month == calMonth, d == today, apts, picks));
            }

            // trim trailing empty weeks
            while (cells.Count > 7 && cells.TakeLast(7).All(c => !c.Appointments.Any() && !c.Pickups.Any() && !c.IsCurrentMonth))
                cells.RemoveRange(cells.Count - 7, 7);

            return cells;
        }
    }

    private string GetQrDataUrl(int appointmentId)
    {
        using var gen   = new QRCodeGenerator();
        var data        = gen.CreateQrCode($"flomi-apt:{appointmentId}", QRCodeGenerator.ECCLevel.M);
        using var qr    = new PngByteQRCode(data);
        var bytes       = qr.GetGraphic(6);
        return $"data:image/png;base64,{Convert.ToBase64String(bytes)}";
    }

    private void CalPrev() { if (--calMonth < 1) { calMonth = 12; calYear--; } }
    private void CalNext() { if (++calMonth > 12) { calMonth = 1; calYear++; } }

    private void ToggleCalendarView()
    {
        showCalendarView = !showCalendarView;
        if (showCalendarView)
        {
            // Springe zum Monat des frühesten Termins
            var firstDate = FilteredAppointments
                .Where(a => a.Area?.Date != null)
                .Select(a => a.Area!.Date.Date)
                .Concat(pickupRequests.Select(r => r.PickupDate.Date))
                .Where(d => d >= DateTime.Today)
                .OrderBy(d => d)
                .FirstOrDefault();

            if (firstDate != default)
            {
                calMonth = firstDate.Month;
                calYear  = firstDate.Year;
            }
            else
            {
                calMonth = DateTime.Today.Month;
                calYear  = DateTime.Today.Year;
            }
        }
    }

    // ── Loading State ─────────────────────────────────────────────────────────
    private int? cancellingId     = null;
    private int? deletingPickupId = null;
    private bool sendingMail      = false;
    private bool mailSent         = false;
    private ApplicationUser? currentUser;

    // ── Vehicle Assignments ───────────────────────────────────────────────────
    private List<AssignmentDate> vehicleAssignments = new();

    private AssignmentDate? VehicleForAppointment(Appointment a)
    {
        var date    = a.Area?.Date.Date ?? DateTime.MinValue;
        var eventId = a.Area?.EventId ?? 0;
        return vehicleAssignments.FirstOrDefault(
            d => d.Date.Date == date && d.Assignment.EventId == eventId);
    }

    // ── Pickup ────────────────────────────────────────────────────────────────
    private List<FurniturePickupRequest> pickupRequests = new();
    private bool unassignedPickupOpen = true;

    private void ToggleUnassignedPickup() => unassignedPickupOpen = !unassignedPickupOpen;

    // ── Pickup-Gruppen Collapse ───────────────────────────────────────────────
    private HashSet<string> openPickupGroups = new();

    private bool IsPickupGroupOpen(string eventKey) =>
        openPickupGroups.Contains(eventKey);

    private void TogglePickupGroup(string eventKey)
    {
        if (!openPickupGroups.Remove(eventKey))
            openPickupGroups.Add(eventKey);
    }

    // ── Collapse-State ────────────────────────────────────────────────────────
    private HashSet<string> openEvents = new();
    private HashSet<string> openDates  = new();

    // ── Gefilterte & gruppierte Appointments ──────────────────────────────────
    private List<Appointment> FilteredAppointments =>
        showCancelledAppointments
            ? appointments
            : appointments.Where(a => a.Status != AppointmentStatus.Cancelled).ToList();

    private Dictionary<string, Dictionary<DateTime, List<Appointment>>> GroupedAppointments =>
        FilteredAppointments
            .GroupBy(a => a.Area.Event?.Name ?? "Unbekanntes Event")
            .OrderBy(g => g.Key)
            .ToDictionary(
                g => g.Key,
                g => g
                    .GroupBy(a => a.Area.Date.Date)
                    .OrderBy(d => d.Key)
                    .ToDictionary(
                        d => d.Key,
                        d => d.ToList()
                    )
            );

    private Dictionary<string, List<FurniturePickupRequest>> PickupsByEvent =>
        pickupRequests
            .Where(r => r.EventId.HasValue && r.Event != null)
            .GroupBy(r => r.Event!.Name)
            .ToDictionary(g => g.Key, g => g.ToList());

    private List<FurniturePickupRequest> UnassignedPickups =>
        pickupRequests
            .Where(r => !r.EventId.HasValue || r.Event == null)
            .ToList();

    private IEnumerable<string> AllEventKeys =>
        GroupedAppointments.Keys
            .Union(PickupsByEvent.Keys)
            .OrderBy(k => k);

    // ── Collapse-Logik ────────────────────────────────────────────────────────
    private bool IsEventOpen(string eventName) =>
        openEvents.Contains(eventName);

    private void ToggleEvent(string eventName)
    {
        if (!openEvents.Remove(eventName))
            openEvents.Add(eventName);
    }

    private string DateKey(string eventName, DateTime date) =>
        $"{eventName}|{date:yyyyMMdd}";

    private bool IsDateOpen(string eventName, DateTime date) =>
        openDates.Contains(DateKey(eventName, date));

    private void ToggleDate(string eventName, DateTime date)
    {
        var key = DateKey(eventName, date);
        if (!openDates.Remove(key))
            openDates.Add(key);
    }

    private void ExpandAll()
    {
        foreach (var eventGroup in GroupedAppointments)
            openEvents.Add(eventGroup.Key);

        foreach (var eventKey in PickupsByEvent.Keys)
            openEvents.Add(eventKey);
    }

    // ── Initialisierung ───────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user      = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value
                     ?? string.Empty;

            currentUser         = await UserManager.GetUserAsync(user);
            pickupRequests      = await FurniturePickupService.GetUserRequestsAsync(userId);
            vehicleAssignments  = await VehicleService.GetVehicleAssignmentsForUserAsync(userId);
            await LoadAppointments();
        }
    }


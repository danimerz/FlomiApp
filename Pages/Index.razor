@page "/"
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject INewsService NewsService
@using FlomiApp.Data.Models

<PageTitle>Willkommen</PageTitle>

<div class="home-page">
    <section class="home-hero">
        <div class="home-hero__content">
            <span class="home-hero__badge">Willkommen</span>
            <h1>@welcomeText</h1>
            <p class="home-hero__lead">
                Schön, dass du uns als Helfer/in, Sortierer/in oder Verkäufer/in unterstützen möchtest.
                Mit dieser App kannst du dich einfach für einen oder mehrere Einsätze anmelden.
            </p>

            <div class="home-hero__actions">
                @if (isAuthenticated)
                {
                    <a class="home-secondary-btn home-secondary-btn--primary" href="/user/register">Jetzt anmelden</a>
                    <a class="home-secondary-btn" href="/user/dashboard">Zum Dashboard</a>
                    <a class="home-secondary-btn" href="/user/settings">Meine Daten</a>
                }
                else
                {
                    <a class="home-secondary-btn" href="/Identity/Account/Login">Login</a>
                    <a class="home-secondary-btn" href="/Identity/Account/Register">Registrieren</a>

                }
            </div>
        </div>
    </section>
    <section class="home-card">
        <div class="home-card__header">
            <div>
                <div class="home-card__topline">Aktuell</div>
                <h2>News</h2>
            </div>
            <a href="/news" class="home-card__link">Alle News →</a>
        </div>

        <div class="home-card__body">
            @if (latestNews == null)
            {
                <p style="color:var(--color-text-placeholder)">Wird geladen...</p>
            }
            else if (latestNews.Count == 0)
            {
                <p style="color:var(--color-text-placeholder)">Aktuell keine Meldungen vorhanden.</p>
            }
            else
            {
                var n = latestNews[0];
                <div class="notice-box @(n.IsPinned ? "notice-box--pinned" : "")">
                    <div class="notice-box__date">
                        @if (n.IsPinned) { <span class="notice-box__pin">📌 Wichtig</span> }
                        📅 @n.CreatedAt.ToString("dd. MMMM yyyy", new System.Globalization.CultureInfo("de-CH"))
                    </div>
                    <strong class="notice-box__title">@n.Title</strong>
                    <p class="notice-box__content">@n.Content</p>
                </div>
                @if (latestNews.Count > 1)
                {
                    <p style="margin-top:.75rem;font-size:.85rem;color:var(--color-text-light)">
                        + @(latestNews.Count - 1) weitere Meldung(en) —
                        <a href="/news">alle anzeigen</a>
                    </p>
                }
            }
        </div>
    </section>
    <section class="home-card">
        <div class="home-card__header">
            <div>
                <div class="home-card__topline">Informationen</div>
                <h2>So funktioniert die Flomi App</h2>
            </div>
        </div>

        <div class="home-card__body">
            <p>
                Mit der Flomi App meldest du dich schnell und unkompliziert für deinen Einsatz am Pfadi-Flohmarkt an.
                Erstelle einmal ein Konto, wähle deinen Bereich — und fertig. Alle deine Anmeldungen hast du
                jederzeit übersichtlich im Blick.
            </p>

            <div class="info-grid">
                <article class="info-box">
                    <div class="info-box__icon">📋</div>
                    <h3>Bereiche auswählen</h3>
                    <p>
                        Durchsuche alle verfügbaren Bereiche für ein Event — mit Datum, Zeitslot, Standort und freien Plätzen.
                        Du kannst dich für <strong>mehrere Bereiche</strong> gleichzeitig anmelden und siehst sofort,
                        ob noch Platz frei ist.
                    </p>
                </article>

                <article class="info-box">
                    <div class="info-box__icon">👨‍👩‍👧</div>
                    <h3>Familie anmelden</h3>
                    <p>
                        Mit einem einzigen Konto kannst du auch <strong>Familienmitglieder</strong> anmelden.
                        Hinterlege einfach die Daten deiner Familie und wähle beim Registrieren die jeweilige Person aus —
                        ganz ohne separate Logins.
                    </p>
                </article>

                <article class="info-box">
                    <div class="info-box__icon">📊</div>
                    <h3>Dashboard</h3>
                    <p>
                        Im <strong>Dashboard</strong> siehst du alle deine Anmeldungen auf einen Blick, kannst Einsätze
                        absagen, Termine als ICS-Datei in deinen Kalender importieren und eine Übersicht per Mail anfordern.
                    </p>
                </article>

                <article class="info-box">
                    <div class="info-box__icon">🔒</div>
                    <h3>Deine Daten sind sicher</h3>
                    <p>
                        Die App wurde mit <strong>modernen Industriestandards</strong> entwickelt: verschlüsselte
                        Verbindung (HTTPS), gesichertes Login über ASP.NET Core Identity mit Brute-Force-Schutz
                        und passwortgeschützten Konten. Deine Daten werden ausschliesslich für die Organisation
                        des Flohmarkts verwendet.
                    </p>
                </article>
            </div>
        </div>
    </section>

    <section class="home-card">
        <div class="home-card__header">
            <div>
                <div class="home-card__topline">Hinweis</div>
                <h2>Gut zu wissen</h2>
            </div>
        </div>

        <div class="home-card__body">
            <div class="notice-box">
                <p>
                    Falls ein Bereich bereits <strong>ausgebucht</strong> ist, schau einfach nach einer anderen
                    spannenden Möglichkeit — es gibt viele verschiedene Einsatzbereiche. Bei Fragen melde dich
                    direkt beim Flomi-Team, wir helfen dir gerne weiter.
                </p>
            </div>

            <p class="home-closing">
                Vielen Dank für deine Unterstützung — wir freuen uns auf einen tollen Flohmarkt zusammen mit dir! 🙌
            </p>
        </div>
    </section>
</div>

@code {
    private string           welcomeText  = "Willkommen bei der Flomi App";
    private bool             isAuthenticated = false;
    private List<NewsItem>?  latestNews   = null;

    protected override async Task OnInitializedAsync()
    {
        latestNews = await NewsService.GetPublishedAsync();

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            isAuthenticated = true;

            var firstName =
                user.FindFirst(ClaimTypes.GivenName)?.Value ??
                user.FindFirst("FirstName")?.Value ??
                user.Identity?.Name;

            if (!string.IsNullOrWhiteSpace(firstName))
            {
                welcomeText = $"Hallo {firstName}, willkommen bei der Flomi App";
            }
            else
            {
                welcomeText = "Willkommen bei der Flomi App";
            }
        }
    }
}
@page "/"
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Willkommen</PageTitle>

<div class="home-page">
    <section class="home-hero">
        <div class="home-hero__content">
            <span class="home-hero__badge">Willkommen</span>
            <h1>@welcomeText</h1>
            <p class="home-hero__lead">
                Schön, dass du uns als Helfer/in, Sortierer/in oder Verkäufer/in unterstützen möchtest.
                Mit dieser App kannst du dich einfach für einen oder mehrere Einsätze anmelden.
            </p>

            <div class="home-hero__actions">
                @if (isAuthenticated)
                {
                    <a class="home-secondary-btn" href="/user/dashboard">Zum Dashboard</a>
                    <a class="home-secondary-btn" href="/user/settings">Meine Daten</a>
                }
                else
                {
                    <a class="home-primary-btn" href="/user/register">Jetzt anmelden</a>
                    <a class="home-secondary-btn" href="/Identity/Account/Login">Login</a>
                }
            </div>
        </div>
    </section>
    <section class="home-card">
        <div class="home-card__header">
            <div>
                <div class="home-card__topline">News</div>
                <h2>News</h2>
            </div>
        </div>

        <div class="home-card__body">
            <div class="notice-box">
                <p>
                    Der Flomi im 2027 findet nächstes Jahr <strong>früher</strong> statt als gewohnt, nämlich am 10. und 17. April 2027.
                    Daher empfehlen wir allen Helferinnen und Helfern, sich bereits jetzt für die Einsätze anzumelden, damit wir besser planen können.
                </p>
            </div>
        </div>
    </section>
    <section class="home-card">
        <div class="home-card__header">
            <div>
                <div class="home-card__topline">Informationen</div>
                <h2>So funktioniert die Flomi App</h2>
            </div>
        </div>

        <div class="home-card__body">
            <p>
                Besten Dank, dass du dich für die Unterstützung der Pfadi Flomi anmeldest.
                Das Formular begleitet dich durch die nächsten Schritte und passt sich dynamisch an deine Auswahl an.
            </p>

            <p>
                Das bedeutet: Je nachdem, für welchen Bereich du dich interessierst, werden dir nur die relevanten Seiten und Felder angezeigt.
                Wenn du zum Beispiel im Verkauf helfen möchtest, werden dir andere Bereiche übersprungen, die für dich nicht wichtig sind.
            </p>

            <div class="info-grid">
                <article class="info-box">
                    <div class="info-box__icon">🧭</div>
                    <h3>Eine Anmeldung</h3>
                    <p>
                        Mit der Flomi App kannst du dich mit einer einzigen Anmeldung für alle Einsätze registrieren, die dich interessieren.
                        So musst du nicht jedes Mal deine Daten neu eingeben, sondern kannst einfach die Bereiche auswählen. Ausserdem besteht
                        die Möglichkeit deine ganze <strong>Familie</strong> mit einem Login anzumelden.
                    </p>
                </article>

                <article class="info-box">
                    <div class="info-box__icon">📺</div>
                    <h3>Dashboard</h3>
                    <p>
                        Mit dem neuen <strong>Dashboard</strong> hast du jederzeit den Überblick über deine Anmeldungen, kannst diese verwalten und
                        siehst auf einen Blick, wie viele Plätze in den einzelnen Bereichen noch frei sind.
                    </p>
                </article>

                <article class="info-box">
                    <div class="info-box__icon">📰</div>
                    <h3>News</h3>
                    <p>
                        Mit der Flomi App bist du immer auf dem neuesten Stand, was die Planung und Organisation des Flohmarkts betrifft.
                        Alle wichtigen Informationen, wie zum Beispiel die Termine, die verfügbaren Bereiche und die Anzahl der freien Plätze,
                        findest du jederzeit in der App.
                    </p>
                </article>

                <article class="info-box">
                    <div class="info-box__icon">👥</div>
                    <h3>Verfügbare Plätze</h3>
                    <p>
                        Bei jeder Tätigkeit siehst du, wie viele Personen noch gesucht werden. Falls ein Bereich ausgebucht ist,
                        findest du bestimmt eine andere spannende Möglichkeit.
                    </p>
                </article>
            </div>
        </div>
    </section>

    <section class="home-card">
        <div class="home-card__header">
            <div>
                <div class="home-card__topline">Hinweis</div>
                <h2>Wichtig für dich</h2>
            </div>
        </div>

        <div class="home-card__body">
            <div class="notice-box">
                <p>
                    Falls dein gewünschter Bereich bereits als <strong>ausgebucht</strong> markiert ist,
                    wähle gerne einen anderen spannenden Einsatzbereich oder melde dich direkt bei uns —
                    gemeinsam finden wir bestimmt eine Lösung.
                </p>
            </div>

            <p class="home-closing">
                Nun wünsche ich dir viel Freude beim Ausfüllen und bedanke mich bereits jetzt herzlich für deine Unterstützung.
            </p>
        </div>
    </section>
</div>

@code {
    private string welcomeText = "Willkommen bei der Flomi App";
    private bool isAuthenticated = false;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            isAuthenticated = true;

            var firstName =
                user.FindFirst(ClaimTypes.GivenName)?.Value ??
                user.FindFirst("FirstName")?.Value ??
                user.Identity?.Name;

            if (!string.IsNullOrWhiteSpace(firstName))
            {
                welcomeText = $"Hallo {firstName}, willkommen bei der Flomi App";
            }
            else
            {
                welcomeText = "Willkommen bei der Flomi App";
            }
        }
    }
}
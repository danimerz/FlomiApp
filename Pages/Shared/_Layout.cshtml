@using Microsoft.AspNetCore.Hosting
@inject IWebHostEnvironment Environment
@inject Microsoft.AspNetCore.Identity.SignInManager<FlomiApp.Data.Models.ApplicationUser> SignInManager
<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FlomiApp</title>
    <link rel="stylesheet" href="/css/site.css" />
    <link rel="stylesheet" href="/css/register.css" />
</head>
<body>

    <nav class="flomi-nav">
        <div class="flomi-nav__inner">
            <a class="flomi-nav__brand" href="/">FlomiApp</a>

            <div class="flomi-nav__links">
                @if (SignInManager.IsSignedIn(User))
                {
                    <a class="flomi-nav__link" href="/user/dashboard">Dashboard</a>
                    <form method="post"
                          asp-area="Identity"
                          asp-page="/Account/Logout"
                          asp-route-returnUrl="/"
                          style="display:inline;">
                        <button type="submit" class="flomi-nav__link flomi-nav__link--btn">Logout</button>
                    </form>
                }
                else
                {
                    <a class="flomi-nav__link" href="/Identity/Account/Login">Login</a>
                    <a class="flomi-nav__link" href="/Identity/Account/Register">Registrieren</a>
                }
            </div>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <script src="~/Identity/lib/jquery/dist/jquery.js"></script>
    <script src="~/Identity/lib/bootstrap/dist/js/bootstrap.bundle.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
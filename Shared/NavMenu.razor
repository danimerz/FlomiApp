@using System.Security.Claims
@inject FlomiApp.Services.ThemeState ThemeState

<div class="navmenu-shell">
    <div class="navmenu-links" @onclick="HandleNavClick">
        <nav class="navmenu-list">
            <div class="navmenu-section">
                <div class="navmenu-section__label">Allgemein</div>

                <div class="navmenu-item">
                    <NavLink class="navmenu-link" href="" Match="NavLinkMatch.All">
                        <span class="navmenu-icon">⌂</span>
                        <span>Startseite</span>
                    </NavLink>
                </div>
            </div>

            <AuthorizeView Context="authState">
                <Authorized>
                    <div class="navmenu-section">
                        <div class="navmenu-section__label">Benutzer</div>

                        <div class="navmenu-item">
                            <NavLink class="navmenu-link" href="user/dashboard">
                                <span class="navmenu-icon">▦</span>
                                <span>Dashboard</span>
                            </NavLink>
                        </div>

                        <div class="navmenu-item">
                            <NavLink class="navmenu-link" href="user/register">
                                <span class="navmenu-icon">＋</span>
                                <span>Anmeldung</span>
                            </NavLink>
                        </div>

                        <div class="navmenu-item">
                            <NavLink class="navmenu-link" href="user/furniture-pickup">
                                <span class="navmenu-icon">🛋</span>
                                <span>Möbel Abholservice</span>
                            </NavLink>
                        </div>

                        <div class="navmenu-item">
                            <NavLink class="navmenu-link" href="user/settings">
                                <span class="navmenu-icon">⚙</span>
                                <span>Einstellungen</span>
                            </NavLink>
                        </div>

                    </div>

                    <AuthorizeView Roles="Admin">
                        <Authorized>
                            <div class="navmenu-section">
                                <div class="navmenu-section__label">Administration</div>

                                <!-- ── Gruppe: Übersicht ── -->
                                <button class="navmenu-group-header" @onclick='() => ToggleGroup("overview")'>
                                    <span>Übersicht</span>
                                    <span class="navmenu-group-chevron @(IsOpen("overview") ? "navmenu-group-chevron--open" : "")">▾</span>
                                </button>
                                @if (IsOpen("overview"))
                                {
                                    <div class="navmenu-group-body">
                                        <div class="navmenu-item">
                                            <NavLink class="navmenu-link" href="admin/dashboard">
                                                <span class="navmenu-icon">📊</span>
                                                <span>Dashboard</span>
                                            </NavLink>
                                        </div>
                                        <div class="navmenu-item">
                                            <NavLink class="navmenu-link" href="admin/appointments">
                                                <span class="navmenu-icon">📋</span>
                                                <span>Anmeldungen</span>
                                            </NavLink>
                                        </div>
                                    </div>
                                }

                                <!-- ── Gruppe: Event & Betrieb ── -->
                                <button class="navmenu-group-header" @onclick='() => ToggleGroup("event")'>
                                    <span>Event & Betrieb</span>
                                    <span class="navmenu-group-chevron @(IsOpen("event") ? "navmenu-group-chevron--open" : "")">▾</span>
                                </button>
                                @if (IsOpen("event"))
                                {
                                    <div class="navmenu-group-body">
                                        <div class="navmenu-item">
                                            <NavLink class="navmenu-link" href="admin/config">
                                                <span class="navmenu-icon">🗓</span>
                                                <span>Konfiguration</span>
                                            </NavLink>
                                        </div>
                                        <div class="navmenu-item">
                                            <NavLink class="navmenu-link" href="admin/vehicles">
                                                <span class="navmenu-icon">🚗</span>
                                                <span>Fahrzeuge</span>
                                            </NavLink>
                                        </div>
                                        <div class="navmenu-item">
                                            <NavLink class="navmenu-link" href="admin/furniture-pickup">
                                                <span class="navmenu-icon">📦</span>
                                                <span>Möbel Abholungen</span>
                                            </NavLink>
                                        </div>
                                    </div>
                                }

                                <!-- ── Gruppe: Community ── -->
                                <button class="navmenu-group-header" @onclick='() => ToggleGroup("community")'>
                                    <span>Community</span>
                                    <span class="navmenu-group-chevron @(IsOpen("community") ? "navmenu-group-chevron--open" : "")">▾</span>
                                </button>
                                @if (IsOpen("community"))
                                {
                                    <div class="navmenu-group-body">
                                        <div class="navmenu-item">
                                            <NavLink class="navmenu-link" href="admin/news">
                                                <span class="navmenu-icon">📢</span>
                                                <span>News</span>
                                            </NavLink>
                                        </div>
                                        <div class="navmenu-item">
                                            <NavLink class="navmenu-link" href="admin/users">
                                                <span class="navmenu-icon">👥</span>
                                                <span>Benutzerverwaltung</span>
                                            </NavLink>
                                        </div>
                                    </div>
                                }

                                <!-- ── Gruppe: Daten ── -->
                                <button class="navmenu-group-header" @onclick='() => ToggleGroup("data")'>
                                    <span>Daten</span>
                                    <span class="navmenu-group-chevron @(IsOpen("data") ? "navmenu-group-chevron--open" : "")">▾</span>
                                </button>
                                @if (IsOpen("data"))
                                {
                                    <div class="navmenu-group-body">
                                        <div class="navmenu-item">
                                            <NavLink class="navmenu-link" href="admin/export">
                                                <span class="navmenu-icon">📤</span>
                                                <span>Export</span>
                                            </NavLink>
                                        </div>
                                    </div>
                                }

                            </div>
                        </Authorized>
                    </AuthorizeView>

                    <div class="navmenu-mobile-theme">
                        <div class="navmenu-mobile-theme__label">Darstellung</div>

                        <div class="navmenu-mobile-theme__switch-row">
                            <button class="theme-switch @(ThemeState.CurrentTheme == "dark" ? "is-dark" : "is-light")"
                                    type="button"
                                    @onclick:stopPropagation="true"
                                    @onclick="ToggleTheme"
                                    aria-label="Theme umschalten">
                                <span class="theme-switch__track">
                                    <span class="theme-switch__icon theme-switch__icon--sun">☀</span>
                                    <span class="theme-switch__icon theme-switch__icon--moon">☾</span>
                                    <span class="theme-switch__thumb"></span>
                                </span>
                            </button>

                            <span class="theme-switch__label">
                                @(ThemeState.CurrentTheme == "dark" ? "Dark Mode" : "Light Mode")
                            </span>
                        </div>
                    </div>

                    <div class="navmenu-mobile-user">
                        <div class="navmenu-mobile-user__label">Konto</div>

                        <div class="navmenu-mobile-user__card">
                            <div class="navmenu-mobile-user__identity">
                                <div class="navmenu-mobile-user__avatar">
                                    @GetUserInitial(authState.User)
                                </div>

                                <div class="navmenu-mobile-user__meta">
                                    <span class="navmenu-mobile-user__status">Angemeldet</span>
                                    <span class="navmenu-mobile-user__name">@GetDisplayName(authState.User)</span>
                                </div>
                            </div>

                            <form method="post" action="Identity/Account/Logout"
                                  class="navmenu-mobile-user__logout"
                                  @onclick:stopPropagation="true">
                                <AntiforgeryToken />
                                <input type="hidden" name="ReturnUrl" value="/" />
                                <button type="submit" class="navmenu-mobile-user__logout-button">
                                    Abmelden
                                </button>
                            </form>
                        </div>
                    </div>
                </Authorized>
            </AuthorizeView>
        </nav>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnNavLinkClicked { get; set; }

    // ── Admin-Gruppen Collapse ─────────────────────────────────────────────
    private HashSet<string> openGroups = new();

    private bool IsOpen(string group) => openGroups.Contains(group);

    private void ToggleGroup(string group)
    {
        if (!openGroups.Remove(group))
            openGroups.Add(group);
    }

    private async Task HandleNavClick()
    {
        await OnNavLinkClicked.InvokeAsync();
    }

    private async Task ToggleTheme()
    {
        await ThemeState.ToggleAsync();
    }

    private string GetDisplayName(ClaimsPrincipal user)
    {
        return user.FindFirst(ClaimTypes.GivenName)?.Value
            ?? user.FindFirst("FirstName")?.Value
            ?? user.Identity?.Name
            ?? "Benutzer";
    }

    private string GetUserInitial(ClaimsPrincipal user)
    {
        var displayName = GetDisplayName(user);

        if (string.IsNullOrWhiteSpace(displayName))
            return "B";

        return displayName.Substring(0, 1).ToUpperInvariant();
    }
}
@inherits LayoutComponentBase
@implements IDisposable
@inject FlomiApp.Services.ThemeState ThemeState

<PageTitle>FlomiApp</PageTitle>

<div class="app-shell" data-theme="@ThemeState.CurrentTheme">
    <aside class="sidebar">
        <div class="sidebar__inner">
            <div class="sidebar__brand">
                <div class="sidebar__logo">
                    <img src="img/pfadi_logo.png" alt="Pfadi Flomi Logo" class="sidebar__logo-image" />
                </div>
                <div class="sidebar__brand-text">
                    <span class="sidebar__eyebrow"></span>
                    <strong>FlomiApp</strong>
                </div>
            </div>

            <div class="sidebar__nav">
                <NavMenu />
            </div>

            <div class="sidebar__theme-toggle sidebar__theme-toggle--desktop">
                <button class="theme-switch @(ThemeState.CurrentTheme == "dark" ? "is-dark" : "is-light")"
                        type="button"
                        @onclick="ToggleTheme"
                        aria-label="Theme umschalten">
                    <span class="theme-switch__track">
                        <span class="theme-switch__icon theme-switch__icon--sun">☀</span>
                        <span class="theme-switch__icon theme-switch__icon--moon">☾</span>
                        <span class="theme-switch__thumb"></span>
                    </span>
                </button>

                <span class="theme-switch__label">
                    @(ThemeState.CurrentTheme == "dark" ? "Dark Mode" : "Light Mode")
                </span>
            </div>

            <div class="sidebar-login-desktop">
                <LoginDisplay />
            </div>
        </div>
    </aside>

    <main class="main-area">
        <article class="content-container">
            @Body
        </article>
    </main>
</div>

@code {
    private bool _themeInitialized;

    protected override void OnInitialized()
    {
        ThemeState.OnChange += HandleThemeChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_themeInitialized)
        {
            _themeInitialized = true;
            await ThemeState.InitializeAsync();
        }
    }

    private async Task ToggleTheme()
    {
        await ThemeState.ToggleAsync();
    }

    private void HandleThemeChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ThemeState.OnChange -= HandleThemeChanged;
    }
}
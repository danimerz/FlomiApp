@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Components.Authorization
@using FlomiApp.Data.Models
@inject UserManager<ApplicationUser> UserManager

<AuthorizeView Context="authState">
    <Authorized>
        <div class="login-panel">
            <div class="login-panel__user">
                <div class="login-panel__avatar">
                    @GetUserInitial()
                </div>

                <div class="login-panel__meta">
                    <span class="login-panel__label">Angemeldet</span>
                    <span class="login-panel__name">@displayName</span>
                </div>
            </div>

            <form method="post" action="Identity/Account/Logout" class="login-panel__actions">
                <AntiforgeryToken />
                <input type="hidden" name="ReturnUrl" value="/" />
                <button type="submit" class="login-panel__button login-panel__button--secondary">
                    Abmelden
                </button>
            </form>
        </div>
    </Authorized>

    <NotAuthorized>
        <div class="login-panel">
            <div class="login-panel__meta login-panel__meta--guest">
                <span class="login-panel__label">Nicht angemeldet</span>
                <span class="login-panel__name">Bitte einloggen</span>
            </div>

            <div class="login-panel__actions login-panel__actions--stacked">
                <a href="Identity/Account/Login" class="login-panel__button login-panel__button--primary">
                    Anmelden
                </a>
            </div>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private string displayName = "Benutzer";

    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (AuthenticationStateTask is null)
            return;

        var authState = await AuthenticationStateTask;
        var principal = authState.User;

        if (principal?.Identity?.IsAuthenticated != true)
            return;

        var user = await UserManager.GetUserAsync(principal);

        if (user is null)
            return;

        if (!string.IsNullOrWhiteSpace(user.FirstName))
        {
            displayName = user.FirstName;
            return;
        }

        if (!string.IsNullOrWhiteSpace(user.UserName))
        {
            displayName = user.UserName;
            return;
        }

        if (!string.IsNullOrWhiteSpace(user.Email))
        {
            displayName = user.Email;
        }
    }

    private string GetUserInitial()
    {
        if (string.IsNullOrWhiteSpace(displayName))
            return "B";

        return displayName.Substring(0, 1).ToUpperInvariant();
    }
}
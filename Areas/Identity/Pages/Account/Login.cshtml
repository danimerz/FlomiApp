@page
@model LoginModel

@{
    ViewData["Title"] = "Anmelden";
}

<link rel="stylesheet" href="/css/register.css" />

<div class="register-page">
    <section class="register-hero">
        <div class="register-hero__content">
            <span class="register-hero__badge">Willkommen zurück</span>
            <h1>Anmelden</h1>
            <p>
                Melde dich mit deinem Konto bei der FlomiApp an, um auf Einsätze und Veranstaltungen zuzugreifen.
            </p>
        </div>
    </section>

    <section class="register-card">
        <div class="register-card__header">
            <div class="register-card__topline">Benutzerzugang</div>
            <h2>Kontoanmeldung</h2>
            <p>Gib deine E-Mail-Adresse und dein Passwort ein, um dich anzumelden.</p>
        </div>

        <div class="register-card__body">
            <form id="account" method="post" class="register-form">
                <div asp-validation-summary="ModelOnly" class="register-validation"></div>

                <div class="register-grid register-grid--full">
                    <div class="register-field">
                        <label asp-for="Input.Email" class="register-label"></label>
                        <input asp-for="Input.Email"
                               class="register-input"
                               autocomplete="username"
                               aria-required="true"
                               placeholder="name@example.com" />
                        <span asp-validation-for="Input.Email" class="register-error"></span>
                    </div>
                </div>

                <div class="register-grid register-grid--full">
                    <div class="register-field">
                        <label asp-for="Input.Password" class="register-label"></label>
                        <input asp-for="Input.Password"
                               type="password"
                               class="register-input"
                               autocomplete="current-password"
                               aria-required="true"
                               placeholder="Passwort" />
                        <span asp-validation-for="Input.Password" class="register-error"></span>
                    </div>
                </div>

                <div class="register-grid register-grid--full">
                    <div class="register-field">
                        <label asp-for="Input.RememberMe" class="register-label"></label>
                        <div class="register-checkbox">
                            <input asp-for="Input.RememberMe" />
                            <span>Angemeldet bleiben</span>
                        </div>
                        <span asp-validation-for="Input.RememberMe" class="register-error"></span>
                    </div>
                </div>

                <div class="register-actions">
                    <button id="login-submit" type="submit" class="register-button">Anmelden</button>
                </div>

                <div class="register-links">
                    <p>
                        <a id="forgot-password" asp-page="./ForgotPassword">Passwort vergessen?</a>
                    </p>
                    <p>
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Neuen Account erstellen</a>
                    </p>
                    <p>
                        <a id="resend-confirmation" asp-page="./ResendEmailConfirmation">Bestätigungs-E-Mail erneut senden</a>
                    </p>
                </div>
            </form>

            @if ((Model.ExternalLogins?.Count ?? 0) > 0)
            {
                <div style="margin-top: 2rem;">
                    <div class="register-card__topline">Externe Anmeldung</div>
                    <h2 style="margin-top: 0;">Alternative Anmeldung</h2>
                    <p style="margin-bottom: 1rem; color: #475569;">
                        Du kannst dich auch mit einem externen Dienst anmelden.
                    </p>

                    <form id="external-account"
                          asp-page="./ExternalLogin"
                          asp-route-returnUrl="@Model.ReturnUrl"
                          method="post"
                          class="register-form">
                        <div class="register-actions">
                            @foreach (var provider in Model.ExternalLogins!)
                            {
                                <button type="submit"
                                        class="register-button"
                                        name="provider"
                                        value="@provider.Name"
                                        title="Log in using your @provider.DisplayName account">
                                    @provider.DisplayName
                                </button>
                            }
                        </div>
                    </form>
                </div>
            }
        </div>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
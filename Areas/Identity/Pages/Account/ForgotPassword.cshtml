@page
@model ForgotPasswordModel

@{
    ViewData["Title"] = "Passwort zurücksetzen";
}

<link rel="stylesheet" href="/css/register.css" />
<style>
    .register-form { display: flex; flex-direction: column; gap: 1.25rem; }
    .form-group { display: flex; flex-direction: column; gap: .45rem; }
    .form-group label { font-size: .92rem; font-weight: 700; color: #374151; }
    .form-control-modern {
        display: block; width: 100%; height: 3.35rem; padding: 0 1rem;
        border: 1px solid #d1d5db; border-radius: 14px; background: #f9fafb;
        color: #111827; font-size: .97rem; box-sizing: border-box;
        transition: border-color .2s, box-shadow .2s;
    }
    .form-control-modern:focus {
        outline: none; border-color: #2563eb;
        box-shadow: 0 0 0 4px rgba(37,99,235,.12); background: #fff;
    }
    .register-submit-btn {
        display: flex; align-items: center; justify-content: center; gap: .5rem;
        width: 100%; padding: 1rem 1.5rem; border: none; border-radius: 16px;
        background: linear-gradient(135deg, #1d4ed8 0%, #2563eb 100%);
        color: #fff; font-size: 1rem; font-weight: 800; cursor: pointer;
        box-shadow: 0 4px 18px rgba(37,99,235,.28);
        transition: filter .18s, transform .18s; margin-top: .5rem;
    }
    .register-submit-btn:hover { filter: brightness(1.06); transform: translateY(-1px); }
    .register-validation { color: #dc2626; font-size: .88rem; margin-bottom: .5rem; }
    .register-field-error { color: #dc2626; font-size: .82rem; margin-top: .2rem; }
    .fp-back { display: inline-flex; align-items: center; gap: .4rem; margin-top: 1rem;
               font-size: .88rem; font-weight: 600; color: #2563eb; text-decoration: none; }
    .fp-back:hover { text-decoration: underline; }
</style>

<div class="register-page">
    <section class="register-hero">
        <div class="register-hero__content">
            <span class="register-hero__badge">Sicherheit</span>
            <h1>Passwort vergessen?</h1>
            <p>Gib deine E-Mail-Adresse ein und wir schicken dir einen Link zum Zurücksetzen.</p>
        </div>
    </section>

    <section class="register-card">
        <div class="register-card__header">
            <div class="register-card__topline">Passwort zurücksetzen</div>
            <h2>Reset-Link anfordern</h2>
            <p>Du erhältst eine E-Mail mit einem Link, mit dem du ein neues Passwort festlegen kannst.</p>
        </div>

        <div class="register-card__body">
            @if (Model.EmailSent)
            {
                <div style="text-align:center;padding:1.5rem 0">
                    <div style="font-size:3rem;margin-bottom:1rem">📧</div>
                    <h3 style="margin:0 0 .5rem;color:#111827">E-Mail gesendet!</h3>
                    <p style="color:#6b7280;font-size:.95rem;margin-bottom:1.5rem">
                        Falls ein Konto mit dieser Adresse existiert, erhältst du in Kürze eine E-Mail mit dem Reset-Link.
                    </p>
                    <a href="/Identity/Account/Login" class="fp-back">← Zurück zum Login</a>
                </div>
            }
            else
            {
                <form method="post" class="register-form">
                    <div asp-validation-summary="ModelOnly" class="register-validation"></div>

                    <div class="form-group">
                        <label asp-for="Input.Email">E-Mail-Adresse</label>
                        <input asp-for="Input.Email"
                               class="form-control-modern"
                               type="email"
                               autocomplete="username"
                               placeholder="name@example.com" />
                        <span asp-validation-for="Input.Email" class="register-field-error"></span>
                    </div>

                    <button type="submit" class="register-submit-btn">
                        📧 Reset-Link senden
                    </button>
                </form>

                <a href="/Identity/Account/Login" class="fp-back">← Zurück zum Login</a>
            }
        </div>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

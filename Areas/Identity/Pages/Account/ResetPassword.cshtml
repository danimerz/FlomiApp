@page
@model ResetPasswordModel

@{
    ViewData["Title"] = "Passwort zurücksetzen";
}

<link rel="stylesheet" href="/css/register.css" />
<style>
    /* ── Form classes not in register.css (scoped in Blazor components) ── */
    .register-form { display: flex; flex-direction: column; gap: 1.25rem; }

    .form-group { display: flex; flex-direction: column; gap: .45rem; }
    .form-group label { font-size: .92rem; font-weight: 700; color: #374151; }

    .form-control-modern {
        display: block;
        width: 100%;
        height: 3.35rem;
        padding: 0 1rem;
        border: 1px solid #d1d5db;
        border-radius: 14px;
        background: #f9fafb;
        color: #111827;
        font-size: .97rem;
        box-sizing: border-box;
        transition: border-color .2s, box-shadow .2s;
    }
    .form-control-modern:focus {
        outline: none;
        border-color: #2563eb;
        box-shadow: 0 0 0 4px rgba(37,99,235,.12);
        background: #ffffff;
    }
    .form-control-modern[readonly] { background: #f3f4f6; color: #6b7280; }

    .register-submit-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .5rem;
        width: 100%;
        padding: 1rem 1.5rem;
        border: none;
        border-radius: 16px;
        background: linear-gradient(135deg, #1d4ed8 0%, #2563eb 100%);
        color: #ffffff;
        font-size: 1rem;
        font-weight: 800;
        cursor: pointer;
        box-shadow: 0 4px 18px rgba(37,99,235,.28);
        transition: filter .18s, transform .18s;
        margin-top: .5rem;
    }
    .register-submit-btn:hover { filter: brightness(1.06); transform: translateY(-1px); }

    .register-validation { color: #dc2626; font-size: .88rem; margin-bottom: .5rem; }
    .register-field-error { color: #dc2626; font-size: .82rem; margin-top: .2rem; }

    /* ── Passwort-spezifisch ── */
    .pw-field-wrap {
        position: relative;
        display: flex;
        gap: .5rem;
        align-items: center;
    }
    .pw-field-wrap .form-control-modern {
        flex: 1;
        padding-right: 1rem;
    }
    .pw-icon-btn {
        flex-shrink: 0;
        height: 3.35rem;
        width: 3.35rem;
        border: 1px solid var(--color-border-form);
        border-radius: 14px;
        background: var(--color-surface-input);
        font-size: 1.1rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background .15s, border-color .15s;
    }
    .pw-icon-btn:hover {
        background: var(--color-primary-tint, #eff6ff);
        border-color: var(--color-primary, #2563eb);
    }
    .pw-icon-btn--spacer {
        visibility: hidden;
        pointer-events: none;
    }
    .pw-strength-bar {
        height: 5px;
        border-radius: 999px;
        margin-top: .4rem;
        background: var(--color-border-soft);
        overflow: hidden;
        transition: all .3s;
    }
    .pw-strength-fill {
        height: 100%;
        border-radius: 999px;
        transition: width .3s, background .3s;
    }
    .pw-strength-label {
        font-size: .8rem;
        font-weight: 600;
        margin-top: .25rem;
        display: block;
    }
    .pw-generated-hint {
        margin-top: .5rem;
        padding: .6rem .9rem;
        border-radius: 10px;
        background: var(--color-info-bg);
        border: 1px solid var(--color-info-border);
        color: var(--color-info-text);
        font-size: .85rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .5rem;
    }
    .pw-copy-btn {
        background: none;
        border: none;
        cursor: pointer;
        font-size: .85rem;
        color: var(--color-primary);
        font-weight: 700;
        padding: 0;
    }
    .pw-email-badge {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        padding: .6rem 1rem;
        border-radius: 12px;
        background: var(--color-surface-card-soft);
        border: 1px solid var(--color-border-soft);
        color: var(--color-text-medium);
        font-size: .92rem;
        font-weight: 600;
        width: 100%;
    }
</style>

<div class="register-page">
    <section class="register-hero">
        <div class="register-hero__content">
            <span class="register-hero__badge">Sicherheit</span>
            <h1>Neues Passwort festlegen</h1>
            <p>Wähle ein sicheres Passwort für dein FlomiApp-Konto.</p>
        </div>
    </section>

    <section class="register-card">
        <div class="register-card__header">
            <div class="register-card__topline">Passwort zurücksetzen</div>
            <h2>Neues Passwort</h2>
            <p>Gib dein Passwort ein oder generiere ein sicheres mit dem Würfel-Button.</p>
        </div>

        <div class="register-card__body">
            <form method="post" class="register-form" id="resetForm">
                <div asp-validation-summary="ModelOnly" class="register-validation"></div>
                <input asp-for="Input.Code" type="hidden" />
                <input asp-for="Input.UserId" type="hidden" />

                <!-- E-Mail (read-only, schön angezeigt) -->
                <div class="form-group">
                    <label>E-Mail</label>
                    <div class="pw-email-badge">
                        📧 <span id="emailDisplay"></span>
                    </div>
                    <input asp-for="Input.Email" type="hidden" id="emailHidden" autocomplete="username" />
                </div>

                <!-- Neues Passwort -->
                <div class="form-group">
                    <label asp-for="Input.Password">Neues Passwort</label>
                    <div class="pw-field-wrap">
                        <input asp-for="Input.Password"
                               id="pwInput"
                               class="form-control-modern"
                               type="password"
                               autocomplete="new-password"
                               placeholder="Mindestens 6 Zeichen"
                               oninput="updateStrength(this.value)" />
                        <button type="button" class="pw-icon-btn" onclick="togglePw('pwInput', this)" title="Passwort anzeigen">
                            👁️
                        </button>
                        <button type="button" class="pw-icon-btn" onclick="generatePw()" title="Sicheres Passwort generieren">
                            🎲
                        </button>
                    </div>
                    <div class="pw-strength-bar">
                        <div class="pw-strength-fill" id="strengthFill" style="width:0%"></div>
                    </div>
                    <span class="pw-strength-label" id="strengthLabel"></span>
                    <div class="pw-generated-hint" id="generatedHint" style="display:none">
                        <span id="generatedPwText"></span>
                        <button type="button" class="pw-copy-btn" onclick="copyPw()">📋 Kopieren</button>
                    </div>
                    <span asp-validation-for="Input.Password" class="register-field-error"></span>
                </div>

                <!-- Passwort bestätigen -->
                <div class="form-group">
                    <label asp-for="Input.ConfirmPassword">Passwort bestätigen</label>
                    <div class="pw-field-wrap">
                        <input asp-for="Input.ConfirmPassword"
                               id="pwConfirm"
                               class="form-control-modern"
                               type="password"
                               autocomplete="new-password"
                               placeholder="Passwort wiederholen" />
                        <button type="button" class="pw-icon-btn" onclick="togglePw('pwConfirm', this)" title="Passwort anzeigen">
                            👁️
                        </button>
                        <div class="pw-icon-btn pw-icon-btn--spacer"></div>
                    </div>
                    <span asp-validation-for="Input.ConfirmPassword" class="register-field-error"></span>
                </div>

                <button type="submit" class="register-submit-btn">
                    🔑 Passwort speichern
                </button>
            </form>
        </div>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // E-Mail aus hidden field in Badge zeigen
        document.addEventListener('DOMContentLoaded', function () {
            document.getElementById('emailDisplay').textContent =
                document.getElementById('emailHidden').value;
        });

        function togglePw(inputId, btn) {
            var inp = document.getElementById(inputId);
            var show = inp.type === 'password';
            inp.type = show ? 'text' : 'password';
            btn.textContent = show ? '🙈' : '👁️';
        }

        function generatePw() {
            // Jede Gruppe mind. 1× — entspricht den ASP.NET Identity-Regeln
            var upper   = 'ABCDEFGHJKLMNPQRSTUVWXYZ';
            var lower   = 'abcdefghjkmnpqrstuvwxyz';
            var digits  = '23456789';
            var special = '!#$%+-=?';
            var all     = upper + lower + digits + special;

            var pick = function(s) { return s[Math.floor(Math.random() * s.length)]; };

            // Garantierte Zeichen
            var pw = [pick(upper), pick(upper), pick(lower), pick(lower),
                      pick(digits), pick(digits), pick(special)];

            // Rest auffüllen auf 14 Zeichen
            while (pw.length < 14) pw.push(pick(all));

            // Mischen (Fisher-Yates)
            for (var i = pw.length - 1; i > 0; i--) {
                var j = Math.floor(Math.random() * (i + 1));
                var t = pw[i]; pw[i] = pw[j]; pw[j] = t;
            }

            var result = pw.join('');
            var inp  = document.getElementById('pwInput');
            var conf = document.getElementById('pwConfirm');
            inp.value  = result;
            conf.value = result;
            inp.type   = 'text';
            updateStrength(result);
            document.getElementById('generatedPwText').textContent = result;
            document.getElementById('generatedHint').style.display = 'flex';
        }

        function copyPw() {
            navigator.clipboard.writeText(document.getElementById('pwInput').value);
            document.querySelector('.pw-copy-btn').textContent = '✅ Kopiert';
            setTimeout(() => document.querySelector('.pw-copy-btn').textContent = '📋 Kopieren', 2000);
        }

        function updateStrength(pw) {
            var fill = document.getElementById('strengthFill');
            var label = document.getElementById('strengthLabel');
            var len = pw.length;
            var score = 0;
            if (len >= 6)  score++;
            if (len >= 10) score++;
            if (/[A-Z]/.test(pw)) score++;
            if (/[0-9]/.test(pw)) score++;
            if (/[^a-zA-Z0-9]/.test(pw)) score++;

            var configs = [
                { pct: '0%',   color: '#e5e7eb', text: '' },
                { pct: '25%',  color: '#ef4444', text: '⚠️ Schwach' },
                { pct: '50%',  color: '#f97316', text: '👍 Ausreichend' },
                { pct: '75%',  color: '#eab308', text: '✅ Gut' },
                { pct: '90%',  color: '#22c55e', text: '🔒 Sehr sicher' },
                { pct: '100%', color: '#16a34a', text: '🔒 Ausgezeichnet' }
            ];
            var c = configs[score] || configs[0];
            fill.style.width = c.pct;
            fill.style.background = c.color;
            label.textContent = len > 0 ? c.text : '';
            label.style.color = c.color;
        }
    </script>
}

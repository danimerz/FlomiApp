@page
@model FlomiApp.Areas.Identity.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Register";
}

<h1>Register</h1>

<div class="row">
    <div class="col-md-6">
        <form method="post">
            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="Input.Email"></label>
                <InputText asp-for="Input.Email" class="form-control" />
            </div>
            <div class="form-group">
                <label asp-for="Input.Password"></label>
                <InputText asp-for="Input.Password" type="password" class="form-control" />
            </div>
            <div class="form-group">
                <label asp-for="Input.ConfirmPassword"></label>
                <InputText asp-for="Input.ConfirmPassword" type="password" class="form-control" />
            </div>
            <div class="form-group">
                <label asp-for="Input.FirstName"></label>
                <InputText asp-for="Input.FirstName" class="form-control" />
            </div>
            <div class="form-group">
                <label asp-for="Input.LastName"></label>
                <InputText asp-for="Input.LastName" class="form-control" />
            </div>
            <div class="form-group">
                <label asp-for="Input.Pfadiname"></label>
                <InputText asp-for="Input.Pfadiname" class="form-control" />
            </div>
            <div class="form-group">
                <label asp-for="Input.Stufe"></label>
                <InputSelect asp-for="Input.Stufe" class="form-control">
                    <option value="">Choose stage</option>
                    <option value="Biber">Biber</option>
                    <option value="Wolf">Wolf</option>
                    <option value="Pfadi">Pfadi</option>
                    <option value="Pio">Pio</option>
                    <option value="Leiter">Leiter</option>
                    <option value="Sonstiges">Sonstiges</option>
                </InputSelect>
            </div>
            <div class="form-group">
                <label asp-for="Input.Birthday"></label>
                <InputDate asp-for="Input.Birthday" class="form-control" />
            </div>
            <div class="form-group">
                <label asp-for="Input.PhoneNumber"></label>
                <InputText asp-for="Input.PhoneNumber" placeholder="+41 41 750 06 49" class="form-control" />
            </div>
            <button type="submit" class="btn btn-primary">Register</button>
        </form>
    </div>
</div>

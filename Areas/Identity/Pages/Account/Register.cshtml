@page
@model FlomiApp.Areas.Identity.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Registrierung";
}

<link rel="stylesheet" href="/css/register.css" />

<div class="register-page">
    <section class="register-hero">
        <div class="register-hero__content">
            <span class="register-hero__badge">Konto erstellen</span>
            <h1>Registrierung</h1>
            <p>
                Erstelle dein Konto für die FlomiApp und hinterlege deine persönlichen Angaben.
                Danach kannst du dich für Einsätze und Veranstaltungen anmelden.
            </p>
        </div>
    </section>

    <section class="register-card">
        <div class="register-card__header">
            <div class="register-card__topline">Benutzerdaten</div>
            <h2>Persönliche Angaben</h2>
            <p>Fülle die Felder aus, um dein Benutzerkonto zu erstellen.</p>
        </div>

        <div class="register-card__body">
            <form method="post" class="register-form">

                @* ✅ Nur anzeigen wenn wirklich Fehler vorhanden *@
                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="All" class="register-validation"></div>
                }

                <div class="register-grid register-grid--full">
                    <div class="register-field">
                        <label asp-for="Input.Email" class="register-label">
                            Email <span class="register-required">*</span>
                        </label>
                        <input asp-for="Input.Email" class="register-input" />
                        <span asp-validation-for="Input.Email" class="register-error"></span>
                    </div>
                </div>

                <div class="register-grid">
                    <div class="register-field">
                        <label asp-for="Input.Password" class="register-label">
                            Passwort <span class="register-required">*</span>
                        </label>
                        <input asp-for="Input.Password" id="reg-pw" type="password"
                               class="register-input" oninput="updateRegPwStrength(this.value)" />
                        <div style="height:5px;border-radius:999px;background:#e2e8f0;margin-top:.4rem;overflow:hidden;">
                            <div id="reg-pw-bar" style="height:100%;border-radius:999px;width:0%;transition:width .3s,background .3s;"></div>
                        </div>
                        <span id="reg-pw-label" style="font-size:.78rem;font-weight:600;margin-top:.2rem;display:block;color:#94a3b8;"></span>
                        <ul style="margin:.4rem 0 0;padding-left:1.1rem;font-size:.8rem;color:#64748b;line-height:1.8;">
                            <li id="req-len">Mindestens 6 Zeichen</li>
                            <li id="req-upper">Mindestens 1 Grossbuchstabe</li>
                            <li id="req-digit">Mindestens 1 Ziffer</li>
                            <li id="req-special">Mindestens 1 Sonderzeichen (!@@#$...)</li>
                        </ul>
                        <span asp-validation-for="Input.Password" class="register-error"></span>
                    </div>

                    <div class="register-field">
                        <label asp-for="Input.ConfirmPassword" class="register-label">
                            Passwort bestätigen <span class="register-required">*</span>
                        </label>
                        <input asp-for="Input.ConfirmPassword" type="password" class="register-input" />
                        <span asp-validation-for="Input.ConfirmPassword" class="register-error"></span>
                    </div>
                </div>

                <div class="register-grid">
                    <div class="register-field">
                        <label asp-for="Input.FirstName" class="register-label">
                            Vorname <span class="register-required">*</span>
                        </label>
                        <input asp-for="Input.FirstName" class="register-input" />
                        <span asp-validation-for="Input.FirstName" class="register-error"></span>
                    </div>

                    <div class="register-field">
                        <label asp-for="Input.LastName" class="register-label">
                            Nachname <span class="register-required">*</span>
                        </label>
                        <input asp-for="Input.LastName" class="register-input" />
                        <span asp-validation-for="Input.LastName" class="register-error"></span>
                    </div>
                </div>

                <div class="register-grid">
                    <div class="register-field">
                        <label asp-for="Input.Pfadiname" class="register-label">
                            Pfadiname
                        </label>
                        <input asp-for="Input.Pfadiname" class="register-input" />
                        <span class="register-hint">Optional</span>
                        <span asp-validation-for="Input.Pfadiname" class="register-error"></span>
                    </div>

                    <div class="register-field">
                        <label asp-for="Input.Stufe" class="register-label">
                            Stufe <span class="register-required">*</span>
                        </label>
                        <select asp-for="Input.Stufe" class="register-input">
                            <option value="">Bitte wählen</option>
                            <option value="Biber">Biber</option>
                            <option value="Wolf">Wolf</option>
                            <option value="Pfadi">Pfadi</option>
                            <option value="Pio">Pio</option>
                            <option value="Leiter">Leiter</option>
                            <option value="Sonstiges">Sonstiges</option>
                        </select>
                        <span asp-validation-for="Input.Stufe" class="register-error"></span>
                    </div>
                </div>

                <div class="register-grid">
                    <div class="register-field">
                        <label asp-for="Input.Birthday" class="register-label">
                            Geburtstag <span class="register-required">*</span>
                        </label>
                        <input asp-for="Input.Birthday" type="date" class="register-input" />
                        <span asp-validation-for="Input.Birthday" class="register-error"></span>
                    </div>

                    <div class="register-field">
                        <label asp-for="Input.PhoneNumber" class="register-label">
                            Telefonnummer <span class="register-required">*</span>
                        </label>
                        <input asp-for="Input.PhoneNumber" class="register-input" placeholder="+41 79 999 99 99" />
                        <span asp-validation-for="Input.PhoneNumber" class="register-error"></span>
                    </div>
                </div>

                <div class="register-actions">
                    <button type="submit" class="register-button">Registrieren</button>
                </div>
            </form>
        </div>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function updateRegPwStrength(pw) {
            var bar   = document.getElementById('reg-pw-bar');
            var label = document.getElementById('reg-pw-label');
            var setReq = function(id, ok) {
                var el = document.getElementById(id);
                if (!el) return;
                el.style.color = ok ? '#16a34a' : '#94a3b8';
                el.style.fontWeight = ok ? '700' : '400';
            };

            var hasLen     = pw.length >= 6;
            var hasUpper   = /[A-Z]/.test(pw);
            var hasDigit   = /[0-9]/.test(pw);
            var hasSpecial = /[^a-zA-Z0-9]/.test(pw);

            setReq('req-len',     hasLen);
            setReq('req-upper',   hasUpper);
            setReq('req-digit',   hasDigit);
            setReq('req-special', hasSpecial);

            var score = [hasLen, hasUpper, hasDigit, hasSpecial].filter(Boolean).length;
            var configs = [
                { w: '0%',   c: '#e2e8f0', t: '' },
                { w: '25%',  c: '#ef4444', t: '⚠️ Schwach' },
                { w: '50%',  c: '#f97316', t: '👍 Ausreichend' },
                { w: '75%',  c: '#eab308', t: '✅ Gut' },
                { w: '100%', c: '#16a34a', t: '🔒 Sicher' }
            ];
            var cfg = configs[pw.length > 0 ? score : 0];
            bar.style.width      = cfg.w;
            bar.style.background = cfg.c;
            label.textContent    = cfg.t;
            label.style.color    = cfg.c;
        }
    </script>
}